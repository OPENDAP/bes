                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>A 32-bit count of sync pulses registered by the LRS FPGA.  The value of the pulse counter starts at 0x00000000, and rolls over to 0x00000000 when it increments from 0xFFFFFFFF.</Value>
                </Attribute>
