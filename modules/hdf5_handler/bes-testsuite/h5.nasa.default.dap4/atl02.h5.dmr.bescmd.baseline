                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0089-0090</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Value of register set in initialization command for the number of 10ns ticks between the range window start and range window stop for the weak spot.  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/dfc_hk/delta_time"/>
                </UInt16>
                <UInt32 name="alt_1pps_count">
                    <Dim name="/atlas/pce1/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>MET 1pps counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0012-0015</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>ATLAS flight s/w 1PPS counter  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/dfc_hk/delta_time"/>
                </UInt32>
                <Byte name="alt_dfc_status">
                    <Dim name="/atlas/pce1/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>DFC Status Bits</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0111</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>DFC Status Bits. Defined in ATLAS MEB PCE DFC FPGA Specification, ICESat-2-MEB-SPEC-0875, section 5.12  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/dfc_hk/delta_time"/>
                </Byte>
                <UInt16 name="alt_cal_fall">
                    <Dim name="/atlas/pce1/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Altimetric Latest Calibration Falling</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0052-0053</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The PCE latest calibration value for the falling edge. (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/dfc_hk/delta_time"/>
                </UInt16>
                <Attribute name="DODS_EXTRA" type="Container">
                    <Attribute name="Unlimited_Dimension" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                </Attribute>
                <Attribute name="Description" type="String">
                    <Value>This DFCx_hk is a diagnostic packet (APID 1072, 1088, 1104) that contains some of the parameters normally part of APID 1254, 1264, 1274 (as sequence flag 01).   Also know as the PCE Altimetric Science Data Major Frame described in ICESat-2-MEB-SPEC-0875, section 5.13 Table 19. The data in the group are neither calibrated nor EU-converted, but preserved from ATL01 in order provided diagnostics for TOF processing.</Value>
                </Attribute>
                <Attribute name="data_rate" type="String">
                    <Value>Data within this group are stored at the data rate of the source APID (nominally 50 Hz).</Value>
                </Attribute>
            </Group>
            <Group name="algorithm_science">
                <Dimension name="delta_time" size="21150"/>
                <Dimension name="ds_4bytes" size="4"/>
                <Dimension name="ds_2samples" size="2"/>
                <Int8 name="ds_2samples">
                    <Dim name="/atlas/pce1/algorithm_science/ds_2samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>DS for 2 bytes</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Dimension Scale</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Int8">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Int8">
                        <Value>2</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Dimension scale for an array of 2 samples.</Value>
                    </Attribute>
                </Int8>
                <Int8 name="ds_4bytes">
                    <Dim name="/atlas/pce1/algorithm_science/ds_4bytes"/>
                    <Attribute name="long_name" type="String">
                        <Value>DS for 4 bytes</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Dimension Scale</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Int8">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Int8">
                        <Value>4</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Dimension scale for an array of 4 bytes.</Value>
                    </Attribute>
                </Int8>
                <Float64 name="delta_time">
                    <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Elapsed GPS seconds</Value>
                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
                </Float64>
                <Float64 name="gps_time">
                    <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>GPS seconds at the Major Frame</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>GPS seconds at the Major Frame</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/algorithm_science/delta_time"/>
                </Float64>
                <Byte name="alt_band_mask">
                    <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Dim name="/atlas/pce1/algorithm_science/ds_4bytes"/>
                    <Attribute name="long_name" type="String">
                        <Value>Band Mask</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>ATLAS flight software Band Mask. Each byte corresponds to a single Band, in the order of 1-4.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Map name="/atlas/pce1/algorithm_science/ds_4bytes"/>
                </Byte>
                <Float64 name="amet_time">
                    <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>AMET seconds at the Major Frame</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>AMET seconds at the Major Frame</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/algorithm_science/delta_time"/>
                </Float64>
                <Byte name="useflag">
                    <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Science Mode Flag</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_alt_sci/</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Byte">
                        <Value>0</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Byte">
                        <Value>15</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Science Mode Flag.  Used by ATL03 to discard non-science mode data. 0=stby, 1=science_mode, 2=test, 3=manual, 4=radio, 5=unknown, &gt; 10=amcs_not_normal</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Attribute name="flag_meanings" type="String">
                        <Value>stby science test manual radio unknown unused unused unused unused stby_alt_amcs science_alt_amcs test_alt_amcs manual_alt_amcs radio_alt_amcs unknown_alt_amcs</Value>
                    </Attribute>
                    <Attribute name="flag_values" type="Byte">
                        <Value>0</Value>
                        <Value>1</Value>
                        <Value>2</Value>
                        <Value>3</Value>
                        <Value>4</Value>
                        <Value>5</Value>
                        <Value>6</Value>
                        <Value>7</Value>
                        <Value>8</Value>
                        <Value>9</Value>
                        <Value>10</Value>
                        <Value>11</Value>
                        <Value>12</Value>
                        <Value>13</Value>
                        <Value>14</Value>
                        <Value>15</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/algorithm_science/delta_time"/>
                </Byte>
                <UInt32 name="alt_band_channel_mask">
                    <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Dim name="/atlas/pce1/algorithm_science/ds_4bytes"/>
                    <Attribute name="long_name" type="String">
                        <Value>Band Channel Mask</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>ATLAS flight software Band Channel Mask. (Bands 1-4)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Map name="/atlas/pce1/algorithm_science/ds_4bytes"/>
                </UInt32>
                <UInt32 name="pce_mframe_cnt">
                    <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>PCE Major frame counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/algorithm_science/delta_time"/>
                </UInt32>
                <Byte name="alt_nbands">
                    <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Number of bands</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>ATLAS flight software Number of bands.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/algorithm_science/delta_time"/>
                </Byte>
                <Attribute name="DODS_EXTRA" type="Container">
                    <Attribute name="Unlimited_Dimension" type="String">
                        <Value>delta_time</Value>
                        <Value>ds_4bytes</Value>
                        <Value>ds_2samples</Value>
                    </Attribute>
                </Attribute>
                <Attribute name="Description" type="String">
                    <Value>The PCE PMF Algorithm Science data group. Contains outputs from the onboard receiver algorithm software.</Value>
                </Attribute>
                <Attribute name="data_rate" type="String">
                    <Value>Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)</Value>
                </Attribute>
                <Group name="weak">
                    <Byte name="alt_error_flags">
                        <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                        <Dim name="/atlas/pce1/algorithm_science/ds_2samples"/>
                        <Attribute name="source" type="String">
                            <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                        </Attribute>
                        <Attribute name="contentType" type="String">
                            <Value>referenceInformation</Value>
                        </Attribute>
                        <Attribute name="description" type="String">
                            <Value>FSW error flags</Value>
                        </Attribute>
                        <Attribute name="coordinates" type="String">
                            <Value>../delta_time</Value>
                        </Attribute>
                        <Attribute name="long_name" type="String">
                            <Value>Error Flags</Value>
                        </Attribute>
                        <Attribute name="units" type="String">
                            <Value>counts</Value>
                        </Attribute>
                        <Map name="/atlas/pce1/algorithm_science/delta_time"/>
                        <Map name="/atlas/pce1/algorithm_science/ds_2samples"/>
                    </Byte>
                    <Byte name="daynight_flag">
                        <Dim name="/atlas/pce1/algorithm_science/delta_time"/>
                        <Attribute name="long_name" type="String">
                            <Value>Day/Night flag</Value>
                        </Attribute>
                        <Attribute name="units" type="String">
