                        <Value>First Major Frame cosZ</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Cosine of the solar zenith angle</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce3/sxp_ssr_w/delta_time"/>
                    <Map name="/atlas/pce3/sxp_ssr_w/latitude"/>
                    <Map name="/atlas/pce3/sxp_ssr_w/longitude"/>
                </Float64>
                <UInt32 name="pce_mframe_cnt">
                    <Dim name="/atlas/pce3/sxp_ssr_w/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>PCE Major frame counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce3/sxp_ssr_w/delta_time"/>
                    <Map name="/atlas/pce3/sxp_ssr_w/latitude"/>
                    <Map name="/atlas/pce3/sxp_ssr_w/longitude"/>
                </UInt32>
                <Float64 name="cosb">
