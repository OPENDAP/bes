                        <Attribute name="source" type="String">
                            <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                        </Attribute>
                        <Attribute name="contentType" type="String">
                            <Value>referenceInformation</Value>
                        </Attribute>
                        <Attribute name="description" type="String">
                            <Value>ATLAS flight software Flywheel associated with the major frame.</Value>
                        </Attribute>
                        <Attribute name="coordinates" type="String">
                            <Value>../delta_time</Value>
                        </Attribute>
                        <Map name="/atlas/pce2/algorithm_science/delta_time"/>
                    </Byte>
                    <Byte name="signalflags">
                        <Dim name="/atlas/pce2/algorithm_science/delta_time"/>
                        <Attribute name="long_name" type="String">
                            <Value>Signal Found Flags</Value>
                        </Attribute>
                        <Attribute name="units" type="String">
                            <Value>counts</Value>
                        </Attribute>
                        <Attribute name="source" type="String">
                            <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                        </Attribute>
                        <Attribute name="contentType" type="String">
                            <Value>referenceInformation</Value>
                        </Attribute>
                        <Attribute name="description" type="String">
                            <Value>ATLAS flight s/w signal event flags associated with the major frame.</Value>
                        </Attribute>
                        <Attribute name="coordinates" type="String">
                            <Value>../delta_time</Value>
                        </Attribute>
                        <Map name="/atlas/pce2/algorithm_science/delta_time"/>
                    </Byte>
                    <Attribute name="Description" type="String">
                        <Value>The PCE PMF Algorithm Science data group. Contains outputs from the onboard receiver algorithm software.</Value>
                    </Attribute>
                    <Attribute name="data_rate" type="String">
                        <Value>Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)</Value>
                    </Attribute>
                </Group>
            </Group>
            <Group name="altimetry">
                <Dimension name="delta_time" size="21150"/>
                <Dimension name="ds_weak_channel_index" size="4"/>
                <Dimension name="ds_strong_channel_index" size="16"/>
                <Dimension name="ds_hist" size="199"/>
                <Float32 name="ds_hist">
                    <Dim name="/atlas/pce2/altimetry/ds_hist"/>
                    <Attribute name="long_name" type="String">
                        <Value>Histogram Dimension Scale</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL02</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Relative bin values of windowed, peak-centered TOF histograms. Peak value = 0</Value>
                    </Attribute>
                </Float32>
                <Float64 name="delta_time">
                    <Dim name="/atlas/pce2/altimetry/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Elapsed GPS seconds</Value>
                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
                </Float64>
                <Int8 name="ds_strong_channel_index">
                    <Dim name="/atlas/pce2/altimetry/ds_strong_channel_index"/>
                    <Attribute name="long_name" type="String">
                        <Value>DS for Strong Channels</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Dimension Scale</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Int8">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Int8">
                        <Value>16</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Dimension scale for strong channels.</Value>
                    </Attribute>
                </Int8>
                <Int8 name="ds_weak_channel_index">
                    <Dim name="/atlas/pce2/altimetry/ds_weak_channel_index"/>
                    <Attribute name="long_name" type="String">
                        <Value>DS for Weak Channels</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Dimension Scale</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Int8">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Int8">
                        <Value>4</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Dimension scale for weak channels.</Value>
                    </Attribute>
                </Int8>
                <Int8 name="ch_mask_s">
                    <Dim name="/atlas/pce2/altimetry/delta_time"/>
                    <Dim name="/atlas/pce2/altimetry/ds_strong_channel_index"/>
                    <Attribute name="long_name" type="String">
                        <Value>Channel Mask Strong</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_alt_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Channel Mask for DLBOs. The 16 flags are a logical OR of the two band offset masks for strong beam</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/altimetry/delta_time"/>
                    <Map name="/atlas/pce2/altimetry/ds_strong_channel_index"/>
                </Int8>
                <Float32 name="cal_rise_sm">
                    <Dim name="/atlas/pce2/altimetry/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Altimetric Latest Calibration Rising</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds/cell</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The smoothed, calibrated value for the rising edge used to convert cell counts to units of time.  time per cell count based on USO for each PCE.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/altimetry/delta_time"/>
                </Float32>
                <Float32 name="cal_fall_sm">
                    <Dim name="/atlas/pce2/altimetry/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Altimetric Latest Calibration Falling</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds/cell</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The smoothed, calibrated value for the falling edge used to convert cell counts to units of time.  time per cell count based on USO for each PCE.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/altimetry/delta_time"/>
                </Float32>
                <Byte name="useflag">
                    <Dim name="/atlas/pce2/altimetry/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Science Mode Flag</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_alt_sci/</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Byte">
                        <Value>0</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Byte">
                        <Value>15</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Science Mode Flag.  Used by ATL03 to discard non-science mode data. 0=stby, 1=science_mode, 2=test, 3=manual, 4=radio, 5=unknown, &gt; 10=amcs_not_normal</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Attribute name="flag_meanings" type="String">
                        <Value>stby science test manual radio unknown unused unused unused unused stby_alt_amcs science_alt_amcs test_alt_amcs manual_alt_amcs radio_alt_amcs unknown_alt_amcs</Value>
                    </Attribute>
                    <Attribute name="flag_values" type="Byte">
                        <Value>0</Value>
                        <Value>1</Value>
                        <Value>2</Value>
                        <Value>3</Value>
                        <Value>4</Value>
                        <Value>5</Value>
                        <Value>6</Value>
                        <Value>7</Value>
                        <Value>8</Value>
                        <Value>9</Value>
                        <Value>10</Value>
                        <Value>11</Value>
                        <Value>12</Value>
                        <Value>13</Value>
                        <Value>14</Value>
                        <Value>15</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/altimetry/delta_time"/>
                </Byte>
                <UInt32 name="pce_mframe_cnt">
                    <Dim name="/atlas/pce2/altimetry/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>PCE Major frame counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL02</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over. It is in the first time tag science packet. Used as part of the photon ID</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/altimetry/delta_time"/>
                </UInt32>
                <Int8 name="n_bands">
                    <Dim name="/atlas/pce2/altimetry/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Number Downlink Bands</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_alt_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Number of bands (in addition to the nominal 1 band) selected for downlink.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/altimetry/delta_time"/>
                </Int8>
                <Int8 name="ch_mask_w">
                    <Dim name="/atlas/pce2/altimetry/delta_time"/>
                    <Dim name="/atlas/pce2/altimetry/ds_weak_channel_index"/>
                    <Attribute name="long_name" type="String">
                        <Value>Channel Mask Weak</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_alt_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Channel Mask for DLBOs. The 4 flags are a logical OR of the two band offset masks for weak beam</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/altimetry/delta_time"/>
                    <Map name="/atlas/pce2/altimetry/ds_weak_channel_index"/>
                </Int8>
                <Attribute name="DODS_EXTRA" type="Container">
                    <Attribute name="Unlimited_Dimension" type="String">
                        <Value>delta_time</Value>
                        <Value>ds_weak_channel_index</Value>
                        <Value>ds_strong_channel_index</Value>
                        <Value>ds_hist</Value>
                    </Attribute>
                </Attribute>
                <Attribute name="Description" type="String">
                    <Value>The PCE Altimetry Science Packet data common to both beams (PCEx_ALT_SCI_TLM_MID in APID 1254, 1264, 1274 sequence flag 01 (once per major frame). (see ICESat-2-MEB-SPEC-0875, section 5.12, Spacewire: Major Frame Packet Data Format</Value>
                </Attribute>
                <Attribute name="data_rate" type="String">
                    <Value>Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)</Value>
                </Attribute>
                <Group name="weak">
                    <Float32 name="band2_width">
                        <Dim name="/atlas/pce2/altimetry/delta_time"/>
