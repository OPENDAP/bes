            </Attribute>
            <Attribute name="description" type="String">
                <Value>The ending orbit number associated with the data contained within this granule. The orbit number increments each time the spacecraft completes a full orbit of the Earth.</Value>
            </Attribute>
        </Int32>
        <Int32 name="start_cycle">
            <Dim size="1"/>
            <Attribute name="long_name" type="String">
                <Value>Starting Cycle</Value>
            </Attribute>
            <Attribute name="units" type="String">
                <Value>1</Value>
