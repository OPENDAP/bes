                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
                </Float64>
                <Int8 name="ds_50samples">
                    <Dim name="/atlas/pce3/sxp_ssr_w/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>DS for 50 bytes</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Int8">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Int8">
                        <Value>50</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Dimension scale for an array of 50 samples.</Value>
                    </Attribute>
