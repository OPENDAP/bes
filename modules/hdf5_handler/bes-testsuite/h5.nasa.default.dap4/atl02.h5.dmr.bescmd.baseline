            </Int8>
            <UInt16 name="sdoverrun">
                <Dim name="/lrs/hk_1120/delta_time"/>
                <Attribute name="long_name" type="String">
                    <Value>LRS_HK SD Processing Overruns</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>LRS_HK</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>This 16-bit counter is incremented each time the Application Mode is still processing Stellar-Side data when a new LRS cycle starts that should include new Stellar-Side data collection.  This overrun condition is a warning, which indicates that some processor activity did not complete in the allocated time and may delay reporting of the next stellar data packets.  This counter starts at 0x0000, and rolls over to 0x0000 when it increments from 0xFFFF.  This counter will be reset at Application Mode initialization and by an Application Reset Counters Command (LRScmRSTCNT).</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/lrs/hk_1120/delta_time"/>
            </UInt16>
