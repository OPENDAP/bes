                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>This 32-bit counter is incremented each time a spacewire command word is skipped by Failsafe Mode to reach a valid packet sync (an abnormal condition).  It starts at 0x00000000, and rolls over to 0x00000000 when it increments from 0xFFFFFFFF.  This counter will be reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT).</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/lrs/hk_1120/delta_time"/>
            </UInt32>
