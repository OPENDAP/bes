                    <Value>pixels/sec</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>LRS_HK</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>X component (tip/tilt) of the stellar rate pattern estimate.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/lrs/hk_1120/delta_time"/>
            </Float32>
            <UInt16 name="cmderrcnt">
                <Dim name="/lrs/hk_1120/delta_time"/>
                <Attribute name="long_name" type="String">
                    <Value>LRS_HK User Command Error Counter</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>LRS_HK</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>The 16-bit User Command Error Counter is incremented every time the Failsafe Mode has one or more command verification or processing errors with the corresponding command type (abnormal conditions).  The counter starts at 0x0000, and rolls over to 0x0000 when it increments from 0xFFFF.  The counter increments only once per command when there is at least one verification/processing error for that command.  CMDERRCODE will indicate the type of error.  The counter is reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT).</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/lrs/hk_1120/delta_time"/>
            </UInt16>
