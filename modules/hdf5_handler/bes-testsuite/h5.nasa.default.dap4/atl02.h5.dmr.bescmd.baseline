        <Group name="solar_array">
            <Dimension name="delta_time" size="423"/>
            <Float64 name="delta_time">
                <Dim name="/sc/solar_array/delta_time"/>
                <Attribute name="long_name" type="String">
                    <Value>Elapsed GPS seconds</Value>
                </Attribute>
                <Attribute name="standard_name" type="String">
                    <Value>time</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>seconds since 2018-01-01</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Derived via Time Tagging</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>SC time at the initiation of the ACS task, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                </Attribute>
            </Float64>
            <Float32 name="azimuth_meas_1">
