                    <Value>Channel Status Record (CSR) - Carrier Loop Mode) - Single Frequency Channel 1-24. 0 = No carrier loop activities; 1 = Carrier acquisition ongoing; 2 = Carrier tracking ongoing; 3 = Carrier acquisition error. Note: num_valid_slots indicate the number of channel that actual valid to use.  the remaining unused data fields are zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>no_activities acquisition tracking acq_error</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int8">
                    <Value>0</Value>
                    <Value>1</Value>
                    <Value>2</Value>
                    <Value>3</Value>
                </Attribute>
                <Map name="/gpsr/channel_status/delta_time"/>
                <Map name="/gpsr/channel_status/ds_24_slots"/>
            </Int8>
            <Int8 name="carrier_loop_disc_ff">
                <Dim name="/gpsr/channel_status/delta_time"/>
                <Dim name="/gpsr/channel_status/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CSR Carrier Loop Discriminator Final Flag</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc4/gpsr/channel_status</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Channel Status Record (CSR) - Carrier Loop Discriminator (CrLD) Final Flag (FF) - Single Frequency Channel 1-24. 0 = Carrier loop discriminator not final, 1 = Final carrier loop discriminator applied. Note: num_valid_slots indicate the number of channel that actual valid to use.  the remaining unused data fields are zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>not_final applied</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int8">
                    <Value>0</Value>
                    <Value>1</Value>
                </Attribute>
                <Map name="/gpsr/channel_status/delta_time"/>
                <Map name="/gpsr/channel_status/ds_24_slots"/>
            </Int8>
            <Int8 name="sv_id">
                <Dim name="/gpsr/channel_status/delta_time"/>
                <Dim name="/gpsr/channel_status/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CSR Space Vehicle ID</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc4/gpsr/channel_status</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>32</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Channel Status Record (CSR) - Space Vehicle ID. (0 = No signal acquisition or tracking;  1-32 = GPS SVs. All other values invalid). Note: num_valid_slots indicate the number of channel that actual valid to use.  the remaining unused data fields are zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/gpsr/channel_status/delta_time"/>
                <Map name="/gpsr/channel_status/ds_24_slots"/>
            </Int8>
            <Attribute name="DODS_EXTRA" type="Container">
                <Attribute name="Unlimited_Dimension" type="String">
                    <Value>delta_time</Value>
                    <Value>ds_24_slots</Value>
                </Attribute>
            </Attribute>
            <Attribute name="Description" type="String">
                <Value>Contains parameters related to Channel Status record (CSR).</Value>
            </Attribute>
            <Attribute name="data_rate" type="String">
                <Value>Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)</Value>
            </Attribute>
        </Group>
        <Group name="code_phase">
            <Dimension name="delta_time" size="423"/>
            <Dimension name="ds_24_slots" size="24"/>
            <Int8 name="ds_24_slots">
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>DS for 24 slots</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Dimension Scale</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>24</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Dimension scale representing each of the 24 slots.</Value>
                </Attribute>
            </Int8>
            <Float64 name="delta_time">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Attribute name="long_name" type="String">
                    <Value>Elapsed GPS seconds</Value>
                </Attribute>
                <Attribute name="standard_name" type="String">
                    <Value>time</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>seconds since 2018-01-01</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Derived via Time Tagging</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Time, in seconds since the ATLAS SDP GPS Epoch, computed from raw_gps_time_sec and subseconds in the time correlation group. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                </Attribute>
            </Float64>
            <Int8 name="num_valid_slots">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Attribute name="long_name" type="String">
                    <Value>Number of slots filled</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase/dfh_x/raw_num_recs</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>24</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Number of the 24 available slots filled by telemetry.  Data values after the number of valid slots are filled with 0. Note: Valid data records will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused data fields within the arrays will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
            </Int8>
            <UInt64 name="code_chip_count">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR Chip Count</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - Number of Code Chips Since Start of GPS Week.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </UInt64>
            <Int8 name="antenna_id">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR Antenna Identifier</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - Antenna Identifier.  0 = First Antenna  1 = Second Antenna (invalid for present receiver)  All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>first_antenna second_antenna</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int8">
                    <Value>0</Value>
                    <Value>1</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </Int8>
            <Int8 name="smooth_flg">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR Smoothing Flag</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - Smoothing Flag. 0 = Smoothing Not Applied 1 = Carrier phase-based smoothing applied for the reported code phase.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>not_applied applied</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int8">
                    <Value>0</Value>
                    <Value>1</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </Int8>
            <Float32 name="code_chip_fract">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR Fractional Chip Count</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase converted</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - Fractional Portion of Number of Code Chips Since Start of GPS Week.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </Float32>
            <Int8 name="constell_id">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR Constellation ID</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - Constellation ID - Single Frequency Channel 1-24 (0 = GPS Constellation; All other values invalid).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </Int8>
            <Int8 name="signal_type">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR GPS Signal Type</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>6</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - GPS Signal Type. 0 = GPS L1 C/A  1 = GPS L1 P   2 = GPS L2 C/A (N/A for present receiver)   3 = GPS L2 P   4 = GPS L2 CM   5 = GPS L2 CL (N/A for present receiver)   6 = No signal processing on this channel   All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>gps_l1a_ca gps_l1_p gps_l2_ca gps_l2_p gps_l2_cm gps_l2_cl no_signal_processing</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int8">
                    <Value>0</Value>
                    <Value>1</Value>
                    <Value>2</Value>
                    <Value>3</Value>
                    <Value>4</Value>
                    <Value>5</Value>
                    <Value>6</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </Int8>
            <Int8 name="deter_f">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR Deterioration Flag</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - Deterioration Flag.  0= Carrier Loop Lock Steady   1 = Carrier Loop Lock Unsteady (Measurement data may be deteriorated).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>steady unsteady</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int8">
                    <Value>0</Value>
                    <Value>1</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </Int8>
            <Int8 name="channel_num">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR Channel Number</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>23</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - Channel Number. 0 to 23;  All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </Int8>
            <Int8 name="sv_id">
                <Dim name="/gpsr/code_phase/delta_time"/>
                <Dim name="/gpsr/code_phase/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CDPDR Space Vehicle ID</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>counts</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc3/gpsr/code_phase</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>32</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Code Phase Data Record (CdPDR) - Space Vehicle ID. (0 = No signal acquisition or tracking;  1-32 = GPS SVs. All other values invalid).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs &lt; 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/gpsr/code_phase/delta_time"/>
                <Map name="/gpsr/code_phase/ds_24_slots"/>
            </Int8>
            <Attribute name="DODS_EXTRA" type="Container">
                <Attribute name="Unlimited_Dimension" type="String">
                    <Value>delta_time</Value>
                    <Value>ds_24_slots</Value>
                </Attribute>
            </Attribute>
            <Attribute name="Description" type="String">
                <Value>Contains parameters related to Code Phase Data Record (CdPDR).</Value>
            </Attribute>
            <Attribute name="data_rate" type="String">
                <Value>Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)</Value>
            </Attribute>
        </Group>
        <Group name="navigation">
            <Dimension name="delta_time" size="423"/>
            <Float64 name="longitude">
