                        <Value>1</Value>
                    </Attribute>
                </Int32>
                <Int32 name="too_few_tx">
                    <Dim size="1"/>
                    <Attribute name="long_name" type="String">
                        <Value>Too_Few_Tx_in_MFrame</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Tx processing</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>qualityInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The number of major frames with less than 199 Tx. The photons associated with these major frames have been discarded from processing.</Value>
                    </Attribute>
                </Int32>
                <Float32 name="st_period">
                    <Dim size="1"/>
                    <Attribute name="long_name" type="String">
                        <Value>Sawtooth_Period</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1/frequency</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>qualityInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Period of the Tx sawtooth.</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>TxRx detection</Value>
                    </Attribute>
                </Float32>
                <UInt32 name="end_mframe_cnt">
                    <Dim size="1"/>
                    <Attribute name="long_name" type="String">
                        <Value>Ending major frame counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>TxRx detection</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>qualityInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Major frame count at the end of a Tx misalignment.</Value>
                    </Attribute>
                </UInt32>
                <Int32 name="n_dnf">
                    <Dim size="1"/>
                    <Attribute name="long_name" type="String">
                        <Value>Number_of_DNF</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Tx processing</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>qualityInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The number of major frames containing a DNF flag, which indicates that the major frame was truncated. By default, these partial major frames are removed from processing.</Value>
                    </Attribute>
                </Int32>
                <Float32 name="slip_magnitude">
                    <Dim size="1"/>
                    <Attribute name="long_name" type="String">
                        <Value>TXRX_Slip_Magnitude</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>TxRx detection</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>qualityInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Average magnitude (and direction) of Tx sawtooth misalignment.</Value>
                    </Attribute>
                </Float32>
                <Float64 name="ne_delta_time">
                    <Dim size="4"/>
                    <Attribute name="_FillValue" type="Float64">
                        <Value>1.7976931348623157e+308</Value>
                    </Attribute>
                    <Attribute name="long_name" type="String">
                        <Value>Nested Exit Times</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>TxRx slip</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>auxiliaryInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Times of up to 4 NestedExit instances. Units are the number of seconds since the ATLAS SDP epoch.</Value>
                    </Attribute>
                </Float64>
                <Int32 name="st_conf">
                    <Dim size="1"/>
                    <Attribute name="long_name" type="String">
                        <Value>Tx Align Confidence</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>TxRx detection</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>qualityInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Confidence level set by Tx alignment (sawtooth) checks.</Value>
                    </Attribute>
                </Int32>
                <Attribute name="Description" type="String">
                    <Value>Per-PCE TOF flags and statistics</Value>
                </Attribute>
            </Group>
        </Group>
    </Group>
    <Group name="sc">
        <Dimension name="delta_time" size="423"/>
        <Float64 name="delta_time">
            <Dim name="/sc/delta_time"/>
            <Attribute name="long_name" type="String">
                <Value>Elapsed GPS seconds</Value>
            </Attribute>
            <Attribute name="standard_name" type="String">
                <Value>time</Value>
            </Attribute>
            <Attribute name="units" type="String">
                <Value>seconds since 2018-01-01</Value>
            </Attribute>
            <Attribute name="source" type="String">
                <Value>Derived via Time Tagging</Value>
            </Attribute>
            <Attribute name="contentType" type="String">
                <Value>referenceInformation</Value>
            </Attribute>
            <Attribute name="description" type="String">
                <Value>Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS Standard Data Product (SDP) epoch. By adding atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch time can be computed.</Value>
            </Attribute>
        </Float64>
        <UInt32 name="sc_time_1pps_sec">
            <Dim name="/sc/delta_time"/>
            <Attribute name="long_name" type="String">
                <Value>SC time at 1 pps (sec)</Value>
            </Attribute>
            <Attribute name="units" type="String">
                <Value>seconds</Value>
            </Attribute>
            <Attribute name="source" type="String">
                <Value>ATL01/sc</Value>
            </Attribute>
            <Attribute name="contentType" type="String">
                <Value>referenceInformation</Value>
            </Attribute>
            <Attribute name="description" type="String">
                <Value>SC time at the reception of the last 1PPS signal from the GPSR (seconds since SC epoch: 6-Jan-1980 00:00:00)</Value>
            </Attribute>
            <Attribute name="coordinates" type="String">
                <Value>delta_time</Value>
            </Attribute>
            <Map name="/sc/delta_time"/>
        </UInt32>
        <UInt32 name="sc_time_1pps_subsec">
            <Dim name="/sc/delta_time"/>
            <Attribute name="long_name" type="String">
                <Value>SC time at 1 pps (subsec)</Value>
            </Attribute>
            <Attribute name="units" type="String">
                <Value>100 nanoseconds</Value>
            </Attribute>
            <Attribute name="source" type="String">
                <Value>ATL01/sc</Value>
            </Attribute>
            <Attribute name="contentType" type="String">
                <Value>referenceInformation</Value>
            </Attribute>
            <Attribute name="description" type="String">
                <Value>Subsecond portion of the SC time at the reception of the last 1PPS signal from the GPSR (seconds since SC epoch: 6-Jan-1980 00:00:00)</Value>
            </Attribute>
            <Attribute name="coordinates" type="String">
                <Value>delta_time</Value>
            </Attribute>
            <Map name="/sc/delta_time"/>
        </UInt32>
        <UInt32 name="acs_time_subsec">
            <Dim name="/sc/delta_time"/>
            <Attribute name="long_name" type="String">
                <Value>ACS time (subsec)</Value>
            </Attribute>
            <Attribute name="units" type="String">
                <Value>100 nanoseconds</Value>
            </Attribute>
            <Attribute name="source" type="String">
                <Value>ATL01/sc</Value>
            </Attribute>
            <Attribute name="contentType" type="String">
                <Value>referenceInformation</Value>
            </Attribute>
            <Attribute name="description" type="String">
                <Value>Subsecond portion of the SC time at the initiation of the ACS task (seconds since SC epoch: 6-Jan-1980 00:00:00) (Same time provided within the Attitude/Rate message to ATLAS in RT at 1Hz)</Value>
            </Attribute>
            <Attribute name="coordinates" type="String">
                <Value>delta_time</Value>
            </Attribute>
            <Map name="/sc/delta_time"/>
        </UInt32>
        <UInt32 name="acs_time_sec">
            <Dim name="/sc/delta_time"/>
            <Attribute name="long_name" type="String">
                <Value>ACS time (sec)</Value>
            </Attribute>
            <Attribute name="units" type="String">
                <Value>seconds</Value>
            </Attribute>
            <Attribute name="source" type="String">
                <Value>ATL01/sc</Value>
            </Attribute>
            <Attribute name="contentType" type="String">
                <Value>referenceInformation</Value>
            </Attribute>
            <Attribute name="description" type="String">
                <Value>SC time at the initiation of the ACS task (seconds since SC epoch: 6-Jan-1980 00:00:00) (Same time provided within the Attitude/Rate message to ATLAS in RT at 1Hz)</Value>
            </Attribute>
            <Attribute name="coordinates" type="String">
                <Value>delta_time</Value>
            </Attribute>
            <Map name="/sc/delta_time"/>
        </UInt32>
        <Attribute name="DODS_EXTRA" type="Container">
            <Attribute name="Unlimited_Dimension" type="String">
                <Value>delta_time</Value>
            </Attribute>
        </Attribute>
        <Attribute name="Description" type="String">
            <Value>Group contains the Spacecraft (SC) Ancillary Science packet #1 decommutated data</Value>
        </Attribute>
        <Attribute name="data_rate" type="String">
            <Value>Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)</Value>
        </Attribute>
        <Group name="ephemeris">
            <Dimension name="delta_time" size="423"/>
