            </Float32>
            <Int8 name="trackstat_f">
                <Dim name="/lrs/stellar_centroid/delta_time"/>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>LRS_LCENT Tracking status</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>LRS_LCENT</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>1</Value>
