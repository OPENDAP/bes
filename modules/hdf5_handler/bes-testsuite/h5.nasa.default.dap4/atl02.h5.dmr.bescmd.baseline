                    <Value>1</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int32">
                    <Value>2</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>auxiliaryInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>WTOM Tuning Flag (1=standard method, 2=alternate method)</Value>
                </Attribute>
