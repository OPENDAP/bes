                <Attribute name="valid_max" type="Int32">
                    <Value>2</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>auxiliaryInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Indicates if the active PDU is side a (1) or side b (2).</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>a b</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int32">
                    <Value>1</Value>
                    <Value>2</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Derived, L1B ATBD</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int32">
                    <Value>1</Value>
                </Attribute>
            </Int32>
            <Int32 name="spd_ab_flag">
                <Dim size="1"/>
