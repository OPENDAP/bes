                    </Attribute>
                </Float64>
                <Float64 name="longitude">
                    <Dim name="/atlas/pce3/sxp_ssr_w/delta_time"/>
                    <Dim name="/atlas/pce3/sxp_ssr_w/ds_50samples"/>
