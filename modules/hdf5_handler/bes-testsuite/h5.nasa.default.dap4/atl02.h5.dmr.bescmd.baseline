                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Command success counter.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/pmf_hk/delta_time"/>
                </Byte>
                <Byte name="activeknobstable">
