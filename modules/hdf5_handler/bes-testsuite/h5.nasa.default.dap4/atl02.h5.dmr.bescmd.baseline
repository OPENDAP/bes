                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/sc2/star_tracker/optical_head_1</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Star Tracker Optical Head (STOH) 1 [ATM TM#7: Subaddress 19] - External Time Reference (ETR) counter - Used to determine measurement time of reported quaternions with respect to SC- provided sync pulse; This item increments upon the reception of the SC-provided sync pulse.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/sc/star_tracker/optical_head_1/delta_time"/>
                </UInt16>
                <Float32 name="att_qa_z">
                    <Dim name="/sc/star_tracker/optical_head_1/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>STOH Attitude Quality (Z)</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>arcsec</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/sc2/star_tracker/optical_head_1 converted</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
