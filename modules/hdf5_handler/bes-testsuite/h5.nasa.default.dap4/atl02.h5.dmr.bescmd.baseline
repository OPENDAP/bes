                    <Value>PCE Diagnostic Telemetry Packet from one of the following APIDs : 1073, 1089, 1105 (each APID is associated with a specific PCE). Packet Frequency is 1 Hertz.</Value>
                </Attribute>
            </Group>
            <Group name="sxp_ssr_w">
                <Dimension name="delta_time" size="423"/>
                <Dimension name="ds_50samples" size="50"/>
                <Float64 name="delta_time">
                    <Dim name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Elapsed GPS seconds</Value>
                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
                </Float64>
                <Int8 name="ds_50samples">
                    <Dim name="/atlas/pce1/sxp_ssr_w/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>DS for 50 bytes</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Int8">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Int8">
                        <Value>50</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Dimension scale for an array of 50 samples.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                </Int8>
                <Float64 name="latitude">
                    <Dim name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Dim name="/atlas/pce1/sxp_ssr_w/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>latitude</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>degrees</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Latitude</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                </Float64>
                <Float64 name="longitude">
                    <Dim name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Dim name="/atlas/pce1/sxp_ssr_w/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>longitude</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>degrees</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Longitude</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                </Float64>
                <Float64 name="mf_cosz">
                    <Dim name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>First Major Frame cosZ</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Cosine of the solar zenith angle</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Map name="/atlas/pce1/sxp_ssr_w/latitude"/>
                    <Map name="/atlas/pce1/sxp_ssr_w/longitude"/>
                </Float64>
                <UInt32 name="pce_mframe_cnt">
                    <Dim name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>PCE Major frame counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Map name="/atlas/pce1/sxp_ssr_w/latitude"/>
                    <Map name="/atlas/pce1/sxp_ssr_w/longitude"/>
                </UInt32>
                <Float64 name="cosb">
                    <Dim name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Dim name="/atlas/pce1/sxp_ssr_w/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>cosB</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Cosine of the off-nadir angle as calculated onboard from the spacecraft information</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Map name="/atlas/pce1/sxp_ssr_w/latitude"/>
                    <Map name="/atlas/pce1/sxp_ssr_w/longitude"/>
                </Float64>
                <Byte name="srm">
                    <Dim name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Dim name="/atlas/pce1/sxp_ssr_w/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>srm</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Surface type, vegetation and coastline information from the SRM. (bit 0-1 = surface type (0=ocean, 1=land, 2=sea ice, 3=land ice). Bit 2 = vegetation present, Bit 3 = coastline present)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/sxp_ssr_w/delta_time"/>
                    <Map name="/atlas/pce1/sxp_ssr_w/latitude"/>
                    <Map name="/atlas/pce1/sxp_ssr_w/longitude"/>
                </Byte>
                <Attribute name="DODS_EXTRA" type="Container">
                    <Attribute name="Unlimited_Dimension" type="String">
                        <Value>delta_time</Value>
                        <Value>ds_50samples</Value>
                    </Attribute>
                </Attribute>
                <Attribute name="Description" type="String">
                    <Value>SBC Extrapolation Task telemetry containing Flight Science Receiver Algorithm team requested telemetry for the first set of PCE extrapolation data for a major frame.: lat, long, range, nadir angle, etc. (from APIDs 1152 thru 1157)</Value>
                </Attribute>
            </Group>
            <Group name="background">
                <Dimension name="delta_time" size="84600"/>
                <Float64 name="delta_time">
                    <Dim name="/atlas/pce1/background/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Elapsed GPS seconds</Value>
                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The time of the first TX pulse in the 50 laser pulses used for background, in seconds relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                </Float64>
                <UInt16 name="bg_cnt_50shot_w">
                    <Dim name="/atlas/pce1/background/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Weak background counts</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>ATLAS flight s/w indicates for the beam the # of counted time tags (BackgroundCounts_50Shot) during the range windows associated with a set of 50 laser pulses of the major frame.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/background/delta_time"/>
                </UInt16>
                <UInt16 name="bg_cnt_50shot_s">
                    <Dim name="/atlas/pce1/background/delta_time"/>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="long_name" type="String">
                        <Value>Strong background counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_pmf_algorithm_science</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>ATLAS flight s/w indicates for the beam the # of counted time tags (BackgroundCounts_50Shot) during the range windows associated with a set of 50 laser pulses of the major frame.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/background/delta_time"/>
                </UInt16>
                <UInt32 name="pce_mframe_cnt">
                    <Dim name="/atlas/pce1/background/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>PCE Major frame counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over. It is in the first time tag science packet. Used as part of the photon ID</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/background/delta_time"/>
                </UInt32>
                <Byte name="useflag">
                    <Dim name="/atlas/pce1/background/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Science Mode Flag</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_alt_sci/</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Byte">
                        <Value>0</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Byte">
                        <Value>15</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Science Mode Flag.  Used by ATL03 to discard non-science mode data. 0=stby, 1=science_mode, 2=test, 3=manual, 4=radio, 5=unknown, &gt; 10=amcs_not_normal</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Attribute name="flag_meanings" type="String">
                        <Value>stby science test manual radio unknown unused unused unused unused stby_alt_amcs science_alt_amcs test_alt_amcs manual_alt_amcs radio_alt_amcs unknown_alt_amcs</Value>
                    </Attribute>
                    <Attribute name="flag_values" type="Byte">
                        <Value>0</Value>
                        <Value>1</Value>
                        <Value>2</Value>
                        <Value>3</Value>
                        <Value>4</Value>
                        <Value>5</Value>
                        <Value>6</Value>
                        <Value>7</Value>
                        <Value>8</Value>
                        <Value>9</Value>
                        <Value>10</Value>
                        <Value>11</Value>
                        <Value>12</Value>
                        <Value>13</Value>
                        <Value>14</Value>
                        <Value>15</Value>
                    </Attribute>
                    <Map name="/atlas/pce1/background/delta_time"/>
                </Byte>
                <Attribute name="DODS_EXTRA" type="Container">
                    <Attribute name="Unlimited_Dimension" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                </Attribute>
                <Attribute name="Description" type="String">
                    <Value>The background data is specific to each beam and reported at a 50-shot rate.</Value>
                </Attribute>
                <Attribute name="data_rate" type="String">
                    <Value>Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)</Value>
                </Attribute>
            </Group>
        </Group>
        <Group name="pce3">
            <Attribute name="Description" type="String">
                <Value>Group contains the Photon Counting Electronics x (PCEx) packet decommutated data</Value>
            </Attribute>
            <Attribute name="data_rate" type="String">
                <Value>Data within this group are stored at the data rate of the source PCE Data Packets. (nominally fifty per second.)</Value>
            </Attribute>
            <Group name="sxp_ssr_s">
                <Dimension name="delta_time" size="423"/>
                <Dimension name="ds_50samples" size="50"/>
                <Float64 name="delta_time">
                    <Dim name="/atlas/pce3/sxp_ssr_s/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Elapsed GPS seconds</Value>
                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
