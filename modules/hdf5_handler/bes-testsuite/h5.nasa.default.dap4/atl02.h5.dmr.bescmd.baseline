                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Value of register set in initialization command for the number of 10ns ticks between the range window start and range window stop for the strong spot.  (not EU-converted)</Value>
                    </Attribute>
