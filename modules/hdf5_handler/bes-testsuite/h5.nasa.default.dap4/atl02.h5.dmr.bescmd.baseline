                    <Value>1</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Channel Status Record (CSR) - Code Phase Deterioration (CdPD) - Single Frequency Channel 1-24. 0 = No deterioration, 1 = Measurement quality deterioration. Note: num_valid_slots indicate the number of channel that actual valid to use.  the remaining unused data fields are zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>no_deterioration deterioration</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int8">
