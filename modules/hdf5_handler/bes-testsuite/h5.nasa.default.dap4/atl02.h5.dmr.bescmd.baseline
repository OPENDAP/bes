            <Group name="time_at_the_tone">
                <Dimension name="delta_time" size="423"/>
                <Float64 name="delta_time">
                    <Dim name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Elapsed GPS seconds</Value>
                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via Time Tagging</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
                </Float64>
                <UInt32 name="gps_1pps_sec">
                    <Dim name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>gps 1pps</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since January 6, 1980</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/APID 1136 Byte 0014-0017</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>GPS reported seconds.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                </UInt32>
                <UInt32 name="gps_1pps_subsec">
                    <Dim name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>gps 1pps subsec</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>milliseconds</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/APID 1136 Byte 0014-0017</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>GPS reported subseconds</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                </UInt32>
                <UInt32 name="sc_time_1pps_sec">
                    <Dim name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>SC time at 1 pps</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since January 6, 1980</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/APID 1136 Byte 0014-0017</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>SC time at the reception of the last 1PPS signal from the GPSR.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                </UInt32>
                <UInt32 name="sc_time_1pps_subsec">
                    <Dim name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>SC time at 1 pps (subsec)</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>100 nanoseconds</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/APID 1136 Byte 0014-0017</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Subsecond portion of the SC time at the reception of the last 1PPS signal from the GPSR (seconds since SC epoch: 6-Jan-1980 00:00:00)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/housekeeping/time_at_the_tone/delta_time"/>
                </UInt32>
                <Attribute name="DODS_EXTRA" type="Container">
                    <Attribute name="Unlimited_Dimension" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                </Attribute>
                <Attribute name="Description" type="String">
                    <Value>APID 1136 Spacecraft Time at the Tone Packet - Relayed to SSR. Packet Frequency is by command. ATLAS Time-At-The-Tone-Was Message</Value>
                </Attribute>
                <Attribute name="data_rate" type="String">
                    <Value>Data within this group are stored at the data rate of the source APIDs. (only downlinked on command).</Value>
                </Attribute>
            </Group>
        </Group>
        <Group name="tx_pulse_width">
            <Dimension name="delta_time" size="4229843"/>
            <Float64 name="delta_time">
                <Dim name="/atlas/tx_pulse_width/delta_time"/>
                <Attribute name="long_name" type="String">
                    <Value>Elapsed GPS seconds</Value>
                </Attribute>
                <Attribute name="standard_name" type="String">
                    <Value>time</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>seconds since 2018-01-01</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>Operations</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Elapsed seconds since the ATLAS SDP GPS Epoch, associated with the transmit time where data from all 3 PCEs are present and aligned. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                </Attribute>
            </Float64>
            <Float32 name="tx_pulse_skew_est">
                <Dim name="/atlas/tx_pulse_width/delta_time"/>
                <Attribute name="units" type="String">
                    <Value>seconds</Value>
                </Attribute>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Transmit Pulse Skew Estimate</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL02 ATBD, Section 7.2</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>The difference between the averages of the lower and upper threshold crossing times.  This is an estimate of the transmit pulse skew.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/atlas/tx_pulse_width/delta_time"/>
            </Float32>
            <Float32 name="tx_pulse_width_lower">
                <Dim name="/atlas/tx_pulse_width/delta_time"/>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Transmit Pulse Energy Lower Width</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>seconds</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL03 ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>The distance between the lower threshold crossing times measured by the Start Pulse Detector. Only present when data from all 3 PCEs are available and aligned.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/atlas/tx_pulse_width/delta_time"/>
            </Float32>
            <Float32 name="tx_pulse_width_upper">
                <Dim name="/atlas/tx_pulse_width/delta_time"/>
                <Attribute name="_FillValue" type="Float32">
                    <Value>3.402823466e+38</Value>
                </Attribute>
                <Attribute name="long_name" type="String">
                    <Value>Transmit Pulse Energy Upper Width</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>seconds</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL03 ATBD</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>modelResult</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>The distance between the upper threshold crossing times measured by the Start Pulse Detector. Only present when data from all 3 PCEs are available and aligned.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/atlas/tx_pulse_width/delta_time"/>
            </Float32>
            <Attribute name="DODS_EXTRA" type="Container">
                <Attribute name="Unlimited_Dimension" type="String">
                    <Value>delta_time</Value>
                </Attribute>
            </Attribute>
            <Attribute name="Description" type="String">
                <Value>Contains parameters to characterize the ATLAS pulse shape, derived from the Start Pulse Detector data.</Value>
            </Attribute>
            <Attribute name="data_rate" type="String">
                <Value>Parameters in this group are stored at the ATLAS shot rate.</Value>
            </Attribute>
        </Group>
        <Group name="pce2">
            <Attribute name="Description" type="String">
                <Value>Group contains the Photon Counting Electronics x (PCEx) packet decommutated data</Value>
            </Attribute>
            <Attribute name="data_rate" type="String">
                <Value>Data within this group are stored at the data rate of the source PCE Data Packets. (nominally fifty per second.)</Value>
            </Attribute>
            <Group name="sxp_ssr_s">
                <Dimension name="delta_time" size="423"/>
                <Dimension name="ds_50samples" size="50"/>
                <Float64 name="delta_time">
                    <Dim name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Elapsed GPS seconds</Value>
                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via L1B ATBD</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
                </Float64>
                <Int8 name="ds_50samples">
                    <Dim name="/atlas/pce2/sxp_ssr_s/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>DS for 50 bytes</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="valid_min" type="Int8">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="valid_max" type="Int8">
                        <Value>50</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Dimension scale for an array of 50 samples.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                </Int8>
                <Float64 name="latitude">
                    <Dim name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Dim name="/atlas/pce2/sxp_ssr_s/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>latitude</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>degrees</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Latitude</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                </Float64>
                <Float64 name="longitude">
                    <Dim name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Dim name="/atlas/pce2/sxp_ssr_s/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>longitude</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>degrees</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Longitude</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                </Float64>
                <Float64 name="mf_cosz">
                    <Dim name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>First Major Frame cosZ</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Cosine of the solar zenith angle</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Map name="/atlas/pce2/sxp_ssr_s/latitude"/>
                    <Map name="/atlas/pce2/sxp_ssr_s/longitude"/>
                </Float64>
                <UInt32 name="pce_mframe_cnt">
                    <Dim name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>PCE Major frame counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over.</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Map name="/atlas/pce2/sxp_ssr_s/latitude"/>
                    <Map name="/atlas/pce2/sxp_ssr_s/longitude"/>
                </UInt32>
                <Float64 name="cosb">
                    <Dim name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Dim name="/atlas/pce2/sxp_ssr_s/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>cosB</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Cosine of the off-nadir angle as calculated onboard from the spacecraft information</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Map name="/atlas/pce2/sxp_ssr_s/latitude"/>
                    <Map name="/atlas/pce2/sxp_ssr_s/longitude"/>
                </Float64>
                <Byte name="srm">
                    <Dim name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Dim name="/atlas/pce2/sxp_ssr_s/ds_50samples"/>
                    <Attribute name="long_name" type="String">
                        <Value>srm</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>1</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>ATL01/atlas/pcex/a_sxp_ssr</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Surface type, vegetation and coastline information from the SRM. (bit 0-1 = surface type (0=ocean, 1=land, 2=sea ice, 3=land ice). Bit 2 = vegetation present, Bit 3 = coastline present)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time latitude longitude</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/sxp_ssr_s/delta_time"/>
                    <Map name="/atlas/pce2/sxp_ssr_s/latitude"/>
                    <Map name="/atlas/pce2/sxp_ssr_s/longitude"/>
                </Byte>
                <Attribute name="DODS_EXTRA" type="Container">
                    <Attribute name="Unlimited_Dimension" type="String">
                        <Value>delta_time</Value>
                        <Value>ds_50samples</Value>
                    </Attribute>
                </Attribute>
                <Attribute name="Description" type="String">
                    <Value>SBC Extrapolation Task telemetry containing Flight Science Receiver Algorithm team requested telemetry for the first set of PCE extrapolation data for a major frame.: lat, long, range, nadir angle, etc. (from APIDs 1152 thru 1157)</Value>
                </Attribute>
            </Group>
            <Group name="dfc_hk">
                <Dimension name="delta_time" size="21150"/>
                <Float64 name="delta_time">
                    <Dim name="/atlas/pce2/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Elapsed GPS seconds</Value>
                    </Attribute>
                    <Attribute name="standard_name" type="String">
                        <Value>time</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>seconds since 2018-01-01</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>Derived via Time Tagging</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (1980-01-06T00:00:00.000000Z UTC) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed.</Value>
                    </Attribute>
                </Float64>
                <UInt16 name="alt_last_seq_count">
                    <Dim name="/atlas/pce2/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>last sequence packet count</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0060-0061</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>CCSDS Packet Sequence Count value of the last downlink packet prior to the major frame. This should be the last packet associated with the previous major frame. That packet should contain the last Tx/RX data for the last shot of the previous major frame.  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/dfc_hk/delta_time"/>
                </UInt16>
                <UInt32 name="alt_rw_start_reg_w">
                    <Dim name="/atlas/pce2/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Altimetric Weak Range Window Start Reg</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0086-0088</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Value of register set in initialization command for the number of 10ns ticks between the transmit pulse and the start of the altimetric range window for the weak spot.  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/dfc_hk/delta_time"/>
                </UInt32>
                <UInt16 name="alt_t0_cnt">
                    <Dim name="/atlas/pce2/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>T0 counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0028-0029</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>ATLAS flight s/w T0 counter that clears with 1PPS  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/dfc_hk/delta_time"/>
                </UInt16>
                <UInt16 name="alt_spw_not_ready_cnt">
                    <Dim name="/atlas/pce2/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>SpW Not Ready Counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0115</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Counts each time SpW causes DFC to wait to transmit data to back-end (Status Only)  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/dfc_hk/delta_time"/>
                </UInt16>
                <UInt16 name="alt_sci_seg_limit">
                    <Dim name="/atlas/pce2/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Science Data Segment Limit Size</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0069-0070</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Science Data Segment Limit Size ; initialization Value  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/dfc_hk/delta_time"/>
                </UInt16>
                <UInt32 name="alt_rw_start_reg_s">
                    <Dim name="/atlas/pce2/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Altimetric Strong Range Window Start Reg</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0076-0078</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>Value of register set in initialization command for the number of 10ns ticks between the transmit pulse and the start of the altimetric range window for the strong spot (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/dfc_hk/delta_time"/>
                </UInt32>
                <UInt16 name="alt_spot_tag_cnts_s">
                    <Dim size="21150"/>
                    <Dim size="4"/>
                    <Attribute name="long_name" type="String">
                        <Value>strong spot tag counter</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0034-0041</Value>
                    </Attribute>
                    <Attribute name="contentType" type="String">
                        <Value>referenceInformation</Value>
                    </Attribute>
                    <Attribute name="description" type="String">
                        <Value>The number of events received by the DFC on channels 1 through 16 summed over 50 range window openings. The four elements of the array correspond to dividing the major frame up into 50 shots. The last element of the array can be 49 or 51 shots depending on the alignment of the range windows with respect to the major frame. Note that these counts are time tag counts and are subject to all the limitations and behaviors associated with time tags (duplicates, FIFO overflows, etc.).  (not EU-converted)</Value>
                    </Attribute>
                    <Attribute name="coordinates" type="String">
                        <Value>delta_time</Value>
                    </Attribute>
                    <Map name="/atlas/pce2/dfc_hk/delta_time"/>
                </UInt16>
                <UInt16 name="alt_rw_width_reg_s">
                    <Dim name="/atlas/pce2/dfc_hk/delta_time"/>
                    <Attribute name="long_name" type="String">
                        <Value>Altimetric Strong Range Window Width Reg</Value>
                    </Attribute>
                    <Attribute name="units" type="String">
                        <Value>counts</Value>
                    </Attribute>
                    <Attribute name="source" type="String">
                        <Value>APID 1072, 1088, 1104 Byte 0079-0080</Value>
