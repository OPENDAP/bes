                    <Value>CSR Code Loop Correlator Spacing Final Flag</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc4/gpsr/channel_status</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
                    <Value>0</Value>
                </Attribute>
                <Attribute name="valid_max" type="Int8">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Channel Status Record (CSR) - Code Loop Correlator Spacing (CdLCS) Final Flag (FF) - Single Frequency Channel 1-24. 0 = Code loop correlator not final, 1 = Final code loop correlator applied. Note: num_valid_slots indicate the number of channel that actual valid to use.  the remaining unused data fields are zero-filled.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>not_final applied</Value>
                </Attribute>
                <Attribute name="flag_values" type="Int8">
                    <Value>0</Value>
                    <Value>1</Value>
                </Attribute>
                <Map name="/gpsr/channel_status/delta_time"/>
                <Map name="/gpsr/channel_status/ds_24_slots"/>
            </Int8>
            <Int8 name="code_phase_deter">
                <Dim name="/gpsr/channel_status/delta_time"/>
                <Dim name="/gpsr/channel_status/ds_24_slots"/>
                <Attribute name="long_name" type="String">
                    <Value>CSR Code Phase Deterioration</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ATL01/sc4/gpsr/channel_status</Value>
                </Attribute>
                <Attribute name="valid_min" type="Int8">
