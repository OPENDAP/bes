                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>referenceInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Voltage of +5VDC LDC Monitor - 0x0000 = 0.000 V; 0xA000 = +5.000 V (nominal value); 0xFFFF = +8.000 V : A_LRS_HK.ANALOGHK[12]</Value>
