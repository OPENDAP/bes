                    <Value>EEPROM Application Data (AD)  checksum (0=PASSED (normal operating condition) 1=FAILED (abnormal condition))</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Attribute name="flag_meanings" type="String">
                    <Value>passed failed</Value>
                </Attribute>
