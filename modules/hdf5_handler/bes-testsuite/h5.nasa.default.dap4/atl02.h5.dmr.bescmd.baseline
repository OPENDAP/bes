                    <Value>This 16-bit counter indicates the remaining number of dump packets to send during Failsafe Mode processing of a Failsafe Dump Memory Command (LRSfscmDPMEM).  It is 0x0000 whenever no dump command is active.</Value>
                </Attribute>
                <Attribute name="coordinates" type="String">
                    <Value>delta_time</Value>
                </Attribute>
                <Map name="/lrs/hk_1120/delta_time"/>
            </UInt16>
