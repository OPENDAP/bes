        <Group name="isf">
            <Float64 name="bias_offset_y">
                <Dim size="2"/>
                <Attribute name="long_name" type="String">
                    <Value>AMCS Bias Offset Y</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>microradians</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ANC27 (ATBD Section 5.3.3.1)</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>auxiliaryInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>Zero is center of BSM range: (x,y)=(8000,8000).  Used in Eqn 5-13 to generate coordinates that are used in Eqn 5-11 to interpolate CAL 47, which has 1 R grid spacing.</Value>
                </Attribute>
            </Float64>
            <Float64 name="wtom_lambda_off">
                <Dim size="1"/>
                <Attribute name="long_name" type="String">
                    <Value>WTOM Wavelength Offset</Value>
                </Attribute>
                <Attribute name="units" type="String">
                    <Value>1</Value>
                </Attribute>
                <Attribute name="contentType" type="String">
                    <Value>auxiliaryInformation</Value>
                </Attribute>
                <Attribute name="description" type="String">
                    <Value>WTOM Wavelength Offset. Currently zero.  An &quot;off-tuning&quot; value to be used with alternate tuning; method for calculating not defined.</Value>
                </Attribute>
                <Attribute name="source" type="String">
                    <Value>ANC27 (ATBD Section 5.3.3.2)</Value>
                </Attribute>
            </Float64>
