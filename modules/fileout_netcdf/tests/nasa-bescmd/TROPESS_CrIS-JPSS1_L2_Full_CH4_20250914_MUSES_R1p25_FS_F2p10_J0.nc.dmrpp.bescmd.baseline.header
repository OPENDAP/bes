  		cloud_top_pressure_dof:long_name = "cloud_top_pressure_dof" ;
  		cloud_top_pressure_dof:standard_name = "cloud_top_pressure_dof" ;
  		cloud_top_pressure_dof:units = "1" ;
  		cloud_top_pressure_dof:missing_value = -999. ;
  } // group characterization

group: geophysical {
  variables:
  	float average_cloud_eod(target) ;
  		average_cloud_eod:_FillValue = -999.f ;
  		average_cloud_eod:long_name = "average_cloud_effective_optical_depth" ;
  		average_cloud_eod:comment = "Average cloud effective optical depth" ;
  		average_cloud_eod:units = "1" ;
  		average_cloud_eod:missing_value = -999.f ;
  	float cloud_top_pressure(target) ;
  		cloud_top_pressure:_FillValue = -999.f ;
  		cloud_top_pressure:comment = "Pressure of inferred cloud top (species independent)" ;
  		cloud_top_pressure:long_name = "cloud_top_pressure" ;
  		cloud_top_pressure:standard_name = "cloud_top_pressure" ;
  		cloud_top_pressure:units = "hPa" ;
  		cloud_top_pressure:missing_value = -999. ;
  	short day_night_flag(target) ;
  		day_night_flag:_FillValue = -999s ;
  		day_night_flag:comment = "If target is during the day == 1, otherwise == 0" ;
  		day_night_flag:long_name = "day_night_flag" ;
  		day_night_flag:standard_name = "sunlit_binary_mask" ;
  		day_night_flag:flag_values = 0s, 1s ;
  		day_night_flag:flag_meanings = "night day" ;
  		day_night_flag:missing_value = -999s ;
  	short land_flag(target) ;
  		land_flag:_FillValue = -999s ;
  		land_flag:comment = "If target is over land == 1, otherwise == 0" ;
  		land_flag:standard_name = "land_binary_mask" ;
  		land_flag:long_name = "land_flag" ;
  		land_flag:flag_values = 0s, 1s ;
  		land_flag:flag_meanings = "water land" ;
  		land_flag:missing_value = -999s ;
  	float surface_temperature(target) ;
  		surface_temperature:_FillValue = -999.f ;
  		surface_temperature:comment = "surface temperature" ;
  		surface_temperature:long_name = "surface_temperature" ;
  		surface_temperature:standard_name = "surface_temperature" ;
  		surface_temperature:units = "K" ;
  		surface_temperature:missing_value = -999. ;
  } // group geophysical

group: retrieval {
  dimensions:
  	mw_inst_len3 = 5 ;
  	mw_spec_len4 = 47 ;
  variables:
  	float x_raw(target, level_ret) ;
  		x_raw:_FillValue = -999.f ;
  		x_raw:units = "1" ;
  		x_raw:coordinates = "longitude latitude" ;
  		x_raw:missing_value = -999.f ;
  		x_raw:standard_name = "dry_atmosphere_volume_mixing_ratio_of_methane" ;
  		x_raw:long_name = "methane_raw_vmr_profile" ;
  		x_raw:comment = "Volume mixing ratio (VMR) of Methane relative to dry air (without bias correction)" ;
  	float column(target, column_type) ;
  		column:_FillValue = -999.f ;
  		column:comment = "Column amounts computed from the retrieved profile. See columnPressureMin, columnPressureMax for pressure ranges" ;
  		column:long_name = "methane_column_density" ;
  		column:standard_name = "methane_column_density" ;
  		column:units = "molecules cm-2" ;
  		column:coordinates = "column_label" ;
  		column:missing_value = -999. ;
  	float column_air(target, column_type) ;
  		column_air:_FillValue = -999.f ;
  		column_air:comment = "Column amounts of dry air. See columnPressureMin, columnPressureMax for pressure ranges" ;
  		column_air:long_name = "column_air" ;
  		column_air:standard_name = "air_column_density" ;
  		column_air:units = "molecules cm-2" ;
  		column_air:coordinates = "column_label" ;
  		column_air:missing_value = -999. ;
  	float air_density(target, level_fm) ;
  		air_density:_FillValue = -999.f ;
  		air_density:comment = "number density of air" ;
  		air_density:long_name = "air_density" ;
  		air_density:standard_name = "air_number_density" ;
  		air_density:units = "molecules/m^3" ;
  		air_density:missing_value = -999. ;
  	float column_prior(target, column_type) ;
  		column_prior:_FillValue = -999.f ;
  		column_prior:comment = "Column amounts computed for prior. See columnPressureMin, columnPressureMax for pressure ranges" ;
  		column_prior:long_name = "methane_apriori_column_density" ;
  		column_prior:standard_name = "methane_apriori_column_density" ;
  		column_prior:units = "molecules cm-2" ;
  		column_prior:coordinates = "column_label" ;
  		column_prior:missing_value = -999. ;
  	float mw(microwindow, microwindow_range) ;
  		mw:_FillValue = -999.f ;
  		mw:comment = "Microwindow start and end wavelength in micrometers (um)" ;
  		mw:long_name = "microwindow_ranges" ;
  		mw:standard_name = "microwindows" ;
  		mw:units = "m-6" ;
  		mw:missing_value = -999. ;
  	char mw_inst(microwindow, mw_inst_len3) ;
  		mw_inst:_FillValue = "-" ;
  		mw_inst:Orig_FillValue = "-" ;
  		mw_inst:comment = "Instrument for which a given microwindow is used." ;
  		mw_inst:long_name = "microwindow_instrument" ;
  		mw_inst:standard_name = "microwindow_instrument" ;
  		mw_inst:units = "1" ;
  		mw_inst:missing_value = "-" ;
  	char mw_spec(microwindow, mw_spec_len4) ;
  		mw_spec:_FillValue = "-" ;
  		mw_spec:Orig_FillValue = "-" ;
  		mw_spec:comment = "Species retrieved in each microwindow" ;
  		mw_spec:long_name = "microwindow_species" ;
  		mw_spec:standard_name = "microwindow_species" ;
  		mw_spec:units = "1" ;
  		mw_spec:missing_value = "-" ;
  	float average_cloud_eff_optical_depth(target) ;
  		average_cloud_eff_optical_depth:_FillValue = -999.f ;
  		average_cloud_eff_optical_depth:comment = "average cloud effective optical depth" ;
  		average_cloud_eff_optical_depth:long_name = "average_cloud_eff_optical_depth" ;
  		average_cloud_eff_optical_depth:standard_name = "average_cloud_eff_optical_depth" ;
  		average_cloud_eff_optical_depth:units = "" ;
  		average_cloud_eff_optical_depth:missing_value = -999. ;
  	float x_raw_col_p(target) ;
  		x_raw_col_p:_FillValue = -999.f ;
  		x_raw_col_p:long_name = "methane_raw_partial_column_vmr" ;
  		x_raw_col_p:comment = "Column-averaged dry air mixing ratio of methane for the free troposphere column between 826 hPa to Top of Atmosphere (without bias correction)" ;
  		x_raw_col_p:units = "1e-9" ;
  		x_raw_col_p:pressure_bounds = "826 hPa, 0 hPa" ;
  		x_raw_col_p:missing_value = -999.f ;
  } // group retrieval

group: geolocation {
  variables:
  	short cris_atrack(target) ;
  		cris_atrack:_FillValue = -999s ;
  		cris_atrack:comment = "The position along the orbit, with a range of values, 0-based from 0 to 44." ;
  		cris_atrack:long_name = "cris_along_track" ;
  		cris_atrack:standard_name = "cris_along_track" ;
  		cris_atrack:units = "1" ;
  		cris_atrack:missing_value = -999s ;
  	short cris_granule(target) ;
  		cris_granule:_FillValue = -999s ;
  		cris_granule:comment = "CrIS granule number" ;
  		cris_granule:long_name = "cris_granule" ;
  		cris_granule:standard_name = "cris_granule" ;
  		cris_granule:units = "1" ;
  		cris_granule:missing_value = -999s ;
  	float cris_view_ang(target) ;
  		cris_view_ang:_FillValue = -999.f ;
  		cris_view_ang:comment = "CrIS boresight (LOS) nadir angle relative to local nadir at SC" ;
  		cris_view_ang:long_name = "cris_view_angle" ;
  		cris_view_ang:standard_name = "sensor_view_angle" ;
  		cris_view_ang:units = "degree" ;
  		cris_view_ang:valid_range = 0.f, 90.f ;
  		cris_view_ang:missing_value = -999.f ;
  	short cris_l1b_type(target) ;
  		cris_l1b_type:_FillValue = -999s ;
  		cris_l1b_type:long_name = "cris_l1b_type" ;
  		cris_l1b_type:standard_name = "cris_l1b_type" ;
  		cris_l1b_type:units = "" ;
  		cris_l1b_type:missing_value = -999. ;
  		cris_l1b_type:flag_values = 0s, 1s, 2s, 3s ;
  		cris_l1b_type:flag_meanings = "suomi_nasa_nsr suomi_nasa_fsr suomi_nasa_nomw jpss1_nasa_fsr" ;
  		cris_l1b_type:comment = "Values can be 0-3. 0=suomi_nasa_nsr (nominal spectral resolution), 1=suomi_nasa_fsr (full spectral resolution), 2=suomi_nasa_nomw (full spectral resolution but without the midwave band), 3=jpss1_nasa_fsr (full spectral resolution, using the instrument on the JPSS-1 satellite)" ;
  	short cris_fov(target) ;
  		cris_fov:_FillValue = -999s ;
  		cris_fov:long_name = "cris_field_of_view" ;
  		cris_fov:comment = "Each Field-Of-Views (FOV) positions of the 9 detector field stops on each band focal planes arranged into a 3x3 grid. Values can be 0-8" ;
  		cris_fov:units = "1" ;
  		cris_fov:missing_value = -999s ;
  	short cris_xtrack(target) ;
  		cris_xtrack:_FillValue = -999s ;
  		cris_xtrack:comment = "A cross-track scan consists of 30 FORs, The Field of Regard (FOR) is defined by the combined 3x3 FOV." ;
  		cris_xtrack:long_name = "cris_cross_track" ;
  		cris_xtrack:standard_name = "cris_cross_track" ;
  		cris_xtrack:units = "1" ;
  		cris_xtrack:missing_value = -999s ;
  } // group geolocation
}
