      		alt_imet_at_1pps:source = "APID 1072, 1088, 1104 Byte 0016-0021" ;
      		alt_imet_at_1pps:contentType = "referenceInformation" ;
      		alt_imet_at_1pps:description = "ATLAS flight s/w 25 MHz IMET counter value when 1PPS is received  (not EU-converted)" ;
