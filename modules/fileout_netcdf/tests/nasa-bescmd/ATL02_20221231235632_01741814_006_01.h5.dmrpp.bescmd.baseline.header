    group: laser_energy_internal {
      dimensions:
      	delta_time = UNLIMITED ; // (423 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed. The timestamp is computed based on the housekeeping design to sample laser near the asc 1pps internal pulse. (See the L1B ATBD section 5 Radiometric Corrections )" ;
      	float e_tx_pce3_w(delta_time) ;
      		e_tx_pce3_w:long_name = "Spot laser energy for PCE3, weak" ;
      		e_tx_pce3_w:units = "joules" ;
      		e_tx_pce3_w:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		e_tx_pce3_w:contentType = "referenceInformation" ;
      		e_tx_pce3_w:description = "Laser energy for the PCE3 weak spot, derived from the internal laser energy monitor and split by calibration." ;
      		e_tx_pce3_w:coordinates = "delta_time" ;
      	byte laser_mode(delta_time) ;
      		laser_mode:long_name = "Laser Mode Setting" ;
      		laser_mode:units = "1" ;
      		laser_mode:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		laser_mode:contentType = "referenceInformation" ;
      		laser_mode:description = "Laser Mode setting reported in A_SLA_HK (APID 1032)." ;
      		laser_mode:coordinates = "delta_time" ;
      	float e_tx_pce3_s(delta_time) ;
      		e_tx_pce3_s:long_name = "Spot laser energy for PCE3, strong" ;
      		e_tx_pce3_s:units = "joules" ;
      		e_tx_pce3_s:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		e_tx_pce3_s:contentType = "referenceInformation" ;
      		e_tx_pce3_s:description = "Laser energy for the PCE3 strong spot, derived from the internal laser energy monitor and split by calibration." ;
      		e_tx_pce3_s:coordinates = "delta_time" ;
      	float e_tx(delta_time) ;
      		e_tx:long_name = "total laser energy" ;
      		e_tx:units = "joules" ;
      		e_tx:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		e_tx:contentType = "referenceInformation" ;
      		e_tx:description = "Total laser energy derived from the internal laser energy monitor (APID 1032)." ;
      		e_tx:coordinates = "delta_time" ;
      	float laser_temp(delta_time) ;
      		laser_temp:long_name = "Laser Temperature" ;
      		laser_temp:units = "degreesC" ;
      		laser_temp:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		laser_temp:contentType = "referenceInformation" ;
      		laser_temp:description = "Laser Temperature. From SLA_HK Telemetry packet (APID 1032, Laser Cmd Code 0xFE LAS-14, raw_lem_temp)." ;
      		laser_temp:coordinates = "delta_time" ;
      	float e_tx_pce1_s(delta_time) ;
      		e_tx_pce1_s:long_name = "Spot laser energy for PCE1, strong" ;
      		e_tx_pce1_s:units = "joules" ;
      		e_tx_pce1_s:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		e_tx_pce1_s:contentType = "referenceInformation" ;
      		e_tx_pce1_s:description = "Laser energy for the PCE1 strong spot, derived from the internal laser energy monitor and split by calibration." ;
      		e_tx_pce1_s:coordinates = "delta_time" ;
      	float e_tx_pce2_w(delta_time) ;
      		e_tx_pce2_w:long_name = "Spot laser energy for PCE2, weak" ;
      		e_tx_pce2_w:units = "joules" ;
      		e_tx_pce2_w:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		e_tx_pce2_w:contentType = "referenceInformation" ;
      		e_tx_pce2_w:description = "Laser energy for the PCE2 weak spot, derived from the internal laser energy monitor and split by calibration." ;
      		e_tx_pce2_w:coordinates = "delta_time" ;
      	float e_tx_pce2_s(delta_time) ;
      		e_tx_pce2_s:long_name = "Spot laser energy for PCE2, strong" ;
      		e_tx_pce2_s:units = "joules" ;
      		e_tx_pce2_s:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		e_tx_pce2_s:contentType = "referenceInformation" ;
      		e_tx_pce2_s:description = "Laser energy for the PCE2 strong spot, derived from the internal laser energy monitor and split by calibration." ;
      		e_tx_pce2_s:coordinates = "delta_time" ;
      	float e_tx_pce1_w(delta_time) ;
      		e_tx_pce1_w:long_name = "Spot laser energy for PCE1, weak" ;
      		e_tx_pce1_w:units = "joules" ;
      		e_tx_pce1_w:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		e_tx_pce1_w:contentType = "referenceInformation" ;
      		e_tx_pce1_w:description = "Laser energy for the PCE1 weak spot, derived from the internal laser energy monitor and split by calibration." ;
      		e_tx_pce1_w:coordinates = "delta_time" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
      		:Description = "Internal laser energy from APID 1032 SLA_HK. Packet Frequency is 1 Hertz." ;
      		:data_rate = "Data within this group are provided at the packet rate of 1hz." ;
      } // group laser_energy_internal

