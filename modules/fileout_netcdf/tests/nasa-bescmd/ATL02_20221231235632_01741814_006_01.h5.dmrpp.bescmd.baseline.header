    group: dfc_hk {
      dimensions:
      	delta_time = UNLIMITED ; // (21150 currently)
      	dim288 = 21150 ;
      	dim289 = 4 ;
      	dim290 = 21150 ;
      	dim291 = 4 ;
      	dim292 = 21150 ;
      	dim293 = 2 ;
      	dim294 = 21150 ;
      	dim295 = 5 ;
      	dim296 = 21150 ;
      	dim297 = 3 ;
      	dim298 = 21150 ;
      	dim299 = 4 ;
      	dim300 = 21150 ;
      	dim301 = 4 ;
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	ushort alt_last_seq_count(delta_time) ;
      		alt_last_seq_count:long_name = "last sequence packet count" ;
      		alt_last_seq_count:units = "counts" ;
      		alt_last_seq_count:source = "APID 1072, 1088, 1104 Byte 0060-0061" ;
      		alt_last_seq_count:contentType = "referenceInformation" ;
      		alt_last_seq_count:description = "CCSDS Packet Sequence Count value of the last downlink packet prior to the major frame. This should be the last packet associated with the previous major frame. That packet should contain the last Tx/RX data for the last shot of the previous major frame.  (not EU-converted)" ;
      		alt_last_seq_count:coordinates = "delta_time" ;
      	uint alt_rw_start_reg_w(delta_time) ;
      		alt_rw_start_reg_w:long_name = "Altimetric Weak Range Window Start Reg" ;
      		alt_rw_start_reg_w:units = "counts" ;
      		alt_rw_start_reg_w:source = "APID 1072, 1088, 1104 Byte 0086-0088" ;
      		alt_rw_start_reg_w:contentType = "referenceInformation" ;
      		alt_rw_start_reg_w:description = "Value of register set in initialization command for the number of 10ns ticks between the transmit pulse and the start of the altimetric range window for the weak spot.  (not EU-converted)" ;
      		alt_rw_start_reg_w:coordinates = "delta_time" ;
      	ushort alt_t0_cnt(delta_time) ;
      		alt_t0_cnt:long_name = "T0 counter" ;
      		alt_t0_cnt:units = "counts" ;
      		alt_t0_cnt:source = "APID 1072, 1088, 1104 Byte 0028-0029" ;
      		alt_t0_cnt:contentType = "referenceInformation" ;
      		alt_t0_cnt:description = "ATLAS flight s/w T0 counter that clears with 1PPS  (not EU-converted)" ;
      		alt_t0_cnt:coordinates = "delta_time" ;
      	ushort alt_spw_not_ready_cnt(delta_time) ;
      		alt_spw_not_ready_cnt:long_name = "SpW Not Ready Counter" ;
      		alt_spw_not_ready_cnt:units = "counts" ;
      		alt_spw_not_ready_cnt:source = "APID 1072, 1088, 1104 Byte 0115" ;
      		alt_spw_not_ready_cnt:contentType = "referenceInformation" ;
      		alt_spw_not_ready_cnt:description = "Counts each time SpW causes DFC to wait to transmit data to back-end (Status Only)  (not EU-converted)" ;
      		alt_spw_not_ready_cnt:coordinates = "delta_time" ;
      	ushort alt_sci_seg_limit(delta_time) ;
      		alt_sci_seg_limit:long_name = "Science Data Segment Limit Size" ;
      		alt_sci_seg_limit:units = "counts" ;
      		alt_sci_seg_limit:source = "APID 1072, 1088, 1104 Byte 0069-0070" ;
      		alt_sci_seg_limit:contentType = "referenceInformation" ;
      		alt_sci_seg_limit:description = "Science Data Segment Limit Size ; initialization Value  (not EU-converted)" ;
      		alt_sci_seg_limit:coordinates = "delta_time" ;
      	uint alt_rw_start_reg_s(delta_time) ;
      		alt_rw_start_reg_s:long_name = "Altimetric Strong Range Window Start Reg" ;
