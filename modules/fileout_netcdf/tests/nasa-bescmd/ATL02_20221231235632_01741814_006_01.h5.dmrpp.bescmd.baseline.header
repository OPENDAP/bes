  group: hk {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    	ds_ab_index = UNLIMITED ; // (2 currently)
    	ds_flexure_index = UNLIMITED ; // (3 currently)
    	ds_temp_index = UNLIMITED ; // (15 currently)
    variables:
    	byte ds_ab_index(ds_ab_index) ;
    		ds_ab_index:long_name = "Dimension scale for Side A or B" ;
    		ds_ab_index:units = "1" ;
    		ds_ab_index:source = "Dimension Scale" ;
    		ds_ab_index:contentType = "referenceInformation" ;
    		ds_ab_index:description = "Dimension scale for Side A or B" ;
    		ds_ab_index:flag_meanings = "side_a side_b" ;
    		ds_ab_index:flag_values = 1b, 2b ;
    	byte ds_flexure_index(ds_flexure_index) ;
    		ds_flexure_index:long_name = "Dimension scale for flexure thermistors" ;
    		ds_flexure_index:units = "1" ;
    		ds_flexure_index:source = "Dimension Scale" ;
    		ds_flexure_index:contentType = "referenceInformation" ;
    		ds_flexure_index:description = "Dimension scale for flexure thermistor temperatures." ;
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "The derived time tag of the data, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
