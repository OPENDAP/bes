    		sysstat_j2:contentType = "referenceInformation" ;
    		sysstat_j2:description = "Jumper 2 status (no planned use on ATLAS). 0 = Jumper is DISCONNECTED (normal operating condition)" ;
    		sysstat_j2:coordinates = "delta_time" ;
    		sysstat_j2:flag_meanings = "disconnected connected" ;
    		sysstat_j2:flag_values = 0b, 1b ;
    	ushort cmdcnt(delta_time) ;
    		cmdcnt:units = "counts" ;
    		cmdcnt:source = "LRS_HK" ;
    		cmdcnt:long_name = "LRS_HK Valid User Command Counter" ;
    		cmdcnt:contentType = "referenceInformation" ;
    		cmdcnt:description = "The Valid User Command Counter is a 16-bit counter that increments each time that the Failsafe Mode processes a valid command of the corresponding command type.  A valid command is defined as a command that passes all verification tests.  The counter starts at 0x0000, and rolls over to 0x0000 when it increments from 0xFFFF.  The counter is reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT)." ;
    		cmdcnt:coordinates = "delta_time" ;
    	uint ppsoscval(delta_time) ;
    		ppsoscval:long_name = "LRS_HK Latched oscillator value at 1PPS sync" ;
    		ppsoscval:units = "counts" ;
    		ppsoscval:source = "LRS_HK" ;
    		ppsoscval:contentType = "referenceInformation" ;
    		ppsoscval:description = "The 32-bit count of internal 27 MHz oscillator ticks at the time when the last 1 PPS sync pulse was registered by the LRS FPGA." ;
    		ppsoscval:coordinates = "delta_time" ;
    	float laser_barrel1_t(delta_time) ;
    		laser_barrel1_t:long_name = "LRS_HK Optics Thermistor #1 (Laser Side Barrel #1 Temperature)" ;
    		laser_barrel1_t:units = "degreesC" ;
    		laser_barrel1_t:source = "LRS_HK" ;
    		laser_barrel1_t:contentType = "referenceInformation" ;
    		laser_barrel1_t:description = "Temperature of Optics Thermistor #1 (Laser Side Barrel #1) - 0x0000 = 0.000 V (nominal short); 0xFFFF = +4.000 V (nominal open) [see thermistor scaling section later for temperature scaling]" ;
    		laser_barrel1_t:coordinates = "delta_time" ;
    	uint spwoutofsync(delta_time) ;
    		spwoutofsync:long_name = "LRS_HK Spacewire words skipped to find sync" ;
    		spwoutofsync:units = "counts" ;
    		spwoutofsync:source = "LRS_HK" ;
    		spwoutofsync:contentType = "referenceInformation" ;
    		spwoutofsync:description = "This 32-bit counter is incremented each time a spacewire command word is skipped by Failsafe Mode to reach a valid packet sync (an abnormal condition).  It starts at 0x00000000, and rolls over to 0x00000000 when it increments from 0xFFFFFFFF.  This counter will be reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT)." ;
    		spwoutofsync:coordinates = "delta_time" ;
    	float ground1_v(delta_time) ;
    		ground1_v:long_name = "LRS_HK Ground 1 Voltage" ;
    		ground1_v:units = "volts" ;
    		ground1_v:source = "LRS_HK" ;
    		ground1_v:contentType = "referenceInformation" ;
    		ground1_v:description = "Voltage of Ground 1 - 0x0000 = 0.000 V (nominal value); 0xFFFF = +4.000 V : A_LRS_HK.ANALOGHK[0]" ;
    		ground1_v:coordinates = "delta_time" ;
    	ushort ldoverrun(delta_time) ;
    		ldoverrun:long_name = "LRS_HK LD Processing Overruns" ;
    		ldoverrun:units = "counts" ;
    		ldoverrun:source = "LRS_HK" ;
    		ldoverrun:contentType = "referenceInformation" ;
    		ldoverrun:description = "This 16-bit counter is incremented each time the Application Mode is still processing Laser-Side data when a new LRS cycle starts.  This overrun condition is a warning, which indicates that some processor activity did not complete in the allocated time and may delay reporting of the next laser data packets.  This counter starts at 0x0000, and rolls over to 0x0000 when it increments from 0xFFFF.  This counter will be reset at Application Mode initialization and by an Application Reset Counters Command (LRScmRSTCNT)." ;
    		ldoverrun:coordinates = "delta_time" ;
    	ushort ldbackground(delta_time) ;
    		ldbackground:long_name = "LRS_HK LD background" ;
    		ldbackground:units = "counts" ;
    		ldbackground:source = "LRS_HK" ;
    		ldbackground:contentType = "referenceInformation" ;
    		ldbackground:description = "The 16-bit values are measures of the measured detector background for the laser side after subtracting the predicted dark frame.  Each is a scaled average of the background levels from all tracking windows on that detector, for all measurements in the preceding one (1) second.  Because the search and imaging windows move around, these values should be expected to fluctuate significantly; however, they are an indication of how well the predicted dark frame matches the background (stray light) levels.  If they are occasionally very large, there is probably a stray light problem.  If they are consistently very large, there is probably error in the dark frame calibration." ;
    		ldbackground:coordinates = "delta_time" ;
    	uint ldmemcnt(delta_time) ;
    		ldmemcnt:long_name = "LRS_HK Number of memory words loaded" ;
    		ldmemcnt:units = "counts" ;
    		ldmemcnt:source = "LRS_HK" ;
    		ldmemcnt:contentType = "referenceInformation" ;
    		ldmemcnt:description = "This 32-bit counter records the total number of memory words loaded during Failsafe Mode processing of Failsafe Load Memory Command (LRSfscmLDMEM).  It starts at 0x00000000, and rolls over to 0x00000000 when it increments from 0xFFFFFFFF.  This counter will be reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT)" ;
    		ldmemcnt:coordinates = "delta_time" ;
    	byte chkstat_s_at(delta_time) ;
    		chkstat_s_at:units = "1" ;
    		chkstat_s_at:long_name = "LRS_HK Checksum Status Register -SRAM Application Text Checksum" ;
