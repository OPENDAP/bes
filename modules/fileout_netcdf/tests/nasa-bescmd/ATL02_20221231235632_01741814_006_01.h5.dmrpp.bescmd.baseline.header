      		edge_xmtnc:source = "ICESat-2 L1B ATBD, Section 5.2, Transmitted Energy" ;
      		edge_xmtnc:contentType = "referenceInformation" ;
      		edge_xmtnc:description = "edge_xmtnc. From Analog HK Telemetry packet E (APID 1063)." ;
      		edge_xmtnc:coordinates = "delta_time" ;
      	float e_tx_pce3_s(delta_time, ds_10) ;
      		e_tx_pce3_s:units = "joules" ;
