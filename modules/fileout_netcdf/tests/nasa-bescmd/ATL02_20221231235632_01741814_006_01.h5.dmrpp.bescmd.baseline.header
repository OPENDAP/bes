    group: position_velocity {
      dimensions:
      	delta_time = UNLIMITED ; // (423 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	double z_sc_eci_pos(delta_time) ;
      		z_sc_eci_pos:long_name = "z_sc_eci_pos" ;
      		z_sc_eci_pos:units = "meters" ;
      		z_sc_eci_pos:source = "ATL01/atlas/a_sc_pos_1137" ;
      		z_sc_eci_pos:contentType = "referenceInformation" ;
      		z_sc_eci_pos:description = "Spacecraft Earth-Centered-Inertial Position: Z axis" ;
      		z_sc_eci_pos:coordinates = "delta_time" ;
      	double z_sc_eci_vel(delta_time) ;
      		z_sc_eci_vel:long_name = "z_sc_eci_vel" ;
      		z_sc_eci_vel:source = "ATL01/atlas/a_sc_pos_1137" ;
      		z_sc_eci_vel:contentType = "referenceInformation" ;
      		z_sc_eci_vel:description = "Spacecraft Earth-Centered-Inertial Velocity: Z axis" ;
      		z_sc_eci_vel:coordinates = "delta_time" ;
      		z_sc_eci_vel:units = "meters/second" ;
      	uint sc_solution_sec(delta_time) ;
      		sc_solution_sec:long_name = "sc_solution_sec" ;
      		sc_solution_sec:units = "seconds" ;
      		sc_solution_sec:source = "ATL01/atlas/a_sc_pos_1137" ;
      		sc_solution_sec:contentType = "referenceInformation" ;
      		sc_solution_sec:description = "Recorded time of the position/velocity solution in seconds from the spacecraft epoch" ;
      		sc_solution_sec:coordinates = "delta_time" ;
      	uint sc_solution_subsec(delta_time) ;
      		sc_solution_subsec:long_name = "sc_solution_subsec" ;
      		sc_solution_subsec:units = "seconds" ;
      		sc_solution_subsec:source = "ATL01/atlas/a_sc_pos_1137" ;
      		sc_solution_subsec:contentType = "referenceInformation" ;
      		sc_solution_subsec:description = "Spacecraft recorded time counts - 24 bits, 100 ns per count" ;
      		sc_solution_subsec:coordinates = "delta_time" ;
