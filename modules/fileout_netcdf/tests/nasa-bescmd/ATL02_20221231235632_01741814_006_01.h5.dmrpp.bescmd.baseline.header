    		norm_neg_in_phase_m3:units = "counts" ;
    		norm_neg_in_phase_m3:source = "ATL01/sc3/gpsr/noise_histogram" ;
    		norm_neg_in_phase_m3:contentType = "referenceInformation" ;
    		norm_neg_in_phase_m3:description = "Noise Histogram Data Record (NHDR) - Normalized signal level detector counts of the negative In-phase samples (M3) - Down Conversion Chain Identifier 1-2" ;
    		norm_neg_in_phase_m3:coordinates = "delta_time" ;
    	ushort norm_neg_in_phase_m1(delta_time, ds_chain) ;
