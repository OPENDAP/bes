      		pce_mframe_cnt:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		pce_mframe_cnt:contentType = "referenceInformation" ;
      		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over." ;
