    		tof_extracted_s:contentType = "auxiliaryInformation" ;
    		tof_extracted_s:description = "Duration of peak-aligned, windowed TOF histograms." ;
    	double dt_t0(dim257) ;
    		dt_t0:long_name = "T0 Clock Tick" ;
