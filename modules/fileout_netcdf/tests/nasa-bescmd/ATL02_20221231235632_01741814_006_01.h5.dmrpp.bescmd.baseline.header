      		atm_rw_width_reg_s:source = "APID 1072, 1088, 1104 Byte 0084-0085" ;
      		atm_rw_width_reg_s:contentType = "referenceInformation" ;
      		atm_rw_width_reg_s:description = "Value of register set in initialization command for the number of 10ns ticks between the Atmospheric range window start and range window stop for the strong spot.  (not EU-converted)" ;
      		atm_rw_width_reg_s:coordinates = "delta_time" ;
