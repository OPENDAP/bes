      } // group sxp_ssr_s

    group: dfc_hk {
      dimensions:
      	delta_time = UNLIMITED ; // (21150 currently)
      	dim302 = 21150 ;
      	dim303 = 4 ;
      	dim304 = 21150 ;
      	dim305 = 4 ;
      	dim306 = 21150 ;
      	dim307 = 2 ;
      	dim308 = 21150 ;
      	dim309 = 5 ;
      	dim310 = 21150 ;
      	dim311 = 3 ;
      	dim312 = 21150 ;
      	dim313 = 4 ;
      	dim314 = 21150 ;
      	dim315 = 4 ;
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	ushort alt_last_seq_count(delta_time) ;
      		alt_last_seq_count:long_name = "last sequence packet count" ;
      		alt_last_seq_count:units = "counts" ;
      		alt_last_seq_count:source = "APID 1072, 1088, 1104 Byte 0060-0061" ;
      		alt_last_seq_count:contentType = "referenceInformation" ;
      		alt_last_seq_count:description = "CCSDS Packet Sequence Count value of the last downlink packet prior to the major frame. This should be the last packet associated with the previous major frame. That packet should contain the last Tx/RX data for the last shot of the previous major frame.  (not EU-converted)" ;
      		alt_last_seq_count:coordinates = "delta_time" ;
      	uint alt_rw_start_reg_w(delta_time) ;
      		alt_rw_start_reg_w:long_name = "Altimetric Weak Range Window Start Reg" ;
      		alt_rw_start_reg_w:units = "counts" ;
      		alt_rw_start_reg_w:source = "APID 1072, 1088, 1104 Byte 0086-0088" ;
      		alt_rw_start_reg_w:contentType = "referenceInformation" ;
      		alt_rw_start_reg_w:description = "Value of register set in initialization command for the number of 10ns ticks between the transmit pulse and the start of the altimetric range window for the weak spot.  (not EU-converted)" ;
      		alt_rw_start_reg_w:coordinates = "delta_time" ;
      	ushort alt_t0_cnt(delta_time) ;
      		alt_t0_cnt:long_name = "T0 counter" ;
      		alt_t0_cnt:units = "counts" ;
      		alt_t0_cnt:source = "APID 1072, 1088, 1104 Byte 0028-0029" ;
      		alt_t0_cnt:contentType = "referenceInformation" ;
      		alt_t0_cnt:description = "ATLAS flight s/w T0 counter that clears with 1PPS  (not EU-converted)" ;
      		alt_t0_cnt:coordinates = "delta_time" ;
      	ushort alt_spw_not_ready_cnt(delta_time) ;
      		alt_spw_not_ready_cnt:long_name = "SpW Not Ready Counter" ;
      		alt_spw_not_ready_cnt:units = "counts" ;
      		alt_spw_not_ready_cnt:source = "APID 1072, 1088, 1104 Byte 0115" ;
      		alt_spw_not_ready_cnt:contentType = "referenceInformation" ;
      		alt_spw_not_ready_cnt:description = "Counts each time SpW causes DFC to wait to transmit data to back-end (Status Only)  (not EU-converted)" ;
      		alt_spw_not_ready_cnt:coordinates = "delta_time" ;
      	ushort alt_sci_seg_limit(delta_time) ;
      		alt_sci_seg_limit:long_name = "Science Data Segment Limit Size" ;
      		alt_sci_seg_limit:units = "counts" ;
      		alt_sci_seg_limit:source = "APID 1072, 1088, 1104 Byte 0069-0070" ;
      		alt_sci_seg_limit:contentType = "referenceInformation" ;
      		alt_sci_seg_limit:description = "Science Data Segment Limit Size ; initialization Value  (not EU-converted)" ;
      		alt_sci_seg_limit:coordinates = "delta_time" ;
      	uint alt_rw_start_reg_s(delta_time) ;
      		alt_rw_start_reg_s:long_name = "Altimetric Strong Range Window Start Reg" ;
      		alt_rw_start_reg_s:units = "counts" ;
      		alt_rw_start_reg_s:source = "APID 1072, 1088, 1104 Byte 0076-0078" ;
      		alt_rw_start_reg_s:contentType = "referenceInformation" ;
      		alt_rw_start_reg_s:description = "Value of register set in initialization command for the number of 10ns ticks between the transmit pulse and the start of the altimetric range window for the strong spot (not EU-converted)" ;
      		alt_rw_start_reg_s:coordinates = "delta_time" ;
      	ushort alt_spot_tag_cnts_s(dim302, dim303) ;
      		alt_spot_tag_cnts_s:long_name = "strong spot tag counter" ;
      		alt_spot_tag_cnts_s:units = "counts" ;
      		alt_spot_tag_cnts_s:source = "APID 1072, 1088, 1104 Byte 0034-0041" ;
      		alt_spot_tag_cnts_s:contentType = "referenceInformation" ;
      		alt_spot_tag_cnts_s:description = "The number of events received by the DFC on channels 1 through 16 summed over 50 range window openings. The four elements of the array correspond to dividing the major frame up into 50 shots. The last element of the array can be 49 or 51 shots depending on the alignment of the range windows with respect to the major frame. Note that these counts are time tag counts and are subject to all the limitations and behaviors associated with time tags (duplicates, FIFO overflows, etc.).  (not EU-converted)" ;
      		alt_spot_tag_cnts_s:coordinates = "delta_time" ;
      	ushort alt_rw_width_reg_s(delta_time) ;
      		alt_rw_width_reg_s:long_name = "Altimetric Strong Range Window Width Reg" ;
      		alt_rw_width_reg_s:units = "counts" ;
      		alt_rw_width_reg_s:source = "APID 1072, 1088, 1104 Byte 0079-0080" ;
      		alt_rw_width_reg_s:contentType = "referenceInformation" ;
      		alt_rw_width_reg_s:description = "Value of register set in initialization command for the number of 10ns ticks between the range window start and range window stop for the strong spot.  (not EU-converted)" ;
      		alt_rw_width_reg_s:coordinates = "delta_time" ;
      	ushort alt_spot_tag_cnts_w(dim304, dim305) ;
      		alt_spot_tag_cnts_w:long_name = "weak spot tag counter" ;
      		alt_spot_tag_cnts_w:units = "counts" ;
      		alt_spot_tag_cnts_w:source = "APID 1072, 1088, 1104 Byte 0042-48" ;
      		alt_spot_tag_cnts_w:contentType = "referenceInformation" ;
      		alt_spot_tag_cnts_w:description = "The number of events received by the DFC on channels 17 through 20 summed over 50 range window openings. The four elements of the array correspond to dividing the major frame up into 50 shots. The last element of the array can be 49 or 51 shots depending on the alignment of the range windows with respect to the major frame. Note that these counts are time tag counts and are subject to all the limitations and behaviors associated with time tags (duplicates, FIFO overflows, etc.).  (not EU-converted)" ;
      		alt_spot_tag_cnts_w:coordinates = "delta_time" ;
      	ushort alt_cmd_count(delta_time) ;
      		alt_cmd_count:long_name = "Command Counter" ;
      		alt_cmd_count:units = "counts" ;
      		alt_cmd_count:source = "APID 1072, 1088, 1104 Byte 0062-0063" ;
      		alt_cmd_count:contentType = "referenceInformation" ;
      		alt_cmd_count:description = "Command Counter; Indicates the number of good commands received by the DFC prior to the Major Frame Packet being transmitted (not EU-converted)" ;
      		alt_cmd_count:coordinates = "delta_time" ;
      	ubyte alt_gp_reg(dim306, dim307) ;
      		alt_gp_reg:long_name = "General Purpose Register" ;
      		alt_gp_reg:units = "counts" ;
      		alt_gp_reg:source = "APID 1072, 1088, 1104 Byte 0100-0101" ;
      		alt_gp_reg:contentType = "referenceInformation" ;
      		alt_gp_reg:description = "General Purpose Register  (not EU-converted)" ;
      		alt_gp_reg:coordinates = "delta_time" ;
      	short tx_leading_coarse(delta_time) ;
      		tx_leading_coarse:long_name = "tx latest leading edge coarse" ;
      		tx_leading_coarse:units = "counts" ;
      		tx_leading_coarse:source = "APID 1072, 1088, 1104 Byte 0054-0056" ;
      		tx_leading_coarse:contentType = "referenceInformation" ;
      		tx_leading_coarse:description = "Latest Leading Start Time Tag-acquired leading start time tag value (paired with trailing start time time tag value) coarse time in counts (not EU-converted)" ;
      		tx_leading_coarse:coordinates = "delta_time" ;
      	ubyte alt_dfc_hk_status(dim308, dim309) ;
      		alt_dfc_hk_status:source = "APID 1072, 1088, 1104 Byte 0106-0110" ;
      		alt_dfc_hk_status:contentType = "referenceInformation" ;
      		alt_dfc_hk_status:description = "DFC Housekeeping Status Bits. Defined in ATLAS MEB PCE DFC FPGA Specification, ICESat-2-MEB-SPEC-0875, section 5.12 (not EU-converted)" ;
      		alt_dfc_hk_status:coordinates = "delta_time" ;
      		alt_dfc_hk_status:long_name = "DFC Housekeeping Status Bits" ;
      		alt_dfc_hk_status:units = "counts" ;
      	ushort alt_write_watchdog(delta_time) ;
      		alt_write_watchdog:long_name = "Tag write watchdog value" ;
      		alt_write_watchdog:units = "counts" ;
      		alt_write_watchdog:source = "APID 1072, 1088, 1104 Byte 0072-0073" ;
      		alt_write_watchdog:contentType = "referenceInformation" ;
      		alt_write_watchdog:description = "Tag write watchdog value ; initialization Value (not EU-converted)" ;
      		alt_write_watchdog:coordinates = "delta_time" ;
