    		norm_neg_quad_phase_m1:contentType = "referenceInformation" ;
    		norm_neg_quad_phase_m1:description = "Noise Histogram Data Record (NHDR) - Normalized signal level detector counts of the negative Quadrature-phase samples (M1) - Down Conversion Chain Identifier 1-2" ;
    		norm_neg_quad_phase_m1:coordinates = "delta_time" ;
    	ushort norm_pos_quad_phase_p3(delta_time, ds_chain) ;
    		norm_pos_quad_phase_p3:long_name = "NHDR Normalized Positive Quadrature-Phase Counts P3 - Chain 1-2" ;
    		norm_pos_quad_phase_p3:units = "counts" ;
    		norm_pos_quad_phase_p3:source = "ATL01/sc3/gpsr/noise_histogram" ;
    		norm_pos_quad_phase_p3:contentType = "referenceInformation" ;
    		norm_pos_quad_phase_p3:description = "Noise Histogram Data Record (NHDR) - Normalized signal level detector counts of the positive Quadrature-phase samples (P3) - Down Conversion Chain Identifier 1-2" ;
    		norm_pos_quad_phase_p3:coordinates = "delta_time" ;
    	ushort norm_pos_quad_phase_p1(delta_time, ds_chain) ;
    		norm_pos_quad_phase_p1:long_name = "NHDR Normalized Positive Quadrature-Phase Counts P1 - Chain 1-2" ;
    		norm_pos_quad_phase_p1:units = "counts" ;
    		norm_pos_quad_phase_p1:source = "ATL01/sc3/gpsr/noise_histogram" ;
    		norm_pos_quad_phase_p1:contentType = "referenceInformation" ;
    		norm_pos_quad_phase_p1:description = "Noise Histogram Data Record (NHDR) - Normalized signal level detector counts of the positive Quadrature-phase samples (P1) - Down Conversion Chain Identifier 1-2" ;
    		norm_pos_quad_phase_p1:coordinates = "delta_time" ;
    	float noise_power(delta_time, ds_chain) ;
    		noise_power:long_name = "NHDR Noise Power - Chain 1-2" ;
    		noise_power:units = "dB" ;
    		noise_power:source = "ATL01/sc3/gpsr/noise_histogram converted" ;
