    		qa_bias_offset_x:source = "Derived (QA)" ;
    		qa_bias_offset_x:contentType = "qualityInformation" ;
    		qa_bias_offset_x:description = "Number of instances where the bias offset X value is outside the limit of -70 to 70 microradians." ;
    		qa_bias_offset_x:coordinates = "delta_time_start" ;
