    		ds_channel:units = "1" ;
    		ds_channel:source = "Dimension Scale" ;
    		ds_channel:valid_min = 1b ;
    		ds_channel:valid_max = 20b ;
    		ds_channel:contentType = "referenceInformation" ;
    		ds_channel:description = "Dimension scale for ATLAS PCE channels (1-16=strong, 17-20=weak)" ;
    	byte ds_fine_counts(ds_fine_counts) ;
    		ds_fine_counts:units = "1" ;
    		ds_fine_counts:long_name = "Fine Counts" ;
