    		ds_fine_counts:valid_max = 74b ;
    		ds_fine_counts:contentType = "referenceInformation" ;
    		ds_fine_counts:description = "Dimension scale for ATLAS Time-of-flight fine counts." ;

    // group attributes:
    		:Description = "This group contains calibrations derived from the ATLAS CAL products." ;
    		:DODS_EXTRA.Unlimited_Dimension = "ds_channel\nds_fine_counts" ;

    group: laser_energy_conversion {
      dimensions:
      	dim34 = 1 ;
      	dim35 = 1 ;
      	cal54_product_len33 = 81 ;
      	dim36 = 8 ;
      	dim37 = 8 ;
      	dim38 = 8 ;
