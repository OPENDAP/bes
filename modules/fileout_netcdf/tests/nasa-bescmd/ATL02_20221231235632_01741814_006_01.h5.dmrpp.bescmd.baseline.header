    		delta_time_start:source = "Derived via Time Tagging" ;
    		delta_time_start:contentType = "referenceInformation" ;
    		delta_time_start:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	int qa_lrs_temp(dim555) ;
    		qa_lrs_temp:long_name = "Num LRS Temp OOB" ;
    		qa_lrs_temp:units = "counts" ;
    		qa_lrs_temp:source = "Derived (QA)" ;
    		qa_lrs_temp:contentType = "qualityInformation" ;
    		qa_lrs_temp:description = "Number of instances where the LRS temperature is outside the limit of -20 to 50 degC." ;
    		qa_lrs_temp:coordinates = "delta_time_start" ;
    	int qa_bias_offset_x(dim556) ;
