    		tams_ab_flag:valid_max = 2 ;
    		tams_ab_flag:contentType = "auxiliaryInformation" ;
    		tams_ab_flag:description = "Indicates if the active TAMS is side a (1) or side b (2)." ;
    		tams_ab_flag:flag_meanings = "a b" ;
    		tams_ab_flag:flag_values = 1, 2 ;

    // group attributes:
    		:Description = "Constants and calibrations related to ATLAS housekeeping data." ;
    } // group housekeeping

  group: tep {
    dimensions:
    	dim248 = 1 ;
    	dim249 = 1 ;
    	dim250 = 1 ;
    	dim251 = 1 ;
    	dim252 = 1 ;
    variables:
    	int tep_check_pce1(dim248) ;
    		tep_check_pce1:long_name = "TEP flag for PCE1." ;
    		tep_check_pce1:units = "1" ;
    		tep_check_pce1:source = "ATLAS L1B ATBD" ;
    		tep_check_pce1:valid_min = 0 ;
    		tep_check_pce1:valid_max = 1 ;
    		tep_check_pce1:contentType = "auxiliaryInformation" ;
    		tep_check_pce1:description = "Flag indicating that the PCE1 strong channels should be checked for TEP events. Default value is 1 (indicating that TEP is possible on PCE1). A value of 0 indicates that PCE1 data are not examined for TEP." ;
    		tep_check_pce1:flag_meanings = "do_not_check check" ;
    		tep_check_pce1:flag_values = 0, 1 ;
    	int tep_check_pce2(dim249) ;
    		tep_check_pce2:long_name = "TEP flag for PCE2." ;
    		tep_check_pce2:units = "1" ;
    		tep_check_pce2:source = "ATLAS L1B ATBD" ;
    		tep_check_pce2:valid_min = 0 ;
    		tep_check_pce2:valid_max = 1 ;
    		tep_check_pce2:contentType = "auxiliaryInformation" ;
    		tep_check_pce2:description = "Flag indicating that the PCE2 strong channels should be checked for TEP events. Default value is 1 (indicating that TEP is possible on PCE2). A value of 0 indicates that PCE2 data are not examined for TEP." ;
    		tep_check_pce2:flag_meanings = "do_not_check check" ;
    		tep_check_pce2:flag_values = 0, 1 ;
    	int tep_check_pce3(dim250) ;
    		tep_check_pce3:long_name = "TEP flag for PCE3." ;
    		tep_check_pce3:units = "1" ;
    		tep_check_pce3:source = "ATLAS L1B ATBD" ;
    		tep_check_pce3:valid_min = 0 ;
    		tep_check_pce3:valid_max = 1 ;
    		tep_check_pce3:contentType = "auxiliaryInformation" ;
    		tep_check_pce3:description = "Flag indicating that the PCE3 strong channels should be checked for TEP events. Default value is 0 (indicating that TEP is not possible on PCE3). A value of 1 indicates that PCE3 data are examined for TEP (even though the hardware does not support this possibility)." ;
    		tep_check_pce3:flag_meanings = "do_not_check check" ;
    		tep_check_pce3:flag_values = 0, 1 ;
    	double thres_tep_max(dim251) ;
    		thres_tep_max:long_name = "TEP Detection Maximum" ;
    		thres_tep_max:units = "seconds" ;
    		thres_tep_max:source = "ATLAS L1B ATBD" ;
    		thres_tep_max:contentType = "auxiliaryInformation" ;
    		thres_tep_max:description = "Maximum value used to classify TEP photons. Default value per ATBD is 100ns. (100e-9 sec)" ;
    	double thres_tep_min(dim252) ;
    		thres_tep_min:long_name = "TEP Detection Minimum" ;
    		thres_tep_min:units = "seconds" ;
    		thres_tep_min:contentType = "auxiliaryInformation" ;
    		thres_tep_min:description = "Minimum value used to classify TEP photons. Default value per ATBD is 0ns. (0e-9 sec)" ;
    		thres_tep_min:source = "ATLAS L1B ATBD" ;

    // group attributes:
    		:Description = "Contains ancillary values related to TEP detection." ;
    } // group tep

  group: tod_tof {
