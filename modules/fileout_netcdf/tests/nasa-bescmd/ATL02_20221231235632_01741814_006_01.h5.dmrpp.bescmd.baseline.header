      		lrs:units = "1" ;
      		lrs:source = "CAL54" ;
      		lrs:contentType = "auxiliaryInformation" ;
      		lrs:description = "LRS coefficients a_(J),b0_(J/count),b1_(J/degC_count),c0_(J/count^2),c1_(J/degC_count^2),d_(J/count^3),e_(J/count^4),std_of_residuals" ;
      	double spd(dim38) ;
      		spd:long_name = "SPD Coeffs" ;
      		spd:units = "1" ;
      		spd:source = "CAL54" ;
      		spd:contentType = "auxiliaryInformation" ;
      		spd:description = "SPD laser monitor coefficients  a_(J),b0_(J/count),b1_(J/degC_count),c0_(J/count^2),c1_(J/degC_count^2),d_(J/count^3),e_(J/count^4),std_of_residuals" ;

      // group attributes:
      		:Description = "Contains CAL54 - absolute, energy monitor" ;
      } // group laser_energy_conversion

    group: low_link_impulse_response {
      dimensions:
      	hist_x = 2000 ;
      	dim40 = 1 ;
      	dim41 = 1 ;
      	dim42 = 1 ;
      	dim43 = 1 ;
