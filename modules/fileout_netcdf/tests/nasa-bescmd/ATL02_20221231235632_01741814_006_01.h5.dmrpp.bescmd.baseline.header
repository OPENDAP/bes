    group: time_at_the_tone {
      dimensions:
      	delta_time = UNLIMITED ; // (423 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	uint gps_1pps_sec(delta_time) ;
      		gps_1pps_sec:long_name = "gps 1pps" ;
      		gps_1pps_sec:units = "seconds since January 6, 1980" ;
      		gps_1pps_sec:source = "ATL01/APID 1136 Byte 0014-0017" ;
      		gps_1pps_sec:contentType = "referenceInformation" ;
      		gps_1pps_sec:description = "GPS reported seconds." ;
      		gps_1pps_sec:coordinates = "delta_time" ;
      	uint gps_1pps_subsec(delta_time) ;
      		gps_1pps_subsec:long_name = "gps 1pps subsec" ;
      		gps_1pps_subsec:units = "milliseconds" ;
      		gps_1pps_subsec:source = "ATL01/APID 1136 Byte 0014-0017" ;
      		gps_1pps_subsec:contentType = "referenceInformation" ;
      		gps_1pps_subsec:description = "GPS reported subseconds" ;
      		gps_1pps_subsec:coordinates = "delta_time" ;
      	uint sc_time_1pps_sec(delta_time) ;
      		sc_time_1pps_sec:long_name = "SC time at 1 pps" ;
      		sc_time_1pps_sec:units = "seconds since January 6, 1980" ;
      		sc_time_1pps_sec:source = "ATL01/APID 1136 Byte 0014-0017" ;
      		sc_time_1pps_sec:contentType = "referenceInformation" ;
      		sc_time_1pps_sec:description = "SC time at the reception of the last 1PPS signal from the GPSR." ;
      		sc_time_1pps_sec:coordinates = "delta_time" ;
      	uint sc_time_1pps_subsec(delta_time) ;
      		sc_time_1pps_subsec:long_name = "SC time at 1 pps (subsec)" ;
      		sc_time_1pps_subsec:units = "100 nanoseconds" ;
      		sc_time_1pps_subsec:source = "ATL01/APID 1136 Byte 0014-0017" ;
      		sc_time_1pps_subsec:contentType = "referenceInformation" ;
      		sc_time_1pps_subsec:description = "Subsecond portion of the SC time at the reception of the last 1PPS signal from the GPSR (seconds since SC epoch: 6-Jan-1980 00:00:00)" ;
      		sc_time_1pps_subsec:coordinates = "delta_time" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
      		:Description = "APID 1136 Spacecraft Time at the Tone Packet - Relayed to SSR. Packet Frequency is by command. ATLAS Time-At-The-Tone-Was Message" ;
      		:data_rate = "Data within this group are stored at the data rate of the source APIDs. (only downlinked on command)." ;
      } // group time_at_the_tone
    } // group housekeeping

  group: tx_pulse_width {
    dimensions:
    	delta_time = UNLIMITED ; // (4229843 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Operations" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Elapsed seconds since the ATLAS SDP GPS Epoch, associated with the transmit time where data from all 3 PCEs are present and aligned. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	float tx_pulse_skew_est(delta_time) ;
    		tx_pulse_skew_est:units = "seconds" ;
    		tx_pulse_skew_est:_FillValue = 3.402823e+38f ;
    		tx_pulse_skew_est:long_name = "Transmit Pulse Skew Estimate" ;
    		tx_pulse_skew_est:source = "ATL02 ATBD, Section 7.2" ;
    		tx_pulse_skew_est:contentType = "modelResult" ;
    		tx_pulse_skew_est:description = "The difference between the averages of the lower and upper threshold crossing times.  This is an estimate of the transmit pulse skew." ;
    		tx_pulse_skew_est:coordinates = "delta_time" ;
    	float tx_pulse_width_lower(delta_time) ;
    		tx_pulse_width_lower:_FillValue = 3.402823e+38f ;
    		tx_pulse_width_lower:long_name = "Transmit Pulse Energy Lower Width" ;
    		tx_pulse_width_lower:units = "seconds" ;
    		tx_pulse_width_lower:source = "ATL03 ATBD" ;
    		tx_pulse_width_lower:contentType = "modelResult" ;
    		tx_pulse_width_lower:description = "The distance between the lower threshold crossing times measured by the Start Pulse Detector. Only present when data from all 3 PCEs are available and aligned." ;
    		tx_pulse_width_lower:coordinates = "delta_time" ;
    	float tx_pulse_width_upper(delta_time) ;
    		tx_pulse_width_upper:_FillValue = 3.402823e+38f ;
    		tx_pulse_width_upper:long_name = "Transmit Pulse Energy Upper Width" ;
    		tx_pulse_width_upper:units = "seconds" ;
    		tx_pulse_width_upper:source = "ATL03 ATBD" ;
    		tx_pulse_width_upper:contentType = "modelResult" ;
    		tx_pulse_width_upper:description = "The distance between the upper threshold crossing times measured by the Start Pulse Detector. Only present when data from all 3 PCEs are available and aligned." ;
    		tx_pulse_width_upper:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters to characterize the ATLAS pulse shape, derived from the Start Pulse Detector data." ;
    		:data_rate = "Parameters in this group are stored at the ATLAS shot rate." ;
    } // group tx_pulse_width

  group: pce2 {

    // group attributes:
    		:Description = "Group contains the Photon Counting Electronics x (PCEx) packet decommutated data" ;
    		:data_rate = "Data within this group are stored at the data rate of the source PCE Data Packets. (nominally fifty per second.)" ;

    group: sxp_ssr_s {
      dimensions:
      	delta_time = UNLIMITED ; // (423 currently)
      	ds_50samples = UNLIMITED ; // (50 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via L1B ATBD" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	byte ds_50samples(ds_50samples) ;
      		ds_50samples:long_name = "DS for 50 bytes" ;
      		ds_50samples:units = "1" ;
      		ds_50samples:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		ds_50samples:valid_min = 1b ;
      		ds_50samples:valid_max = 50b ;
      		ds_50samples:contentType = "referenceInformation" ;
      		ds_50samples:description = "Dimension scale for an array of 50 samples." ;
      		ds_50samples:coordinates = "delta_time latitude longitude" ;
      	double latitude(delta_time, ds_50samples) ;
      		latitude:long_name = "latitude" ;
      		latitude:units = "degrees" ;
      		latitude:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		latitude:contentType = "referenceInformation" ;
      		latitude:description = "Latitude" ;
      		latitude:coordinates = "delta_time" ;
      	double longitude(delta_time, ds_50samples) ;
      		longitude:long_name = "longitude" ;
      		longitude:units = "degrees" ;
      		longitude:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		longitude:contentType = "referenceInformation" ;
      		longitude:description = "Longitude" ;
      		longitude:coordinates = "delta_time" ;
      	double mf_cosz(delta_time) ;
      		mf_cosz:long_name = "First Major Frame cosZ" ;
      		mf_cosz:units = "counts" ;
      		mf_cosz:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		mf_cosz:contentType = "referenceInformation" ;
      		mf_cosz:description = "Cosine of the solar zenith angle" ;
      		mf_cosz:coordinates = "delta_time latitude longitude" ;
      	uint pce_mframe_cnt(delta_time) ;
      		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
      		pce_mframe_cnt:units = "counts" ;
      		pce_mframe_cnt:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		pce_mframe_cnt:contentType = "referenceInformation" ;
      		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over." ;
      		pce_mframe_cnt:coordinates = "delta_time latitude longitude" ;
      	double cosb(delta_time, ds_50samples) ;
      		cosb:long_name = "cosB" ;
      		cosb:units = "counts" ;
      		cosb:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		cosb:contentType = "referenceInformation" ;
      		cosb:description = "Cosine of the off-nadir angle as calculated onboard from the spacecraft information" ;
      		cosb:coordinates = "delta_time latitude longitude" ;
