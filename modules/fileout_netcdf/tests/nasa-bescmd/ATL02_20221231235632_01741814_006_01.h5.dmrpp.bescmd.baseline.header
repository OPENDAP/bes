    		tof_bin_size:contentType = "auxiliaryInformation" ;
    		tof_bin_size:description = "Binsize of peak-aligned, windowed TOF histograms." ;
    	double tof_lower_win_ctr(dim259) ;
    		tof_lower_win_ctr:long_name = "Center of TOF Histogram Lower Window" ;
    		tof_lower_win_ctr:units = "seconds" ;
    		tof_lower_win_ctr:source = "ATLAS L1B ATBD," ;
    		tof_lower_win_ctr:contentType = "auxiliaryInformation" ;
    		tof_lower_win_ctr:description = "Center of the lower TxRx slip detection window within the peak-aligned, windowed TOF histograms." ;
    	double tof_upper_win_ctr(dim260) ;
    		tof_upper_win_ctr:long_name = "Center of TOF Histogram Upper Window" ;
