  group: code_phase {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    	ds_24_slots = UNLIMITED ; // (24 currently)
    variables:
    	byte ds_24_slots(ds_24_slots) ;
    		ds_24_slots:long_name = "DS for 24 slots" ;
    		ds_24_slots:units = "1" ;
    		ds_24_slots:source = "Dimension Scale" ;
    		ds_24_slots:valid_min = 1b ;
    		ds_24_slots:valid_max = 24b ;
    		ds_24_slots:contentType = "referenceInformation" ;
    		ds_24_slots:description = "Dimension scale representing each of the 24 slots." ;
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time, in seconds since the ATLAS SDP GPS Epoch, computed from raw_gps_time_sec and subseconds in the time correlation group. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	byte num_valid_slots(delta_time) ;
    		num_valid_slots:long_name = "Number of slots filled" ;
    		num_valid_slots:units = "counts" ;
    		num_valid_slots:source = "ATL01/sc3/gpsr/code_phase/dfh_x/raw_num_recs" ;
    		num_valid_slots:valid_min = 0b ;
    		num_valid_slots:valid_max = 24b ;
    		num_valid_slots:contentType = "referenceInformation" ;
    		num_valid_slots:description = "Number of the 24 available slots filled by telemetry.  Data values after the number of valid slots are filled with 0. Note: Valid data records will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused data fields within the arrays will be zero-filled." ;
    		num_valid_slots:coordinates = "delta_time" ;
    	uint64 code_chip_count(delta_time, ds_24_slots) ;
    		code_chip_count:long_name = "CDPDR Chip Count" ;
    		code_chip_count:units = "counts" ;
    		code_chip_count:source = "ATL01/sc3/gpsr/code_phase" ;
    		code_chip_count:contentType = "referenceInformation" ;
    		code_chip_count:description = "Code Phase Data Record (CdPDR) - Number of Code Chips Since Start of GPS Week.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		code_chip_count:coordinates = "delta_time" ;
    	byte antenna_id(delta_time, ds_24_slots) ;
    		antenna_id:long_name = "CDPDR Antenna Identifier" ;
    		antenna_id:units = "1" ;
    		antenna_id:source = "ATL01/sc3/gpsr/code_phase" ;
    		antenna_id:valid_min = 0b ;
    		antenna_id:valid_max = 1b ;
    		antenna_id:contentType = "referenceInformation" ;
    		antenna_id:description = "Code Phase Data Record (CdPDR) - Antenna Identifier.  0 = First Antenna  1 = Second Antenna (invalid for present receiver)  All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		antenna_id:coordinates = "delta_time" ;
    		antenna_id:flag_meanings = "first_antenna second_antenna" ;
    		antenna_id:flag_values = 0b, 1b ;
    	byte smooth_flg(delta_time, ds_24_slots) ;
    		smooth_flg:long_name = "CDPDR Smoothing Flag" ;
    		smooth_flg:units = "1" ;
    		smooth_flg:source = "ATL01/sc3/gpsr/code_phase" ;
    		smooth_flg:valid_min = 0b ;
    		smooth_flg:valid_max = 1b ;
    		smooth_flg:contentType = "referenceInformation" ;
    		smooth_flg:description = "Code Phase Data Record (CdPDR) - Smoothing Flag. 0 = Smoothing Not Applied 1 = Carrier phase-based smoothing applied for the reported code phase.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		smooth_flg:coordinates = "delta_time" ;
    		smooth_flg:flag_meanings = "not_applied applied" ;
    		smooth_flg:flag_values = 0b, 1b ;
    	float code_chip_fract(delta_time, ds_24_slots) ;
    		code_chip_fract:long_name = "CDPDR Fractional Chip Count" ;
    		code_chip_fract:units = "counts" ;
    		code_chip_fract:source = "ATL01/sc3/gpsr/code_phase converted" ;
    		code_chip_fract:contentType = "referenceInformation" ;
    		code_chip_fract:description = "Code Phase Data Record (CdPDR) - Fractional Portion of Number of Code Chips Since Start of GPS Week.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		code_chip_fract:coordinates = "delta_time" ;
    	byte constell_id(delta_time, ds_24_slots) ;
    		constell_id:long_name = "CDPDR Constellation ID" ;
    		constell_id:units = "counts" ;
    		constell_id:source = "ATL01/sc3/gpsr/code_phase" ;
    		constell_id:contentType = "referenceInformation" ;
    		constell_id:description = "Code Phase Data Record (CdPDR) - Constellation ID - Single Frequency Channel 1-24 (0 = GPS Constellation; All other values invalid).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		constell_id:coordinates = "delta_time" ;
    	byte signal_type(delta_time, ds_24_slots) ;
    		signal_type:long_name = "CDPDR GPS Signal Type" ;
    		signal_type:units = "1" ;
    		signal_type:source = "ATL01/sc3/gpsr/code_phase" ;
    		signal_type:valid_min = 0b ;
    		signal_type:valid_max = 6b ;
    		signal_type:contentType = "referenceInformation" ;
    		signal_type:description = "Code Phase Data Record (CdPDR) - GPS Signal Type. 0 = GPS L1 C/A  1 = GPS L1 P   2 = GPS L2 C/A (N/A for present receiver)   3 = GPS L2 P   4 = GPS L2 CM   5 = GPS L2 CL (N/A for present receiver)   6 = No signal processing on this channel   All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		signal_type:coordinates = "delta_time" ;
    		signal_type:flag_meanings = "gps_l1a_ca gps_l1_p gps_l2_ca gps_l2_p gps_l2_cm gps_l2_cl no_signal_processing" ;
    		signal_type:flag_values = 0b, 1b, 2b, 3b, 4b, 5b, 6b ;
    	byte deter_f(delta_time, ds_24_slots) ;
    		deter_f:long_name = "CDPDR Deterioration Flag" ;
    		deter_f:units = "1" ;
    		deter_f:source = "ATL01/sc3/gpsr/code_phase" ;
    		deter_f:valid_min = 0b ;
    		deter_f:valid_max = 1b ;
    		deter_f:contentType = "referenceInformation" ;
    		deter_f:description = "Code Phase Data Record (CdPDR) - Deterioration Flag.  0= Carrier Loop Lock Steady   1 = Carrier Loop Lock Unsteady (Measurement data may be deteriorated).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		deter_f:coordinates = "delta_time" ;
    		deter_f:flag_meanings = "steady unsteady" ;
    		deter_f:flag_values = 0b, 1b ;
    	byte channel_num(delta_time, ds_24_slots) ;
    		channel_num:long_name = "CDPDR Channel Number" ;
    		channel_num:units = "counts" ;
    		channel_num:source = "ATL01/sc3/gpsr/code_phase" ;
    		channel_num:valid_min = 0b ;
    		channel_num:valid_max = 23b ;
    		channel_num:contentType = "referenceInformation" ;
    		channel_num:description = "Code Phase Data Record (CdPDR) - Channel Number. 0 to 23;  All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		channel_num:coordinates = "delta_time" ;
    	byte sv_id(delta_time, ds_24_slots) ;
    		sv_id:long_name = "CDPDR Space Vehicle ID" ;
    		sv_id:units = "counts" ;
    		sv_id:source = "ATL01/sc3/gpsr/code_phase" ;
    		sv_id:valid_min = 0b ;
    		sv_id:valid_max = 32b ;
    		sv_id:contentType = "referenceInformation" ;
    		sv_id:description = "Code Phase Data Record (CdPDR) - Space Vehicle ID. (0 = No signal acquisition or tracking;  1-32 = GPS SVs. All other values invalid).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		sv_id:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time\nds_24_slots" ;
    		:Description = "Contains parameters related to Code Phase Data Record (CdPDR)." ;
    		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;
    } // group code_phase

  group: navigation {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    variables:
    	double longitude(delta_time) ;
    		longitude:long_name = "NAV Longitude (WGS84)" ;
    		longitude:units = "degrees_east" ;
    		longitude:source = "ATL01/sc4/gpsr/navigation converted" ;
    		longitude:contentType = "referenceInformation" ;
    		longitude:description = "Navigation Solution Data Record (NAV) - Longitude (WGS84)" ;
    		longitude:coordinates = "delta_time" ;
    	double latitude(delta_time) ;
    		latitude:long_name = "NAV Latitude (WGS84)" ;
    		latitude:units = "degrees_north" ;
    		latitude:source = "ATL01/sc4/gpsr/navigation converted" ;
    		latitude:contentType = "referenceInformation" ;
    		latitude:description = "Navigation Solution Data Record (NAV) - Latitude (WGS84)" ;
    		latitude:coordinates = "delta_time" ;
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time, in seconds since the ATLAS SDP GPS Epoch, computed from raw_gps_time_sec and subseconds in the time correlation group. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	float tdop(delta_time) ;
    		tdop:long_name = "GPSR Time Dilution of Precision" ;
    		tdop:units = "meters" ;
    		tdop:source = "ATL01/sc4/gpsr/navigation converted" ;
    		tdop:contentType = "referenceInformation" ;
    		tdop:description = "GPSR - Time Dilution of Precision. Values greater than 655.34 are saturated to 655.34; Value set to 655.35 when NSM = 1 or in the case NSM = 5 with fewer than 4 SVs available." ;
    		tdop:coordinates = "delta_time latitude longitude" ;
    	double vertical_speed(delta_time) ;
    		vertical_speed:long_name = "NAV Vertical Speed" ;
    		vertical_speed:units = "meters/second" ;
    		vertical_speed:source = "ATL01/sc4/gpsr/navigation converted" ;
    		vertical_speed:contentType = "referenceInformation" ;
    		vertical_speed:description = "Navigation Solution Data Record (NAV) - Vertical Speed" ;
    		vertical_speed:coordinates = "delta_time latitude longitude" ;
    	byte nsm(delta_time) ;
    		nsm:long_name = "GPSR Navigation Solution Method (NSM)" ;
    		nsm:units = "1" ;
    		nsm:source = "ATL01/sc4/gpsr/navigation" ;
    		nsm:valid_min = 1b ;
    		nsm:valid_max = 7b ;
    		nsm:contentType = "referenceInformation" ;
    		nsm:description = "GPSR - Navigation Solution Method. 1 = Propagated  2 = Cold Start - First Nav Fix 3 = Cold Start - Least Squares Method w/ no GDOP Optimization 4 = Least Squares Method w/ all Visible SVs 5 = Kalman Filter Method (Normal Operation) 7 = Invalid Navigation Solution All other values invalid" ;
    		nsm:coordinates = "delta_time latitude longitude" ;
    		nsm:flag_meanings = "propagated cold_lsq_no_gdop lsqm_w_svs normal_lsqm normal_kalman unused invalid_solution" ;
    		nsm:flag_values = 1b, 2b, 3b, 4b, 5b, 6b, 7b ;
    	float velocity_error_x(delta_time) ;
    		velocity_error_x:long_name = "NAV Velocity Error X" ;
    		velocity_error_x:units = "meters/second" ;
    		velocity_error_x:source = "ATL01/sc4/gpsr/navigation converted" ;
    		velocity_error_x:contentType = "referenceInformation" ;
    		velocity_error_x:description = "Navigation Solution Data Record (NAV) - Estimated X velocity error" ;
    		velocity_error_x:coordinates = "delta_time latitude longitude" ;
    	byte max_ura(delta_time) ;
    		max_ura:long_name = "NAV Maximum User Range Accuracy (URA)" ;
    		max_ura:units = "counts" ;
    		max_ura:source = "ATL01/sc4/gpsr/navigation" ;
    		max_ura:valid_min = -16b ;
    		max_ura:valid_max = 15b ;
    		max_ura:contentType = "referenceInformation" ;
    		max_ura:description = "Navigation Solution Data Record (NAV) - Maximum User Range Accuracy (-16 means that no URA is available)" ;
    		max_ura:coordinates = "delta_time latitude longitude" ;
    	float pdop(delta_time) ;
    		pdop:long_name = "NAV Position Dilution of Precision" ;
    		pdop:units = "counts" ;
    		pdop:source = "ATL01/sc4/gpsr/navigation converted" ;
    		pdop:contentType = "referenceInformation" ;
    		pdop:description = "Navigation Solution Data Record (NAV) - Position Dilution of Precision. Values greater than 655.34 are saturated to 655.34; Value set to 655.35 when NSM = 1 or in the case NSM = 5 with fewer than 4 SVs available." ;
    		pdop:coordinates = "delta_time latitude longitude" ;
    	uint gps_time_subsec(delta_time) ;
    		gps_time_subsec:long_name = "TCDR GPS Time (Subseconds)" ;
    		gps_time_subsec:units = "1/4294967296 seconds" ;
    		gps_time_subsec:source = "ATL01/sc4/gpsr/navigation" ;
    		gps_time_subsec:contentType = "referenceInformation" ;
    		gps_time_subsec:description = "Time Correlation Data Record (TCDR) - Subseconds portion of the GPS Time (GPST) representation of the synchronization time stamp. Total seconds elapsed since GPS epoch (6-Jan-1980 00:00:00) starting with 0. (Same data that is provided to ATLAS in RT)" ;
    		gps_time_subsec:coordinates = "delta_time latitude longitude" ;
    	byte n_svs(delta_time) ;
    		n_svs:long_name = "NAV Number of SVs in Solution" ;
    		n_svs:units = "counts" ;
    		n_svs:source = "ATL01/sc4/gpsr/navigation" ;
    		n_svs:valid_min = 0b ;
    		n_svs:valid_max = 8b ;
    		n_svs:contentType = "referenceInformation" ;
    		n_svs:description = "Navigation Solution Data Record (NAV) - The number of SVs the receiver was able to use for the Navigation Solution computation, i.e. SVs for which code and carrier phase measurements and Ephemeris data were available" ;
    		n_svs:coordinates = "delta_time latitude longitude" ;
    	float velocity_error_z(delta_time) ;
    		velocity_error_z:long_name = "NAV Velocity Error Z" ;
    		velocity_error_z:units = "meters/second" ;
    		velocity_error_z:source = "ATL01/sc4/gpsr/navigation converted" ;
    		velocity_error_z:contentType = "referenceInformation" ;
    		velocity_error_z:description = "Navigation Solution Data Record (NAV) - Estimated Z velocity error" ;
    		velocity_error_z:coordinates = "delta_time latitude longitude" ;
    	byte max_curve_fit(delta_time) ;
    		max_curve_fit:long_name = "NAV Maximum Curve Fit" ;
    		max_curve_fit:units = "1" ;
    		max_curve_fit:source = "ATL01/sc4/gpsr/navigation" ;
    		max_curve_fit:valid_min = 0b ;
    		max_curve_fit:valid_max = 15b ;
    		max_curve_fit:contentType = "referenceInformation" ;
    		max_curve_fit:description = "Navigation Solution Data Record (NAV) - Maximum Curve Fit interval taken from all SVs used in current navigation solution" ;
    		max_curve_fit:coordinates = "delta_time latitude longitude" ;
    		max_curve_fit:flag_meanings = "4h 6h 8h 14h 26h 50h 74h 98h 122h 146h no_curve_fit" ;
    		max_curve_fit:flag_values = 0b, 1b, 2b, 3b, 4b, 5b, 6b, 7b, 8b, 9b, 15b ;
    	double position_y(delta_time) ;
    		position_y:long_name = "NAV Position Y (WGS84)" ;
    		position_y:units = "meters" ;
    		position_y:source = "ATL01/sc4/gpsr/navigation converted" ;
    		position_y:contentType = "referenceInformation" ;
    		position_y:description = "Navigation Solution Data Record (NAV) - Estimated Y position of the platform reference point according to the Navigation Solution Method (NSM) at the point in time of GPST (WGS84)" ;
    		position_y:coordinates = "delta_time latitude longitude" ;
    	float position_error_y(delta_time) ;
    		position_error_y:long_name = "NAV Position Error Y" ;
    		position_error_y:units = "meters" ;
    		position_error_y:source = "ATL01/sc4/gpsr/navigation converted" ;
    		position_error_y:contentType = "referenceInformation" ;
    		position_error_y:description = "Navigation Solution Data Record (NAV) - Estimated Y position error" ;
    		position_error_y:coordinates = "delta_time latitude longitude" ;
    	double velocity_y(delta_time) ;
    		velocity_y:long_name = "NAV Velocity Y (WGS84)" ;
    		velocity_y:units = "meters/second" ;
    		velocity_y:source = "ATL01/sc4/gpsr/navigation converted" ;
    		velocity_y:contentType = "referenceInformation" ;
    		velocity_y:description = "Navigation Solution Data Record (NAV) - Estimated Y velocity of the platform reference point according to the Navigation Solution Method (NSM) at the point in time of GPST (WGS84)" ;
    		velocity_y:coordinates = "delta_time latitude longitude" ;
    	double position_x(delta_time) ;
    		position_x:long_name = "NAV Position X (WGS84)" ;
    		position_x:units = "meters" ;
    		position_x:source = "ATL01/sc4/gpsr/navigation converted" ;
    		position_x:contentType = "referenceInformation" ;
    		position_x:description = "Navigation Solution Data Record (NAV) - Estimated X position of the platform reference point according to the Navigation Solution Method (NSM) at the point in time of GPST (WGS84)" ;
    		position_x:coordinates = "delta_time latitude longitude" ;
    	uint gps_time_sec(delta_time) ;
    		gps_time_sec:long_name = "TCDR GPS Time (Seconds)" ;
    		gps_time_sec:units = "seconds" ;
    		gps_time_sec:source = "ATL01/sc4/gpsr/navigation" ;
    		gps_time_sec:contentType = "referenceInformation" ;
    		gps_time_sec:description = "Time Correlation Data Record (TCDR) - GPS Time (GPST) representation of the synchronization time stamp. Total seconds elapsed since GPS epoch (6-Jan-1980 00:00:00) starting with 0. (Same data that is provided to ATLAS in RT)" ;
    		gps_time_sec:coordinates = "delta_time latitude longitude" ;
    	double position_z(delta_time) ;
    		position_z:long_name = "NAV Position Z (WGS84)" ;
    		position_z:units = "meters" ;
    		position_z:source = "ATL01/sc4/gpsr/navigation converted" ;
    		position_z:contentType = "referenceInformation" ;
    		position_z:description = "Navigation Solution Data Record (NAV) - Estimated Z position of the platform reference point according to the Navigation Solution Method (NSM) at the point in time of GPST (WGS84)" ;
    		position_z:coordinates = "delta_time latitude longitude" ;
    	double velocity_x(delta_time) ;
    		velocity_x:long_name = "NAV Velocity X (WGS84)" ;
    		velocity_x:units = "meters/second" ;
    		velocity_x:source = "ATL01/sc4/gpsr/navigation converted" ;
    		velocity_x:contentType = "referenceInformation" ;
    		velocity_x:description = "Navigation Solution Data Record (NAV) - Estimated X velocity of the platform reference point according to the Navigation Solution Method (NSM) at the point in time of GPST (WGS84)" ;
    		velocity_x:coordinates = "delta_time latitude longitude" ;
    	float gdop(delta_time) ;
    		gdop:long_name = "NAV Geometric Dilution of Precision" ;
    		gdop:units = "meters" ;
    		gdop:source = "ATL01/sc4/gpsr/navigation converted" ;
    		gdop:contentType = "referenceInformation" ;
    		gdop:description = "Navigation Solution Data Record (NAV) - Geometric Dilution of Precision (Values greater than 655.34 m are saturated to 655.34 m.)" ;
    		gdop:coordinates = "delta_time latitude longitude" ;
    	int clock_freq_error(delta_time) ;
    		clock_freq_error:long_name = "NAV Receiver Clock Frequency Error" ;
    		clock_freq_error:units = "seconds" ;
    		clock_freq_error:source = "ATL01/sc4/gpsr/navigation" ;
    		clock_freq_error:contentType = "referenceInformation" ;
    		clock_freq_error:description = "Navigation Solution Data Record (NAV) - Receiver Clock Frequency Error" ;
    		clock_freq_error:coordinates = "delta_time" ;
    	float gnss_time_error(delta_time) ;
    		gnss_time_error:long_name = "NAV GNSS System Time Error" ;
    		gnss_time_error:units = "seconds" ;
    		gnss_time_error:source = "ATL01/sc4/gpsr/navigation converted" ;
    		gnss_time_error:contentType = "referenceInformation" ;
    		gnss_time_error:description = "Navigation Solution Data Record (NAV) - GNSS System Time Error" ;
    		gnss_time_error:coordinates = "delta_time latitude longitude" ;
    	float velocity_error_y(delta_time) ;
    		velocity_error_y:long_name = "NAV Velocity Error Y" ;
    		velocity_error_y:units = "meters/second" ;
    		velocity_error_y:source = "ATL01/sc4/gpsr/navigation converted" ;
    		velocity_error_y:contentType = "referenceInformation" ;
    		velocity_error_y:description = "Navigation Solution Data Record (NAV) - Estimated Y velocity error" ;
    		velocity_error_y:coordinates = "delta_time latitude longitude" ;
    	float position_error_x(delta_time) ;
    		position_error_x:long_name = "NAV Position Error X" ;
    		position_error_x:units = "meters" ;
    		position_error_x:source = "ATL01/sc4/gpsr/navigation converted" ;
    		position_error_x:contentType = "referenceInformation" ;
    		position_error_x:description = "Navigation Solution Data Record (NAV) - Estimated X position error" ;
    		position_error_x:coordinates = "delta_time latitude longitude" ;
    	short position_qa(delta_time) ;
    		position_qa:long_name = "NAV Time Quality Index" ;
    		position_qa:units = "seconds" ;
    		position_qa:source = "ATL01/sc4/gpsr/navigation" ;
    		position_qa:valid_min = 0s ;
    		position_qa:valid_max = 4095s ;
    		position_qa:contentType = "referenceInformation" ;
    		position_qa:description = "Navigation Solution Data Record (NAV) - Time Quality Index; Values greater than 4095 ns are saturated to 4095 ns." ;
    		position_qa:coordinates = "delta_time latitude longitude" ;
    	double velocity_z(delta_time) ;
    		velocity_z:long_name = "NAV Velocity Z (WGS84)" ;
    		velocity_z:units = "meters/second" ;
    		velocity_z:source = "ATL01/sc4/gpsr/navigation converted" ;
    		velocity_z:contentType = "referenceInformation" ;
    		velocity_z:description = "Navigation Solution Data Record (NAV) - Estimated Z velocity of the platform reference point according to the Navigation Solution Method (NSM) at the point in time of GPST (WGS84)" ;
    		velocity_z:coordinates = "delta_time latitude longitude" ;
    	double h_ell(delta_time) ;
    		h_ell:units = "meters" ;
    		h_ell:long_name = "NAV Height Above Reference Ellipsoid (WGS84)" ;
