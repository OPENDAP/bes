group: sc {
  dimensions:
  	delta_time = UNLIMITED ; // (423 currently)
  variables:
  	double delta_time(delta_time) ;
  		delta_time:long_name = "Elapsed GPS seconds" ;
  		delta_time:standard_name = "time" ;
  		delta_time:units = "seconds since 2018-01-01" ;
  		delta_time:source = "Derived via Time Tagging" ;
  		delta_time:contentType = "referenceInformation" ;
  		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS Standard Data Product (SDP) epoch. By adding atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch time can be computed." ;
  	uint sc_time_1pps_sec(delta_time) ;
  		sc_time_1pps_sec:long_name = "SC time at 1 pps (sec)" ;
  		sc_time_1pps_sec:units = "seconds" ;
  		sc_time_1pps_sec:source = "ATL01/sc" ;
  		sc_time_1pps_sec:contentType = "referenceInformation" ;
  		sc_time_1pps_sec:description = "SC time at the reception of the last 1PPS signal from the GPSR (seconds since SC epoch: 6-Jan-1980 00:00:00)" ;
  		sc_time_1pps_sec:coordinates = "delta_time" ;
  	uint sc_time_1pps_subsec(delta_time) ;
  		sc_time_1pps_subsec:long_name = "SC time at 1 pps (subsec)" ;
  		sc_time_1pps_subsec:units = "100 nanoseconds" ;
  		sc_time_1pps_subsec:source = "ATL01/sc" ;
  		sc_time_1pps_subsec:contentType = "referenceInformation" ;
  		sc_time_1pps_subsec:description = "Subsecond portion of the SC time at the reception of the last 1PPS signal from the GPSR (seconds since SC epoch: 6-Jan-1980 00:00:00)" ;
  		sc_time_1pps_subsec:coordinates = "delta_time" ;
  	uint acs_time_subsec(delta_time) ;
  		acs_time_subsec:long_name = "ACS time (subsec)" ;
  		acs_time_subsec:units = "100 nanoseconds" ;
  		acs_time_subsec:source = "ATL01/sc" ;
  		acs_time_subsec:contentType = "referenceInformation" ;
  		acs_time_subsec:description = "Subsecond portion of the SC time at the initiation of the ACS task (seconds since SC epoch: 6-Jan-1980 00:00:00) (Same time provided within the Attitude/Rate message to ATLAS in RT at 1Hz)" ;
  		acs_time_subsec:coordinates = "delta_time" ;
  	uint acs_time_sec(delta_time) ;
  		acs_time_sec:long_name = "ACS time (sec)" ;
  		acs_time_sec:units = "seconds" ;
  		acs_time_sec:source = "ATL01/sc" ;
  		acs_time_sec:contentType = "referenceInformation" ;
  		acs_time_sec:description = "SC time at the initiation of the ACS task (seconds since SC epoch: 6-Jan-1980 00:00:00) (Same time provided within the Attitude/Rate message to ATLAS in RT at 1Hz)" ;
  		acs_time_sec:coordinates = "delta_time" ;

  // group attributes:
  		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
  		:Description = "Group contains the Spacecraft (SC) Ancillary Science packet #1 decommutated data" ;
  		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;

  group: ephemeris {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "The time tag of the data by using raw_prop_time_sec and subsecs in the L1A ephemeris group, relative to the ATLAS SDP GSP epoch. The ATLAS Standard Data Products (SDP) GPS epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	float eci_velocity_res_z(delta_time) ;
    		eci_velocity_res_z:long_name = "SC ECI velocity residual Z" ;
    		eci_velocity_res_z:units = "meters/second" ;
    		eci_velocity_res_z:source = "ATL01/sc1/ephemeris" ;
    		eci_velocity_res_z:contentType = "referenceInformation" ;
    		eci_velocity_res_z:description = "ACS Orbit Determination Filter velocity of Z frame residual." ;
    		eci_velocity_res_z:coordinates = "delta_time" ;
    	double eci_velocity_z(delta_time) ;
    		eci_velocity_z:long_name = "SC ECI Velocity Z" ;
    		eci_velocity_z:units = "meters/second" ;
    		eci_velocity_z:source = "ATL01/sc1/ephemeris converted" ;
    		eci_velocity_z:contentType = "referenceInformation" ;
    		eci_velocity_z:description = "ACS SC Z velocity in the ECI coordinate frame. (Same data that is provided to ATLAS in RT)" ;
    		eci_velocity_z:coordinates = "delta_time" ;
    	double eci_position_y(delta_time) ;
    		eci_position_y:long_name = "SC ECI Position Y" ;
    		eci_position_y:units = "meters" ;
    		eci_position_y:source = "ATL01/sc1/ephemeris converted" ;
    		eci_position_y:contentType = "referenceInformation" ;
    		eci_position_y:description = "ACS SC Y position in the ECI coordinate frame. (Same data that is provided to ATLAS in RT)" ;
    		eci_position_y:coordinates = "delta_time" ;
    	double eci_velocity_y(delta_time) ;
    		eci_velocity_y:long_name = "SC ECI Velocity Y" ;
    		eci_velocity_y:units = "meters/second" ;
    		eci_velocity_y:source = "ATL01/sc1/ephemeris converted" ;
    		eci_velocity_y:contentType = "referenceInformation" ;
    		eci_velocity_y:description = "ACS SCY  velocity in the ECI coordinate frame. (Same data that is provided to ATLAS in RT)" ;
    		eci_velocity_y:coordinates = "delta_time" ;
    	float eci_velocity_res_x(delta_time) ;
    		eci_velocity_res_x:long_name = "SC ECI velocity residual X" ;
    		eci_velocity_res_x:units = "meters/second" ;
    		eci_velocity_res_x:source = "ATL01/sc1/ephemeris" ;
    		eci_velocity_res_x:contentType = "referenceInformation" ;
    		eci_velocity_res_x:description = "ACS Orbit Determination Filter velocity of X frame residual." ;
    		eci_velocity_res_x:coordinates = "delta_time" ;
    	float eci_position_res_z(delta_time) ;
    		eci_position_res_z:long_name = "SC ECI Position residual Z" ;
    		eci_position_res_z:units = "meters" ;
    		eci_position_res_z:source = "ATL01/sc1/ephemeris" ;
    		eci_position_res_z:contentType = "referenceInformation" ;
    		eci_position_res_z:description = "ACS Orbit Determination Filter position of Z frame residual." ;
    		eci_position_res_z:coordinates = "delta_time" ;
    	double eci_position_x(delta_time) ;
    		eci_position_x:long_name = "SC ECI Position X" ;
    		eci_position_x:units = "meters" ;
    		eci_position_x:source = "ATL01/sc1/ephemeris converted" ;
    		eci_position_x:contentType = "referenceInformation" ;
    		eci_position_x:description = "ACS SC X position in the ECI coordinate frame. (Same data that is provided to ATLAS in RT)" ;
    		eci_position_x:coordinates = "delta_time" ;
    	double eci_velocity_x(delta_time) ;
    		eci_velocity_x:long_name = "SC ECI Velocity X" ;
    		eci_velocity_x:units = "meters/second" ;
    		eci_velocity_x:source = "ATL01/sc1/ephemeris converted" ;
    		eci_velocity_x:contentType = "referenceInformation" ;
    		eci_velocity_x:description = "ACS SC X velocity in the ECI coordinate frame. (Same data that is provided to ATLAS in RT)" ;
    		eci_velocity_x:coordinates = "delta_time" ;
    	float eci_velocity_res_y(delta_time) ;
    		eci_velocity_res_y:long_name = "SC ECI velocity residual Y" ;
    		eci_velocity_res_y:units = "meters/second" ;
    		eci_velocity_res_y:source = "ATL01/sc1/ephemeris" ;
    		eci_velocity_res_y:contentType = "referenceInformation" ;
    		eci_velocity_res_y:description = "ACS Orbit Determination Filter velocity of Y frame residual." ;
    		eci_velocity_res_y:coordinates = "delta_time" ;
    	float eci_position_res_y(delta_time) ;
    		eci_position_res_y:long_name = "SC ECI Position residualY" ;
    		eci_position_res_y:units = "meters" ;
    		eci_position_res_y:source = "ATL01/sc1/ephemeris" ;
    		eci_position_res_y:contentType = "referenceInformation" ;
    		eci_position_res_y:description = "ACS Orbit Determination Filter position of Y frame residual." ;
    		eci_position_res_y:coordinates = "delta_time" ;
    	float eci_position_res_x(delta_time) ;
    		eci_position_res_x:long_name = "SC ECI Position residual X" ;
    		eci_position_res_x:units = "meters" ;
    		eci_position_res_x:source = "ATL01/sc1/ephemeris" ;
    		eci_position_res_x:contentType = "referenceInformation" ;
    		eci_position_res_x:description = "ACS Orbit Determination Filter position of X frame residual." ;
    		eci_position_res_x:coordinates = "delta_time" ;
    	double eci_position_z(delta_time) ;
    		eci_position_z:long_name = "SC ECI Position Z" ;
    		eci_position_z:units = "meters" ;
    		eci_position_z:source = "ATL01/sc1/ephemeris converted" ;
    		eci_position_z:contentType = "referenceInformation" ;
    		eci_position_z:description = "ACS SC Z position in the ECI coordinate frame. (Same data that is provided to ATLAS in RT)" ;
    		eci_position_z:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters related to spacecraft Ephemeris Propagator." ;
    		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;
