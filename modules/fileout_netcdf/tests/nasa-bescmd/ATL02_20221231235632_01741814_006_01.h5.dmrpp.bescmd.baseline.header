      // group attributes:
      		:Description = "CAL17 - PCE Effective Cell Delay. Calibration product for PCE Unit Cell Delay --  a matrix of effective fine counts as a function of temperature, voltage, PCE card, channel, and event edge (rising, falling)." ;

