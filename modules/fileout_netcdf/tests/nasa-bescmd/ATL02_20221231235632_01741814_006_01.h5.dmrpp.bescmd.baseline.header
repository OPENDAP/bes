    		txrx_discard_count:contentType = "qualityInformation" ;
    		txrx_discard_count:description = "The number of Tx discarded because of data gaps when attempting to repair a TxRx slip." ;
    	int txrx_repair_count(dim650) ;
    		txrx_repair_count:long_name = "TxRx Repair Count" ;
    		txrx_repair_count:units = "counts" ;
    		txrx_repair_count:source = "TxRx detection" ;
    		txrx_repair_count:contentType = "qualityInformation" ;
    		txrx_repair_count:description = "The number of Tx misalignments repaired for the PCE indicated in txrx_slip_repair. (0=no repair attempted)" ;
    	int txrx_slip_repair(dim651) ;
    		txrx_slip_repair:long_name = "TxRx Repair flag" ;
    		txrx_slip_repair:units = "1" ;
    		txrx_slip_repair:source = "TxRx detection" ;
    		txrx_slip_repair:valid_min = 0 ;
    		txrx_slip_repair:valid_max = 3 ;
    		txrx_slip_repair:contentType = "qualityInformation" ;
    		txrx_slip_repair:description = "Indicates the PCE for which a txrx slip repair was attempted. (0=no repair attempted)" ;
    		txrx_slip_repair:flag_meanings = "not_attempted pce1 pce2 pce3" ;
    		txrx_slip_repair:flag_values = 0, 1, 2, 3 ;

    // group attributes:
    		:Description = "Contains statistics and flags related to TOF QA." ;

    group: pce2 {
