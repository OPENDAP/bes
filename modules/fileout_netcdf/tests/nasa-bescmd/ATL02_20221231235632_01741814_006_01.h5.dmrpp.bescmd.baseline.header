    		norm_pos_in_phase_p3:description = "Noise Histogram Data Record (NHDR) - Normalized signal level detector counts of the positive In-phase samples (P3) - Down Conversion Chain Identifier 1-2" ;
    		norm_pos_in_phase_p3:coordinates = "delta_time" ;
    	ushort norm_pos_in_phase_p1(delta_time, ds_chain) ;
    		norm_pos_in_phase_p1:long_name = "NHDR Normalized Positive In-Phase Counts P1 - Chain 1-2" ;
