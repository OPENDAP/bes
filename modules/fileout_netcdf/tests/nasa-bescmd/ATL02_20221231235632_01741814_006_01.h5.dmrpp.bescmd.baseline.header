    		corr_tx_coarse_pce3:source = "ATLAS L1B ATBD" ;
    		corr_tx_coarse_pce3:contentType = "auxiliaryInformation" ;
    		corr_tx_coarse_pce3:description = "Correction for the PCE3 Transmit coarse clock offset. This corrects for the offset between the actual number of coarse clock cycles and the reported number of coarse clock cycles. Default value is -1." ;
    	float dupe_fc_tol(dim267) ;
    		dupe_fc_tol:long_name = "Duplicate_Tolerance" ;
    		dupe_fc_tol:units = "counts" ;
    		dupe_fc_tol:source = "ATLAS L1B ATBD" ;
    		dupe_fc_tol:contentType = "auxiliaryInformation" ;
    		dupe_fc_tol:description = "Tolerance used when comparing fine counts within duplicate detection" ;
    	int discard_short_mframes(dim268) ;
    		discard_short_mframes:long_name = "Discard_Short_MFrames" ;
    		discard_short_mframes:units = "1" ;
    		discard_short_mframes:contentType = "auxiliaryInformation" ;
    		discard_short_mframes:description = "If TRUE, discard the photons associated with major frames containing less than 199 Tx." ;
    		discard_short_mframes:source = "ATLAS L1B ATBD," ;
    	int repair_txrx_slip(dim269) ;
    		repair_txrx_slip:long_name = "TXRX_Slip_Repair" ;
    		repair_txrx_slip:units = "1" ;
    		repair_txrx_slip:source = "ATLAS L1B ATBD," ;
    		repair_txrx_slip:contentType = "auxiliaryInformation" ;
    		repair_txrx_slip:description = "If TRUE, attempt to repair any detected TXRX slip." ;
    	double cal_uso_scale(dim270) ;
    		cal_uso_scale:long_name = "Calibration value for USO" ;
    		cal_uso_scale:units = "1" ;
    		cal_uso_scale:source = "ATLAS L1B ATBD" ;
    		cal_uso_scale:contentType = "auxiliaryInformation" ;
    		cal_uso_scale:description = "Calibration value for the Ultra Stable Oscillator (USO). Computed using the number of coarse clock ticks measurement generated by the USO between sequential 1PPS time stamps from the on-orbit GPS to estimate the coarse clock ruler scale factor." ;
    	int corr_rx_coarse_pce1(dim271) ;
    		corr_rx_coarse_pce1:long_name = "Correction value for PCE1 Rx coarse clock offset" ;
    		corr_rx_coarse_pce1:units = "counts" ;
    		corr_rx_coarse_pce1:source = "ATLAS L1B ATBD" ;
    		corr_rx_coarse_pce1:contentType = "auxiliaryInformation" ;
    		corr_rx_coarse_pce1:description = "Correction for the PCE1 Receive coarse clock offset. This corrects for the offset between the actual number of coarse clock cycles and the reported number of coarse clock cycles (for each channel). Default value is -1." ;
    	double cal_risefall_box_int(dim272) ;
    		cal_risefall_box_int:long_name = "cal_risefall boxcar interval" ;
    		cal_risefall_box_int:units = "counts" ;
    		cal_risefall_box_int:source = "ATLAS L1B ATBD" ;
    		cal_risefall_box_int:contentType = "auxiliaryInformation" ;
    		cal_risefall_box_int:description = "Boxcar averaging interval for cal_risefall averaging, in major-frame counts.  Boxcar averages are using to generate 1D spline coefficients. The spline coefficients are used to create smoothed, interpolated cal_risefall values at the full data rate." ;
    	int corr_tx_coarse_pce1(dim273) ;
    		corr_tx_coarse_pce1:long_name = "Correction value for PCE1 Tx coarse clock offset" ;
    		corr_tx_coarse_pce1:units = "counts" ;
    		corr_tx_coarse_pce1:source = "ATLAS L1B ATBD" ;
    		corr_tx_coarse_pce1:contentType = "auxiliaryInformation" ;
    		corr_tx_coarse_pce1:description = "Correction for the PCE1 Transmit coarse clock offset. This corrects for the offset between the actual number of coarse clock cycles and the reported number of coarse clock cycles. Default value is -1." ;

    // group attributes:
    		:Description = "Contains ancillary parameters related to Time-of-Flight and/or Time-of-Day calculations." ;
    		:data_rate = "Data within this group pertain to the granule in its entirety." ;
    } // group tod_tof
  } // group ancillary_data

group: atlas {

  // group attributes:
  		:Description = "Group contains the ATLAS EU-converted data" ;
  		:data_rate = "Data within this group are stored at the nominal rate of the corresponding ATLAS APIDs (varies per APID)." ;

  group: housekeeping {

    // group attributes:
    		:Description = "Group contains the ATLAS EU-converted housekeeping data" ;
    		:data_rate = "Data within this group are stored at the nominal rate of the corresponding ATLAS APIDs (varies per APID)." ;

    group: radiometry {
      dimensions:
      	delta_time = UNLIMITED ; // (423 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via L1B ATBD" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed. The timestamp is computed based on the housekeeping design to sample laser near the asc 1pps internal pulse. (See the L1B ATBD section 5 Radiometric Corrections )" ;
      		delta_time:coordinates = "delta_time" ;
      	float bg_sensitivity_pce3_s(delta_time) ;
      		bg_sensitivity_pce3_s:long_name = "PCE3 Strong background sensitivity" ;
      		bg_sensitivity_pce3_s:units = "events/s/Watt" ;
      		bg_sensitivity_pce3_s:source = "ATBD Section 5.5.2" ;
      		bg_sensitivity_pce3_s:contentType = "referenceInformation" ;
      		bg_sensitivity_pce3_s:description = "PCE3, Strong spot - receiver response per watt of continuous illumination in the passband from a diffuse source larger than the field of view, in the absence of any dead time effects." ;
      		bg_sensitivity_pce3_s:coordinates = "delta_time" ;
      	float bg_sensitivity_pce1_s(delta_time) ;
      		bg_sensitivity_pce1_s:long_name = "PCE1 Strong background sensitivity" ;
      		bg_sensitivity_pce1_s:units = "events/s/Watt" ;
      		bg_sensitivity_pce1_s:source = "ATBD Section 5.5.2" ;
      		bg_sensitivity_pce1_s:contentType = "referenceInformation" ;
      		bg_sensitivity_pce1_s:description = "PCE1, Strong spot - receiver response per watt of continuous illumination in the passband from a diffuse source larger than the field of view, in the absence of any dead time effects." ;
      		bg_sensitivity_pce1_s:coordinates = "delta_time" ;
      	float ret_sensitivity_pce3_w(delta_time) ;
      		ret_sensitivity_pce3_w:long_name = "PCE3 Weak return sensitivity" ;
      		ret_sensitivity_pce3_w:units = "events/s/Watt" ;
      		ret_sensitivity_pce3_w:source = "ATBD Section 5.5.3" ;
      		ret_sensitivity_pce3_w:contentType = "referenceInformation" ;
      		ret_sensitivity_pce3_w:description = "PCE3, Weak spot - receiver response per joule/return pulse in the field of view, in the absence of any deadtime effects." ;
      		ret_sensitivity_pce3_w:coordinates = "delta_time" ;
      	float ret_sensitivity_pce3_s(delta_time) ;
      		ret_sensitivity_pce3_s:long_name = "PCE3 Strong return sensitivity" ;
      		ret_sensitivity_pce3_s:units = "events/s/Watt" ;
      		ret_sensitivity_pce3_s:source = "ATBD Section 5.5.3" ;
      		ret_sensitivity_pce3_s:contentType = "referenceInformation" ;
      		ret_sensitivity_pce3_s:description = "PCE3, Strong spot - receiver response per joule/return pulse in the field of view, in the absence of any deadtime effects." ;
      		ret_sensitivity_pce3_s:coordinates = "delta_time" ;
      	float ret_sensitivity_pce2_w(delta_time) ;
      		ret_sensitivity_pce2_w:long_name = "PCE2 Weak return sensitivity" ;
      		ret_sensitivity_pce2_w:units = "events/s/Watt" ;
      		ret_sensitivity_pce2_w:source = "ATBD Section 5.5.3" ;
      		ret_sensitivity_pce2_w:contentType = "referenceInformation" ;
      		ret_sensitivity_pce2_w:description = "PCE2, Weak spot - receiver response per joule/return pulse in the field of view, in the absence of any deadtime effects." ;
      		ret_sensitivity_pce2_w:coordinates = "delta_time" ;
      	float bg_sensitivity_pce2_w(delta_time) ;
      		bg_sensitivity_pce2_w:long_name = "PCE2 Weak background sensitivity" ;
      		bg_sensitivity_pce2_w:units = "events/s/Watt" ;
      		bg_sensitivity_pce2_w:source = "ATBD Section 5.5.2" ;
      		bg_sensitivity_pce2_w:contentType = "referenceInformation" ;
      		bg_sensitivity_pce2_w:description = "PCE2, Weak spot - receiver response per watt of continuous illumination in the passband from a diffuse source larger than the field of view, in the absence of any dead time effects." ;
      		bg_sensitivity_pce2_w:coordinates = "delta_time" ;
      	float bg_sensitivity_pce1_w(delta_time) ;
      		bg_sensitivity_pce1_w:long_name = "PCE1 Weak background sensitivity" ;
      		bg_sensitivity_pce1_w:units = "events/s/Watt" ;
      		bg_sensitivity_pce1_w:source = "ATBD Section 5.5.2" ;
      		bg_sensitivity_pce1_w:contentType = "referenceInformation" ;
      		bg_sensitivity_pce1_w:description = "PCE1, Weak spot - receiver response per watt of continuous illumination in the passband from a diffuse source larger than the field of view, in the absence of any dead time effects." ;
      		bg_sensitivity_pce1_w:coordinates = "delta_time" ;
      	float ret_sensitivity_pce1_s(delta_time) ;
      		ret_sensitivity_pce1_s:long_name = "PCE1 Strong return sensitivity" ;
      		ret_sensitivity_pce1_s:units = "events/s/Watt" ;
      		ret_sensitivity_pce1_s:source = "ATBD Section 5.5.3" ;
      		ret_sensitivity_pce1_s:contentType = "referenceInformation" ;
      		ret_sensitivity_pce1_s:description = "PCE1, Strong spot - receiver response per joule/return pulse in the field of view, in the absence of any deadtime effects." ;
      		ret_sensitivity_pce1_s:coordinates = "delta_time" ;
      	float bg_sensitivity_pce3_w(delta_time) ;
      		bg_sensitivity_pce3_w:long_name = "PCE3 Weak background sensitivity" ;
      		bg_sensitivity_pce3_w:units = "events/s/Watt" ;
      		bg_sensitivity_pce3_w:source = "ATBD Section 5.5.2" ;
      		bg_sensitivity_pce3_w:contentType = "referenceInformation" ;
      		bg_sensitivity_pce3_w:description = "PCE3, Weak spot - receiver response per watt of continuous illumination in the passband from a diffuse source larger than the field of view, in the absence of any dead time effects." ;
      		bg_sensitivity_pce3_w:coordinates = "delta_time" ;
      	float ret_sensitivity_pce1_w(delta_time) ;
      		ret_sensitivity_pce1_w:long_name = "PCE1 Weak return sensitivity" ;
      		ret_sensitivity_pce1_w:units = "events/s/Watt" ;
      		ret_sensitivity_pce1_w:source = "ATBD Section 5.5.3" ;
      		ret_sensitivity_pce1_w:contentType = "referenceInformation" ;
      		ret_sensitivity_pce1_w:description = "PCE1, Weak spot - receiver response per joule/return pulse in the field of view, in the absence of any deadtime effects." ;
      		ret_sensitivity_pce1_w:coordinates = "delta_time" ;
      	float bg_sensitivity_pce2_s(delta_time) ;
      		bg_sensitivity_pce2_s:long_name = "PCE2 Strong background sensitivity" ;
      		bg_sensitivity_pce2_s:units = "events/s/Watt" ;
      		bg_sensitivity_pce2_s:source = "ATBD Section 5.5.2" ;
      		bg_sensitivity_pce2_s:contentType = "referenceInformation" ;
      		bg_sensitivity_pce2_s:description = "PCE2, Strong spot - receiver response per watt of continuous illumination in the passband from a diffuse source larger than the field of view, in the absence of any dead time effects." ;
      		bg_sensitivity_pce2_s:coordinates = "delta_time" ;
      	float ret_sensitivity_pce2_s(delta_time) ;
      		ret_sensitivity_pce2_s:long_name = "PCE2 Strong return sensitivity" ;
      		ret_sensitivity_pce2_s:units = "events/s/Watt" ;
      		ret_sensitivity_pce2_s:source = "ATBD Section 5.5.3" ;
      		ret_sensitivity_pce2_s:contentType = "referenceInformation" ;
      		ret_sensitivity_pce2_s:description = "PCE2, Strong spot - receiver response per joule/return pulse in the field of view, in the absence of any deadtime effects." ;
      		ret_sensitivity_pce2_s:coordinates = "delta_time" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
      		:Description = "The radiometry group contains background and receiver sensitivity" ;
      		:data_rate = "Data within this group are stored at the data rate of one hertz." ;
      } // group radiometry

    group: laser_energy_lrs {
      dimensions:
      	delta_time = UNLIMITED ; // (21150 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed. The timestamp is computed based on the housekeeping design to sample laser near the asc 1pps internal pulse. (See the L1B ATBD section 5 Radiometric Corrections )" ;
      	float e_tx_pce3_w(delta_time) ;
      		e_tx_pce3_w:_FillValue = 3.402823e+38f ;
      		e_tx_pce3_w:long_name = "Spot laser energy for PCE3, weak" ;
