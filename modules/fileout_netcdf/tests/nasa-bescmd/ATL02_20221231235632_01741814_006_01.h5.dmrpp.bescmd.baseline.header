      		return_source:contentType = "auxiliaryInformation" ;
      		return_source:description = "Source of the events from which the data are derived." ;
      		return_source:flag_meanings = "none tep maat echo" ;
      		return_source:flag_values = 0, 1, 2, 3 ;
      	char cal20_product(dim43, cal20_product_len39) ;
      		cal20_product:long_name = "CAL Product Name" ;
      		cal20_product:units = "1" ;
      		cal20_product:source = "CAL20" ;
