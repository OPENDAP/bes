    		n_svs_acquired:contentType = "referenceInformation" ;
    		n_svs_acquired:description = "Housekeeping Parameter Report (HK) - GNSS satellites being acquired at the most recent PPS, i.e. channels with Multi-Frequency Tracking state 2...4" ;
    		n_svs_acquired:coordinates = "delta_time" ;
    	byte protocol_selection_f(delta_time) ;
    		protocol_selection_f:long_name = "HK MilBus Protocol Selection Flag" ;
    		protocol_selection_f:units = "counts" ;
    		protocol_selection_f:source = "ATL01/sc4/gpsr/hk" ;
    		protocol_selection_f:valid_min = 0b ;
    		protocol_selection_f:valid_max = 1b ;
    		protocol_selection_f:contentType = "referenceInformation" ;
    		protocol_selection_f:description = "Housekeeping Parameter Report (HK) - MilBus Protocol Selection Flag" ;
    		protocol_selection_f:coordinates = "delta_time" ;
    	ushort transient_protocol_errors(delta_time) ;
    		transient_protocol_errors:long_name = "HK MilBus Transient Protocol Error Count" ;
    		transient_protocol_errors:units = "counts" ;
    		transient_protocol_errors:source = "ATL01/sc4/gpsr/hk" ;
    		transient_protocol_errors:contentType = "referenceInformation" ;
    		transient_protocol_errors:description = "Housekeeping Parameter Report (HK) - MilBus Transient Protocol Error Count" ;
    		transient_protocol_errors:coordinates = "delta_time" ;
    	ubyte dc_tag_error(delta_time) ;
    		dc_tag_error:units = "counts" ;
    		dc_tag_error:long_name = "HK Data Cache Tag Error Counter" ;
    		dc_tag_error:source = "ATL01/sc4/gpsr/hk" ;
    		dc_tag_error:contentType = "referenceInformation" ;
    		dc_tag_error:description = "Housekeeping Parameter Report (HK) - Data Cache Tag Error Counter" ;
    		dc_tag_error:coordinates = "delta_time" ;
    	byte clock_source(delta_time) ;
    		clock_source:long_name = "HK Clock Source" ;
    		clock_source:units = "1" ;
    		clock_source:source = "ATL01/sc4/gpsr/hk" ;
    		clock_source:valid_min = 0b ;
    		clock_source:valid_max = 1b ;
    		clock_source:contentType = "referenceInformation" ;
    		clock_source:description = "Housekeeping Parameter Report (HK) - Clock Source" ;
    		clock_source:coordinates = "delta_time" ;
    		clock_source:flag_meanings = "internal_clock value_invalid" ;
    		clock_source:flag_values = 0b, 1b ;
    	byte prom_edac_status(delta_time) ;
