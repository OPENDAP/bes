      		alt_debug_reg:contentType = "referenceInformation" ;
      		alt_debug_reg:description = "Debug Control Register  (not EU-converted)" ;
      		alt_debug_reg:coordinates = "delta_time" ;
      	ubyte alt_cal_interval(delta_time) ;
      		alt_cal_interval:long_name = "Calibration request interval from TDC" ;
      		alt_cal_interval:units = "counts" ;
      		alt_cal_interval:source = "APID 1072, 1088, 1104 Byte 0068" ;
      		alt_cal_interval:contentType = "referenceInformation" ;
      		alt_cal_interval:description = "Calibration request interval from TDC  (not EU-converted)" ;
      		alt_cal_interval:coordinates = "delta_time" ;
      	ubyte alt_edac_status(dim314, dim315) ;
      		alt_edac_status:long_name = "EDAC Status Bits" ;
      		alt_edac_status:units = "counts" ;
      		alt_edac_status:source = "APID 1072, 1088, 1104 Byte 102-105" ;
      		alt_edac_status:contentType = "referenceInformation" ;
      		alt_edac_status:description = "EDAC Status Bits.  Defined in ATLAS MEB PCE DFC FPGA Specification, ICESat-2-MEB-SPEC-0875, section 5.12  (not EU-converted)" ;
      		alt_edac_status:coordinates = "delta_time" ;
      	ushort alt_cal_rise(delta_time) ;
      		alt_cal_rise:units = "counts" ;
      		alt_cal_rise:long_name = "Altimetric Latest Calibration Rising" ;
      		alt_cal_rise:source = "APID 1072, 1088, 1104 Byte 0050-0051" ;
      		alt_cal_rise:contentType = "referenceInformation" ;
      		alt_cal_rise:description = "The PCE latest calibration value for the rising edge  (not EU-converted)" ;
      		alt_cal_rise:coordinates = "delta_time" ;
      	uint pce_mframe_cnt(delta_time) ;
      		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
      		pce_mframe_cnt:units = "counts" ;
      		pce_mframe_cnt:source = "APID 1072, 1088, 1104 Byte 0030-0033" ;
      		pce_mframe_cnt:contentType = "referenceInformation" ;
      		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over. It is in the first time tag science packet. Used as part of the photon ID" ;
      		pce_mframe_cnt:coordinates = "delta_time" ;
      	int64 alt_imet_at_first_t0(delta_time) ;
      		alt_imet_at_first_t0:long_name = "IMET at first T0 after 1 pps" ;
      		alt_imet_at_first_t0:units = "counts" ;
      		alt_imet_at_first_t0:source = "APID 1072, 1088, 1104 Byte 0022-0027" ;
      		alt_imet_at_first_t0:contentType = "referenceInformation" ;
      		alt_imet_at_first_t0:description = "ATLAS flight s/w 25 MHz IMET counter value when 1PPS is received  (not EU-converted)" ;
      		alt_imet_at_first_t0:coordinates = "delta_time" ;
      	ubyte alt_last_opcode(delta_time) ;
      		alt_last_opcode:long_name = "Last Opcode Received" ;
      		alt_last_opcode:units = "counts" ;
      		alt_last_opcode:source = "APID 1072, 1088, 1104 Byte 0064" ;
      		alt_last_opcode:contentType = "referenceInformation" ;
      		alt_last_opcode:description = "Indicates the last good opcode received prior to the Major Frame Packet being transmitted; 0xFF indicates an error condition of either protocol ID mismatch, invalid opcode, or invalid length  (not EU-converted)" ;
      		alt_last_opcode:coordinates = "delta_time" ;
      	ushort alt_rw_width_reg_w(delta_time) ;
      		alt_rw_width_reg_w:long_name = "Altimetric Weak Range Window Width Reg" ;
      		alt_rw_width_reg_w:units = "counts" ;
      		alt_rw_width_reg_w:source = "APID 1072, 1088, 1104 Byte 0089-0090" ;
      		alt_rw_width_reg_w:contentType = "referenceInformation" ;
      		alt_rw_width_reg_w:description = "Value of register set in initialization command for the number of 10ns ticks between the range window start and range window stop for the weak spot.  (not EU-converted)" ;
      		alt_rw_width_reg_w:coordinates = "delta_time" ;
      	uint alt_1pps_count(delta_time) ;
      		alt_1pps_count:long_name = "MET 1pps counter" ;
      		alt_1pps_count:units = "counts" ;
      		alt_1pps_count:source = "APID 1072, 1088, 1104 Byte 0012-0015" ;
      		alt_1pps_count:contentType = "referenceInformation" ;
      		alt_1pps_count:description = "ATLAS flight s/w 1PPS counter  (not EU-converted)" ;
      		alt_1pps_count:coordinates = "delta_time" ;
      	ubyte alt_dfc_status(delta_time) ;
