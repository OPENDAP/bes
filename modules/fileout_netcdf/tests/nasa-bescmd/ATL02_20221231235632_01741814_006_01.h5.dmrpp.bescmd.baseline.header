      		slip_magnitude:units = "seconds" ;
      		slip_magnitude:source = "TxRx detection" ;
      		slip_magnitude:contentType = "qualityInformation" ;
      		slip_magnitude:description = "Average magnitude (and direction) of Tx sawtooth misalignment." ;
      	double ne_delta_time(dim661) ;
