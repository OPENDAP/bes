    		laser_barrel2_t:long_name = "LRS_HK Optics Thermistor #2 (Laser Side Barrel #2 Temperature)" ;
    		laser_barrel2_t:units = "degreesC" ;
    		laser_barrel2_t:source = "LRS_HK" ;
    		laser_barrel2_t:contentType = "referenceInformation" ;
    		laser_barrel2_t:description = "Temperature of Optics Thermistor #2 (Laser Side Barrel #2) - 0x0000 = 0.000 V (nominal short); 0xFFFF = +4.000 V (nominal open) [see thermistor scaling section later for temperature scaling]" ;
    		laser_barrel2_t:coordinates = "delta_time" ;
    	uint spwdiscardcmd(delta_time) ;
    		spwdiscardcmd:long_name = "LRS_HK Spacewire words dropped due to timeout waiting for full CCSDS packet" ;
    		spwdiscardcmd:units = "counts" ;
    		spwdiscardcmd:source = "LRS_HK" ;
    		spwdiscardcmd:contentType = "referenceInformation" ;
    		spwdiscardcmd:description = "This 32-bit counter is incremented each time a spacewire command word is dropped by Failsafe Mode due to a timeout while waiting for a full CCSDS packet (an abnormal condition).  It starts at 0x00000000, and rolls over to 0x00000000 when it increments from 0xFFFFFFFF.  This counter will be reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT)." ;
    		spwdiscardcmd:coordinates = "delta_time" ;
    	byte sysstat_sdca_cable(delta_time) ;
    		sysstat_sdca_cable:long_name = "LRS_HK System Status Register - SDC Analog Cable Status" ;
    		sysstat_sdca_cable:units = "1" ;
    		sysstat_sdca_cable:source = "LRS_HK" ;
    		sysstat_sdca_cable:valid_min = 0b ;
    		sysstat_sdca_cable:valid_max = 1b ;
    		sysstat_sdca_cable:contentType = "referenceInformation" ;
    		sysstat_sdca_cable:description = "The current status of the LRS FPGA SDCD (Stellar Detector Card Digital Cable. (0 = DISCONNECTED (abnormal condition); 1 = CONNECTED (normal operating condition))" ;
    		sysstat_sdca_cable:coordinates = "delta_time" ;
    		sysstat_sdca_cable:flag_meanings = "disconnected connected" ;
    		sysstat_sdca_cable:flag_values = 0b, 1b ;
    	float p5v_cmon_a(delta_time) ;
    		p5v_cmon_a:long_name = "LRS_HK +5VDC Current Monitor" ;
    		p5v_cmon_a:units = "amps" ;
    		p5v_cmon_a:source = "LRS_HK" ;
    		p5v_cmon_a:contentType = "referenceInformation" ;
    		p5v_cmon_a:description = "Amperage of +5VDC Current Monitor - 0x0000 = 0.000 A; 0xFFFF = +0.400 A : A_LRS_HK.ANALOGHK[8]" ;
    		p5v_cmon_a:coordinates = "delta_time" ;
    	byte spwstat_lp_err(delta_time) ;
    		spwstat_lp_err:long_name = "LRS_HK Spacewire Status Register - Last Packet Error" ;
    		spwstat_lp_err:units = "1" ;
    		spwstat_lp_err:source = "LRS_HK" ;
    		spwstat_lp_err:valid_min = 0b ;
    		spwstat_lp_err:valid_max = 3b ;
    		spwstat_lp_err:contentType = "referenceInformation" ;
    		spwstat_lp_err:description = "This is the Last Packet Error Code portion of the LRS spacewire interface register." ;
    		spwstat_lp_err:coordinates = "delta_time" ;
    		spwstat_lp_err:flag_meanings = "no_error eep_rec incomplete_sw invalid" ;
    		spwstat_lp_err:flag_values = 0b, 1b, 2b, 3b ;
    	byte sysstat_ldca_cable(delta_time) ;
    		sysstat_ldca_cable:long_name = "LRS_HK System Status Register - LDC Analog Cable Status" ;
    		sysstat_ldca_cable:units = "1" ;
    		sysstat_ldca_cable:source = "LRS_HK" ;
    		sysstat_ldca_cable:valid_min = 0b ;
    		sysstat_ldca_cable:valid_max = 1b ;
    		sysstat_ldca_cable:contentType = "referenceInformation" ;
    		sysstat_ldca_cable:description = "The current status of the LRS FPGA LDCA (Laser Detector Card Analog) Cable. (0 = DISCONNECTED (abnormal condition); 1 = CONNECTED (normal operating condition))" ;
    		sysstat_ldca_cable:coordinates = "delta_time" ;
    		sysstat_ldca_cable:flag_meanings = "disconnected connected" ;
    		sysstat_ldca_cable:flag_values = 0b, 1b ;
    	byte spwstat_st_f(delta_time) ;
    		spwstat_st_f:long_name = "LRS_HK Spacewire Status Register - Status" ;
    		spwstat_st_f:units = "1" ;
    		spwstat_st_f:source = "LRS_HK" ;
    		spwstat_st_f:valid_min = 0b ;
    		spwstat_st_f:valid_max = 1b ;
    		spwstat_st_f:contentType = "referenceInformation" ;
    		spwstat_st_f:description = "This is the status flag portion of the LRS spacewire interface status register." ;
    		spwstat_st_f:coordinates = "delta_time" ;
    		spwstat_st_f:flag_meanings = "not_running running" ;
    		spwstat_st_f:flag_values = 0b, 1b ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters relating to the Application Housekeeping Packet (LRStmHK)(APID 1120). The (Application Mode) Housekeeping Packet provides all LRS health and safety data.  It is normally reported and stored at a 1 Hz rate." ;
    		:data_rate = "Data within this group are stored at the data rate of the source LRS Housekeeping Data (nominally once per second)." ;
    } // group hk_1120
  } // group lrs

group: orbit_info {
  dimensions:
  	delta_time = UNLIMITED ; // (1 currently)
  variables:
  	double delta_time(delta_time) ;
  		delta_time:long_name = "Granule Start Time" ;
  		delta_time:standard_name = "time" ;
  		delta_time:units = "seconds since 2018-01-01" ;
  		delta_time:source = "Operations" ;
  		delta_time:contentType = "referenceInformation" ;
  		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch at the start of the granule. At the time of ATL02 creation, the equator crossing time is not precisely known.. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
  	byte cycle_number(delta_time) ;
  		cycle_number:long_name = "Cycle Number" ;
  		cycle_number:units = "1" ;
  		cycle_number:valid_min = 0b ;
  		cycle_number:valid_max = 50b ;
  		cycle_number:contentType = "referenceInformation" ;
  		cycle_number:description = "A count of the number of exact repeats of this reference orbit." ;
  		cycle_number:coordinates = "delta_time" ;
  		cycle_number:source = "Operations" ;
  	ushort orbit_number(delta_time) ;
  		orbit_number:long_name = "Orbit Number" ;
  		orbit_number:units = "1" ;
  		orbit_number:valid_min = 1US ;
  		orbit_number:valid_max = 65000US ;
  		orbit_number:contentType = "referenceInformation" ;
  		orbit_number:description = "Unique identifying number for each planned ICESat-2 orbit." ;
  		orbit_number:coordinates = "delta_time" ;
  		orbit_number:source = "Operations" ;
  	short rgt(delta_time) ;
  		rgt:long_name = "Reference Ground track" ;
  		rgt:units = "1" ;
  		rgt:source = "Operations" ;
  		rgt:valid_min = 1s ;
  		rgt:valid_max = 1387s ;
  		rgt:contentType = "referenceInformation" ;
  		rgt:description = "The reference ground track (RGT) is the track on the earth at which a specified unit vector within the observatory is pointed. Under nominal operating conditions, there will be no data collected along the RGT, as the RGT is spanned by GT3 and GT4.  During slews or off-pointing, it is possible that ground tracks may intersect the RGT. The ICESat-2 mission has 1387 RGTs." ;
  		rgt:coordinates = "delta_time" ;

  // group attributes:
  		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
  		:Description = "Contains orbit information." ;
  		:data_rate = "Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)" ;
  } // group orbit_info

group: quality_assessment {
  dimensions:
  	ds_statistics = UNLIMITED ; // (5 currently)
  	dim316 = 1 ;
  	dim317 = 1 ;
  variables:
  	byte ds_statistics(ds_statistics) ;
  		ds_statistics:long_name = "Dimension scale for QA statistics" ;
  		ds_statistics:units = "1" ;
  		ds_statistics:source = "Derived (QA)" ;
  		ds_statistics:contentType = "qualityInformation" ;
  		ds_statistics:description = "QA statistics array index" ;
  		ds_statistics:flag_meanings = "number_of_points minimum maximum average standard_deviation" ;
  		ds_statistics:flag_values = 1b, 2b, 3b, 4b, 5b ;
  	int qa_granule_fail_reason(dim316) ;
  		qa_granule_fail_reason:long_name = "Granule Failure Reason" ;
  		qa_granule_fail_reason:units = "1" ;
  		qa_granule_fail_reason:valid_min = 0 ;
  		qa_granule_fail_reason:valid_max = 5 ;
  		qa_granule_fail_reason:contentType = "qualityInformation" ;
  		qa_granule_fail_reason:description = "Flag indicating granule failure reason. 0=no failure; 1=processing error; 2=Insufficient output data was generated; 3=An uncorrected TxRx slip condition was detected; 4=TBD_Failure; 5=other failure." ;
  		qa_granule_fail_reason:flag_meanings = "no_failure NO_SIM_HK NO_PMF_TIME TIME_OF_DAY_FAILURE TIME_OF_FLIGHT_FAILURE OTHER_FAILURE" ;
  		qa_granule_fail_reason:flag_values = 0, 1, 2, 3, 4, 5 ;
  		qa_granule_fail_reason:source = "Operations" ;
  	int qa_granule_pass_fail(dim317) ;
  		qa_granule_pass_fail:long_name = "Granule Pass Flag" ;
  		qa_granule_pass_fail:units = "1" ;
  		qa_granule_pass_fail:valid_min = 0 ;
  		qa_granule_pass_fail:valid_max = 1 ;
  		qa_granule_pass_fail:contentType = "qualityInformation" ;
  		qa_granule_pass_fail:description = "Flag indicating granule quality. 0=granule passes automatic QA. 1=granule fails automatic QA." ;
  		qa_granule_pass_fail:flag_meanings = "PASS FAIL" ;
  		qa_granule_pass_fail:flag_values = 0, 1 ;
  		qa_granule_pass_fail:source = "Operations" ;

  // group attributes:
  		:Description = "Contains quality assessment data. This may include QA counters, QA along-track data and/or QA summary data." ;
  		:DODS_EXTRA.Unlimited_Dimension = "ds_statistics" ;

  group: along_track {
    dimensions:
    	delta_time_start = UNLIMITED ; // (43 currently)
    variables:
    	double delta_time_start(delta_time_start) ;
    		delta_time_start:long_name = "Elapsed UTC seconds" ;
    		delta_time_start:standard_name = "time" ;
    		delta_time_start:units = "seconds since 2018-01-01" ;
    		delta_time_start:source = "Derived via Time Tagging" ;
    		delta_time_start:contentType = "referenceInformation" ;
    		delta_time_start:description = "Number of seconds since the ATLAS SDP epoch at the start of the QA interval. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	double delta_time_end(delta_time_start) ;
    		delta_time_end:long_name = "Elapsed GPS seconds" ;
    		delta_time_end:standard_name = "time" ;
    		delta_time_end:units = "seconds since 2018-01-01" ;
    		delta_time_end:source = "Derived via Time Tagging" ;
    		delta_time_end:contentType = "referenceInformation" ;
    		delta_time_end:description = "Number of seconds since the ATLAS SDP epoch at the end of the QA interval. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time_start" ;
    		:Description = "Along-track statistics" ;

    group: pce1 {
      variables:
      	int qa_at_n_dupe(delta_time_start) ;
      		qa_at_n_dupe:long_name = "Number of duplicates" ;
      		qa_at_n_dupe:units = "counts" ;
      		qa_at_n_dupe:source = "Derived (QA)" ;
      		qa_at_n_dupe:contentType = "qualityInformation" ;
      		qa_at_n_dupe:description = "The number of duplicate Rx events detected in the along-track interval." ;
      		qa_at_n_dupe:coordinates = "../delta_time_start" ;
      	int qa_at_n_rx_w(delta_time_start) ;
      		qa_at_n_rx_w:units = "counts" ;
      		qa_at_n_rx_w:long_name = "Number of Weak Rx Events" ;
      		qa_at_n_rx_w:source = "Derived (QA)" ;
      		qa_at_n_rx_w:contentType = "qualityInformation" ;
      		qa_at_n_rx_w:description = "The number of Weak Rx events in the along-track interval." ;
      		qa_at_n_rx_w:coordinates = "../delta_time_start" ;
      	int qa_at_n_rx_s(delta_time_start) ;
      		qa_at_n_rx_s:units = "counts" ;
      		qa_at_n_rx_s:long_name = "Number of Strong Rx Events" ;
      		qa_at_n_rx_s:source = "Derived (QA)" ;
      		qa_at_n_rx_s:contentType = "qualityInformation" ;
      		qa_at_n_rx_s:description = "The number of Strong Rx events in the along-track interval." ;
      		qa_at_n_rx_s:coordinates = "../delta_time_start" ;
      	int qa_at_n_tep(delta_time_start) ;
      		qa_at_n_tep:long_name = "Number of TEPs" ;
      		qa_at_n_tep:units = "counts" ;
      		qa_at_n_tep:source = "Derived (QA)" ;
      		qa_at_n_tep:contentType = "qualityInformation" ;
      		qa_at_n_tep:description = "The number of TEP events detected in the along-track interval." ;
      		qa_at_n_tep:coordinates = "../delta_time_start" ;
      	int qa_at_n_tx(delta_time_start) ;
      		qa_at_n_tx:long_name = "Number of Tx Pulses" ;
      		qa_at_n_tx:units = "counts" ;
      		qa_at_n_tx:source = "Derived (QA)" ;
      		qa_at_n_tx:contentType = "qualityInformation" ;
      		qa_at_n_tx:description = "The number of Tx Pulses in the along-track interval." ;
      		qa_at_n_tx:coordinates = "../delta_time_start" ;
      	double qa_at_tx_ll_stat(delta_time_start, ds_statistics) ;
      		qa_at_tx_ll_stat:long_name = "QA Tx LL Stat" ;
      		qa_at_tx_ll_stat:units = "counts" ;
      		qa_at_tx_ll_stat:source = "Derived (QA)" ;
      		qa_at_tx_ll_stat:contentType = "qualityInformation" ;
      		qa_at_tx_ll_stat:description = "Along-track statistic of Transmit Leading Lower time of flight. Values are in the order number_of_points, minimum, maximum, average, standard_deviation." ;
      		qa_at_tx_ll_stat:coordinates = "../delta_time_start" ;
      	double qa_at_tx_other_stat(delta_time_start, ds_statistics) ;
      		qa_at_tx_other_stat:long_name = "QA Tx Other Stat" ;
      		qa_at_tx_other_stat:units = "counts" ;
      		qa_at_tx_other_stat:source = "Derived (QA)" ;
      		qa_at_tx_other_stat:contentType = "qualityInformation" ;
      		qa_at_tx_other_stat:description = "Along-track statistic of the Other Transmit time of flight measurement. For PCE1, this is Transmit Leading Upper edge (LU) time; for PCE2 this is Transmit Trailing Upper edge (TU) time; and for PCE3 this is Transmit Trailing Lower edge (TL) time. Values are in the order number_of_points, minimum, maximum, average, standard_deviation." ;
      		qa_at_tx_other_stat:coordinates = "../delta_time_start" ;

      // group attributes:
      		:Description = "Along-track statistics" ;
      } // group pce1

    group: pce2 {
      variables:
      	int qa_at_n_dupe(delta_time_start) ;
      		qa_at_n_dupe:long_name = "Number of duplicates" ;
      		qa_at_n_dupe:units = "counts" ;
      		qa_at_n_dupe:source = "Derived (QA)" ;
