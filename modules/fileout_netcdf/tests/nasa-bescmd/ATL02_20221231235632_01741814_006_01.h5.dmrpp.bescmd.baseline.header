      		alt_dfc_status:units = "counts" ;
      		alt_dfc_status:source = "APID 1072, 1088, 1104 Byte 0111" ;
      		alt_dfc_status:contentType = "referenceInformation" ;
      		alt_dfc_status:description = "DFC Status Bits. Defined in ATLAS MEB PCE DFC FPGA Specification, ICESat-2-MEB-SPEC-0875, section 5.12  (not EU-converted)" ;
      		alt_dfc_status:coordinates = "delta_time" ;
      	ushort alt_cal_fall(delta_time) ;
      		alt_cal_fall:long_name = "Altimetric Latest Calibration Falling" ;
      		alt_cal_fall:units = "counts" ;
      		alt_cal_fall:source = "APID 1072, 1088, 1104 Byte 0052-0053" ;
      		alt_cal_fall:contentType = "referenceInformation" ;
      		alt_cal_fall:description = "The PCE latest calibration value for the falling edge. (not EU-converted)" ;
      		alt_cal_fall:coordinates = "delta_time" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
      		:Description = "This DFCx_hk is a diagnostic packet (APID 1072, 1088, 1104) that contains some of the parameters normally part of APID 1254, 1264, 1274 (as sequence flag 01).   Also know as the PCE Altimetric Science Data Major Frame described in ICESat-2-MEB-SPEC-0875, section 5.13 Table 19. The data in the group are neither calibrated nor EU-converted, but preserved from ATL01 in order provided diagnostics for TOF processing." ;
      		:data_rate = "Data within this group are stored at the data rate of the source APID (nominally 50 Hz)." ;
      } // group dfc_hk

    group: algorithm_science {
      dimensions:
      	delta_time = UNLIMITED ; // (21150 currently)
      	ds_4bytes = UNLIMITED ; // (4 currently)
      	ds_2samples = UNLIMITED ; // (2 currently)
      variables:
      	byte ds_2samples(ds_2samples) ;
      		ds_2samples:long_name = "DS for 2 bytes" ;
      		ds_2samples:units = "1" ;
      		ds_2samples:source = "Dimension Scale" ;
      		ds_2samples:valid_min = 1b ;
      		ds_2samples:valid_max = 2b ;
      		ds_2samples:contentType = "referenceInformation" ;
      		ds_2samples:description = "Dimension scale for an array of 2 samples." ;
      	byte ds_4bytes(ds_4bytes) ;
      		ds_4bytes:long_name = "DS for 4 bytes" ;
      		ds_4bytes:units = "1" ;
      		ds_4bytes:source = "Dimension Scale" ;
      		ds_4bytes:valid_min = 1b ;
      		ds_4bytes:valid_max = 4b ;
      		ds_4bytes:contentType = "referenceInformation" ;
      		ds_4bytes:description = "Dimension scale for an array of 4 bytes." ;
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via L1B ATBD" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	double gps_time(delta_time) ;
      		gps_time:long_name = "GPS seconds at the Major Frame" ;
      		gps_time:units = "seconds" ;
      		gps_time:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
      		gps_time:contentType = "referenceInformation" ;
      		gps_time:description = "GPS seconds at the Major Frame" ;
      		gps_time:coordinates = "delta_time" ;
      	ubyte alt_band_mask(delta_time, ds_4bytes) ;
      		alt_band_mask:long_name = "Band Mask" ;
      		alt_band_mask:units = "counts" ;
      		alt_band_mask:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
      		alt_band_mask:contentType = "referenceInformation" ;
      		alt_band_mask:description = "ATLAS flight software Band Mask. Each byte corresponds to a single Band, in the order of 1-4." ;
      		alt_band_mask:coordinates = "delta_time" ;
      	double amet_time(delta_time) ;
      		amet_time:long_name = "AMET seconds at the Major Frame" ;
      		amet_time:units = "seconds" ;
      		amet_time:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
      		amet_time:contentType = "referenceInformation" ;
      		amet_time:description = "AMET seconds at the Major Frame" ;
      		amet_time:coordinates = "delta_time" ;
      	ubyte useflag(delta_time) ;
      		useflag:long_name = "Science Mode Flag" ;
      		useflag:units = "counts" ;
      		useflag:source = "ATL01/atlas/pcex/a_alt_sci/" ;
      		useflag:valid_min = 0UB ;
      		useflag:valid_max = 15UB ;
      		useflag:contentType = "referenceInformation" ;
      		useflag:description = "Science Mode Flag.  Used by ATL03 to discard non-science mode data. 0=stby, 1=science_mode, 2=test, 3=manual, 4=radio, 5=unknown, > 10=amcs_not_normal" ;
      		useflag:coordinates = "delta_time" ;
      		useflag:flag_meanings = "stby science test manual radio unknown unused unused unused unused stby_alt_amcs science_alt_amcs test_alt_amcs manual_alt_amcs radio_alt_amcs unknown_alt_amcs" ;
      		useflag:flag_values = 0UB, 1UB, 2UB, 3UB, 4UB, 5UB, 6UB, 7UB, 8UB, 9UB, 10UB, 11UB, 12UB, 13UB, 14UB, 15UB ;
      	uint alt_band_channel_mask(delta_time, ds_4bytes) ;
      		alt_band_channel_mask:long_name = "Band Channel Mask" ;
      		alt_band_channel_mask:units = "counts" ;
      		alt_band_channel_mask:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
      		alt_band_channel_mask:contentType = "referenceInformation" ;
      		alt_band_channel_mask:description = "ATLAS flight software Band Channel Mask. (Bands 1-4)" ;
      		alt_band_channel_mask:coordinates = "delta_time" ;
      	uint pce_mframe_cnt(delta_time) ;
      		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
      		pce_mframe_cnt:units = "counts" ;
      		pce_mframe_cnt:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
      		pce_mframe_cnt:contentType = "referenceInformation" ;
      		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over." ;
      		pce_mframe_cnt:coordinates = "delta_time" ;
      	ubyte alt_nbands(delta_time) ;
      		alt_nbands:long_name = "Number of bands" ;
      		alt_nbands:units = "counts" ;
      		alt_nbands:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
      		alt_nbands:contentType = "referenceInformation" ;
      		alt_nbands:description = "ATLAS flight software Number of bands." ;
      		alt_nbands:coordinates = "delta_time" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time\nds_4bytes\nds_2samples" ;
      		:Description = "The PCE PMF Algorithm Science data group. Contains outputs from the onboard receiver algorithm software." ;
      		:data_rate = "Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)" ;

      group: weak {
        variables:
        	ubyte alt_error_flags(delta_time, ds_2samples) ;
        		alt_error_flags:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		alt_error_flags:contentType = "referenceInformation" ;
        		alt_error_flags:description = "FSW error flags" ;
        		alt_error_flags:coordinates = "../delta_time" ;
        		alt_error_flags:long_name = "Error Flags" ;
        		alt_error_flags:units = "counts" ;
        	ubyte daynight_flag(delta_time) ;
        		daynight_flag:long_name = "Day/Night flag" ;
        		daynight_flag:units = "counts" ;
        		daynight_flag:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		daynight_flag:valid_min = 0UB ;
        		daynight_flag:valid_max = 1UB ;
        		daynight_flag:contentType = "referenceInformation" ;
        		daynight_flag:description = "ATLAS flight software Day/Night Flag associated with the major frame. 0= day, 1 =night. Based on an algorithm determination of the background rate, not on the actual position of the sun." ;
        		daynight_flag:coordinates = "../delta_time" ;
        		daynight_flag:flag_meanings = "day night" ;
        		daynight_flag:flag_values = 0UB, 1UB ;
        	ubyte decisionflags(delta_time, ds_4bytes) ;
        		decisionflags:long_name = "Decision Flags" ;
        		decisionflags:units = "counts" ;
        		decisionflags:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		decisionflags:contentType = "referenceInformation" ;
        		decisionflags:description = "ATLAS flight s/w Decision Flags associated with the major frame.  indication if there was an error or if no science data is sent and why" ;
        		decisionflags:coordinates = "../delta_time" ;
        	ubyte flywheel(delta_time) ;
        		flywheel:long_name = "Flywheel" ;
        		flywheel:units = "counts" ;
        		flywheel:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		flywheel:contentType = "referenceInformation" ;
        		flywheel:description = "ATLAS flight software Flywheel associated with the major frame." ;
        		flywheel:coordinates = "../delta_time" ;
        	ubyte signalflags(delta_time) ;
        		signalflags:long_name = "Signal Found Flags" ;
        		signalflags:units = "counts" ;
        		signalflags:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		signalflags:contentType = "referenceInformation" ;
        		signalflags:description = "ATLAS flight s/w signal event flags associated with the major frame." ;
        		signalflags:coordinates = "../delta_time" ;

        // group attributes:
        		:Description = "The PCE PMF Algorithm Science data group. Contains outputs from the onboard receiver algorithm software." ;
        		:data_rate = "Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)" ;
        } // group weak

      group: strong {
        variables:
        	ubyte alt_error_flags(delta_time, ds_2samples) ;
        		alt_error_flags:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		alt_error_flags:contentType = "referenceInformation" ;
        		alt_error_flags:description = "FSW error flags" ;
        		alt_error_flags:coordinates = "../delta_time" ;
        		alt_error_flags:long_name = "Error Flags" ;
        		alt_error_flags:units = "counts" ;
        	ubyte daynight_flag(delta_time) ;
        		daynight_flag:long_name = "Day/Night flag" ;
        		daynight_flag:units = "counts" ;
        		daynight_flag:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		daynight_flag:valid_min = 0UB ;
        		daynight_flag:valid_max = 1UB ;
        		daynight_flag:contentType = "referenceInformation" ;
        		daynight_flag:description = "ATLAS flight software Day/Night Flag associated with the major frame. 0= day, 1 =night. Based on an algorithm determination of the background rate, not on the actual position of the sun." ;
        		daynight_flag:coordinates = "../delta_time" ;
        		daynight_flag:flag_meanings = "day night" ;
        		daynight_flag:flag_values = 0UB, 1UB ;
        	ubyte decisionflags(delta_time, ds_4bytes) ;
        		decisionflags:long_name = "Decision Flags" ;
        		decisionflags:units = "counts" ;
        		decisionflags:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		decisionflags:contentType = "referenceInformation" ;
        		decisionflags:description = "ATLAS flight s/w Decision Flags associated with the major frame.  indication if there was an error or if no science data is sent and why" ;
        		decisionflags:coordinates = "../delta_time" ;
        	ubyte flywheel(delta_time) ;
        		flywheel:long_name = "Flywheel" ;
        		flywheel:units = "counts" ;
        		flywheel:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		flywheel:contentType = "referenceInformation" ;
        		flywheel:description = "ATLAS flight software Flywheel associated with the major frame." ;
        		flywheel:coordinates = "../delta_time" ;
        	ubyte signalflags(delta_time) ;
        		signalflags:long_name = "Signal Found Flags" ;
        		signalflags:units = "counts" ;
        		signalflags:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
        		signalflags:contentType = "referenceInformation" ;
        		signalflags:description = "ATLAS flight s/w signal event flags associated with the major frame." ;
        		signalflags:coordinates = "../delta_time" ;

        // group attributes:
        		:Description = "The PCE PMF Algorithm Science data group. Contains outputs from the onboard receiver algorithm software." ;
        		:data_rate = "Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)" ;
        } // group strong
      } // group algorithm_science

    group: altimetry {
      dimensions:
      	delta_time = UNLIMITED ; // (21150 currently)
      	ds_weak_channel_index = UNLIMITED ; // (4 currently)
      	ds_strong_channel_index = UNLIMITED ; // (16 currently)
      	ds_hist = UNLIMITED ; // (199 currently)
      variables:
      	float ds_hist(ds_hist) ;
      		ds_hist:long_name = "Histogram Dimension Scale" ;
      		ds_hist:units = "seconds" ;
      		ds_hist:source = "ATL02" ;
      		ds_hist:contentType = "referenceInformation" ;
      		ds_hist:description = "Relative bin values of windowed, peak-centered TOF histograms. Peak value = 0" ;
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via L1B ATBD" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	byte ds_strong_channel_index(ds_strong_channel_index) ;
      		ds_strong_channel_index:long_name = "DS for Strong Channels" ;
      		ds_strong_channel_index:units = "1" ;
      		ds_strong_channel_index:source = "Dimension Scale" ;
      		ds_strong_channel_index:valid_min = 1b ;
      		ds_strong_channel_index:valid_max = 16b ;
      		ds_strong_channel_index:contentType = "referenceInformation" ;
      		ds_strong_channel_index:description = "Dimension scale for strong channels." ;
      	byte ds_weak_channel_index(ds_weak_channel_index) ;
      		ds_weak_channel_index:long_name = "DS for Weak Channels" ;
      		ds_weak_channel_index:units = "1" ;
      		ds_weak_channel_index:source = "Dimension Scale" ;
      		ds_weak_channel_index:valid_min = 1b ;
      		ds_weak_channel_index:valid_max = 4b ;
      		ds_weak_channel_index:contentType = "referenceInformation" ;
      		ds_weak_channel_index:description = "Dimension scale for weak channels." ;
      	byte ch_mask_s(delta_time, ds_strong_channel_index) ;
      		ch_mask_s:long_name = "Channel Mask Strong" ;
      		ch_mask_s:units = "counts" ;
      		ch_mask_s:source = "ATL01/atlas/pcex/a_alt_science" ;
      		ch_mask_s:contentType = "referenceInformation" ;
      		ch_mask_s:description = "Channel Mask for DLBOs. The 16 flags are a logical OR of the two band offset masks for strong beam" ;
      		ch_mask_s:coordinates = "delta_time" ;
      	float cal_rise_sm(delta_time) ;
      		cal_rise_sm:long_name = "Altimetric Latest Calibration Rising" ;
      		cal_rise_sm:units = "seconds/cell" ;
      		cal_rise_sm:source = "Derived via L1B ATBD" ;
      		cal_rise_sm:contentType = "referenceInformation" ;
      		cal_rise_sm:description = "The smoothed, calibrated value for the rising edge used to convert cell counts to units of time.  time per cell count based on USO for each PCE." ;
      		cal_rise_sm:coordinates = "delta_time" ;
      	float cal_fall_sm(delta_time) ;
      		cal_fall_sm:long_name = "Altimetric Latest Calibration Falling" ;
      		cal_fall_sm:units = "seconds/cell" ;
      		cal_fall_sm:source = "Derived via L1B ATBD" ;
      		cal_fall_sm:contentType = "referenceInformation" ;
      		cal_fall_sm:description = "The smoothed, calibrated value for the falling edge used to convert cell counts to units of time.  time per cell count based on USO for each PCE." ;
      		cal_fall_sm:coordinates = "delta_time" ;
      	ubyte useflag(delta_time) ;
      		useflag:long_name = "Science Mode Flag" ;
      		useflag:units = "counts" ;
      		useflag:source = "ATL01/atlas/pcex/a_alt_sci/" ;
      		useflag:valid_min = 0UB ;
      		useflag:valid_max = 15UB ;
      		useflag:contentType = "referenceInformation" ;
      		useflag:description = "Science Mode Flag.  Used by ATL03 to discard non-science mode data. 0=stby, 1=science_mode, 2=test, 3=manual, 4=radio, 5=unknown, > 10=amcs_not_normal" ;
      		useflag:coordinates = "delta_time" ;
      		useflag:flag_meanings = "stby science test manual radio unknown unused unused unused unused stby_alt_amcs science_alt_amcs test_alt_amcs manual_alt_amcs radio_alt_amcs unknown_alt_amcs" ;
      		useflag:flag_values = 0UB, 1UB, 2UB, 3UB, 4UB, 5UB, 6UB, 7UB, 8UB, 9UB, 10UB, 11UB, 12UB, 13UB, 14UB, 15UB ;
      	uint pce_mframe_cnt(delta_time) ;
      		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
      		pce_mframe_cnt:units = "counts" ;
      		pce_mframe_cnt:source = "ATL02" ;
      		pce_mframe_cnt:contentType = "referenceInformation" ;
      		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over. It is in the first time tag science packet. Used as part of the photon ID" ;
      		pce_mframe_cnt:coordinates = "delta_time" ;
      	byte n_bands(delta_time) ;
      		n_bands:long_name = "Number Downlink Bands" ;
      		n_bands:units = "counts" ;
      		n_bands:source = "ATL01/atlas/pcex/a_alt_science" ;
      		n_bands:contentType = "referenceInformation" ;
      		n_bands:description = "Number of bands (in addition to the nominal 1 band) selected for downlink." ;
      		n_bands:coordinates = "delta_time" ;
      	byte ch_mask_w(delta_time, ds_weak_channel_index) ;
      		ch_mask_w:long_name = "Channel Mask Weak" ;
      		ch_mask_w:units = "counts" ;
      		ch_mask_w:source = "ATL01/atlas/pcex/a_alt_science" ;
      		ch_mask_w:contentType = "referenceInformation" ;
      		ch_mask_w:description = "Channel Mask for DLBOs. The 4 flags are a logical OR of the two band offset masks for weak beam" ;
      		ch_mask_w:coordinates = "delta_time" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time\nds_weak_channel_index\nds_strong_channel_index\nds_hist" ;
      		:Description = "The PCE Altimetry Science Packet data common to both beams (PCEx_ALT_SCI_TLM_MID in APID 1254, 1264, 1274 sequence flag 01 (once per major frame). (see ICESat-2-MEB-SPEC-0875, section 5.12, Spacewire: Major Frame Packet Data Format" ;
      		:data_rate = "Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)" ;

      group: weak {
        variables:
        	float band2_width(delta_time) ;
        		band2_width:long_name = "Band2 Width" ;
        		band2_width:units = "seconds" ;
        		band2_width:source = "L1A ATBD" ;
        		band2_width:contentType = "physicalMeasurement" ;
        		band2_width:description = "Width of downlink band2." ;
        		band2_width:coordinates = "../delta_time" ;
        	float band1_offset(delta_time) ;
        		band1_offset:long_name = "Band1 Offset" ;
        		band1_offset:source = "L1A ATBD" ;
        		band1_offset:contentType = "physicalMeasurement" ;
        		band1_offset:description = "Downlink band offset (DLBO) for band1." ;
        		band1_offset:coordinates = "../delta_time" ;
        		band1_offset:units = "seconds" ;
        	float band1_width(delta_time) ;
        		band1_width:long_name = "Band1 Width" ;
        		band1_width:source = "L1A ATBD" ;
        		band1_width:contentType = "physicalMeasurement" ;
        		band1_width:description = "Width of downlink band1." ;
        		band1_width:coordinates = "../delta_time" ;
        		band1_width:units = "seconds" ;
        	float alt_rw_width(delta_time) ;
        		alt_rw_width:long_name = "Altimetric Range Window Width" ;
        		alt_rw_width:units = "seconds" ;
        		alt_rw_width:source = "ATL01/atlas/pcex/a_pmf_algorithm_science and L1B ATBD conversion" ;
        		alt_rw_width:contentType = "referenceInformation" ;
        		alt_rw_width:description = "The number of seconds from the range window start and range window stop" ;
        		alt_rw_width:coordinates = "../delta_time" ;
        	int hist(delta_time, ds_hist) ;
        		hist:long_name = "Center-aligned TOF Histogram" ;
        		hist:units = "counts" ;
        		hist:source = "ATL02" ;
        		hist:contentType = "qualityInformation" ;
        		hist:description = "Per-major frame, peak-aligned, windowed time-of-flight histograms.  " ;
        		hist:coordinates = "../ds_hist ../delta_time" ;
        	float alt_rw_start(delta_time) ;
        		alt_rw_start:long_name = "Altimetric Range Window Start" ;
        		alt_rw_start:units = "seconds" ;
        		alt_rw_start:source = "ATL01/atlas/pcex/a_pmf_algorithm_science and L1B ATBD conversion" ;
        		alt_rw_start:contentType = "referenceInformation" ;
        		alt_rw_start:description = "The number of seconds between the transmit pulse and the start of the altimetric range window for the beam" ;
        		alt_rw_start:coordinates = "../delta_time" ;
        	float band2_offset(delta_time) ;
        		band2_offset:long_name = "Band2 Offset" ;
        		band2_offset:units = "seconds" ;
        		band2_offset:source = "L1A ATBD" ;
        		band2_offset:contentType = "physicalMeasurement" ;
        		band2_offset:description = "Downlink band offset (DLBO) for band2." ;
        		band2_offset:coordinates = "../delta_time" ;
        	int n_mf_ph(delta_time) ;
        		n_mf_ph:long_name = "Number of photons" ;
        		n_mf_ph:units = "counts" ;
        		n_mf_ph:source = "Derived" ;
        		n_mf_ph:contentType = "auxiliaryInformation" ;
        		n_mf_ph:description = "Number of photons within each major frame." ;
        		n_mf_ph:coordinates = "../delta_time" ;
        	int64 ph_ndx_beg(delta_time) ;
        		ph_ndx_beg:long_name = "Photon Index Begin" ;
        		ph_ndx_beg:units = "counts" ;
        		ph_ndx_beg:source = "Derived" ;
        		ph_ndx_beg:contentType = "auxiliaryInformation" ;
        		ph_ndx_beg:description = "Index (1-based) within the photon-rate data of the first photon within each major frame." ;
        		ph_ndx_beg:coordinates = "../delta_time" ;

        // group attributes:
        		:Description = "The PCE Altimetry Science Packet specific to  a beam (PCEx_ALT_SCI_TLM_MID in APID 1254, 1264, 1274 sequence flag 01 (once per major frame). (see ICESat-2-MEB-SPEC-0875, section 5.12, Spacewire: Major Frame Packet Data Format" ;
        		:data_rate = "Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)" ;

        group: photons {
          dimensions:
          	delta_time = UNLIMITED ; // (6922635 currently)
          variables:
          	double delta_time(delta_time) ;
          		delta_time:long_name = "Elapsed GPS seconds" ;
          		delta_time:standard_name = "time" ;
          		delta_time:units = "seconds since 2018-01-01" ;
          		delta_time:source = "Derived via L1B ATBD" ;
          		delta_time:contentType = "referenceInformation" ;
          		delta_time:description = "The Time of Day for the specific Transmit (TX) pulse associated with the Received (RX) event. (see L1B ATBD section 5 time of flight), relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
          	ubyte ph_id_count(delta_time) ;
          		ph_id_count:long_name = "photon event counter" ;
          		ph_id_count:units = "counts" ;
          		ph_id_count:source = "Derived as part of Photon ID" ;
          		ph_id_count:contentType = "referenceInformation" ;
          		ph_id_count:description = "photon event counter is part of photon ID and will count from 1 for each channel until reset by laser pulse counter. If ph_id_count is 0, then there was a transmit pulse without any received photons. In this case, the transmit portion of the alt_science packet is valid, but the receive portion is all 0s and should not be used." ;
          		ph_id_count:coordinates = "delta_time" ;
          	double ph_tof(delta_time) ;
          		ph_tof:long_name = "Time of Flight" ;
          		ph_tof:source = "ATL02 ATBD" ;
          		ph_tof:contentType = "physicalMeasurement" ;
          		ph_tof:description = "Time of flight (TOF);  the round trip time in seconds of the received photon relative to the beam\'s zero range point (ZRP). Computed from the Transmit (Tx) and Receive (Rx) Time-of-flight components and then calibrated to the centroid of the transmit pulse." ;
          		ph_tof:coordinates = "delta_time" ;
          		ph_tof:units = "seconds" ;
          	float tx_other_tof(delta_time) ;
          		tx_other_tof:long_name = "Other Transmit Time from LL" ;
          		tx_other_tof:units = "seconds" ;
          		tx_other_tof:source = "ATL01/atlas/pcex/a_alt_science_ph TX data L1B ATBD section tof" ;
          		tx_other_tof:contentType = "referenceInformation" ;
          		tx_other_tof:description = "Time of flight from the PCE-specific leading-lower (LL) threshold (tx_ll_tof) to the detected other transmit pulse edge. For PCE1, this is the time from the PCE1 LL to the Transmit Leading Upper edge (LU) threshold; for PCE2, this is the time from the PCE2 LL to the Transmit Trailing Upper edge (TU) threshold; and for PCE3, this is the time from the PCE3 LL to the Transmit Trailing Lower edge (TL) threshold." ;
          		tx_other_tof:coordinates = "delta_time" ;
          	ubyte ph_id_pulse(delta_time) ;
          		ph_id_pulse:long_name = "laser pulse counter" ;
          		ph_id_pulse:units = "counts" ;
          		ph_id_pulse:source = "Derived as part of Photon ID" ;
          		ph_id_pulse:contentType = "referenceInformation" ;
          		ph_id_pulse:description = "laser pulse counter is part of photon ID and will count from 1 to 200 and reset for each new major frame (major_fram_id). If the corresponding ph_id_count is 0, then there was a transmit pulse without any received photons." ;
          		ph_id_pulse:coordinates = "delta_time" ;
          	byte rx_band_id(delta_time) ;
          		rx_band_id:long_name = "rx downlink band id" ;
          		rx_band_id:units = "counts" ;
          		rx_band_id:source = "ATL01/atlas/pcex/a_alt_science_ph RX data" ;
          		rx_band_id:valid_min = 0b ;
          		rx_band_id:valid_max = 1b ;
          		rx_band_id:contentType = "referenceInformation" ;
          		rx_band_id:description = "Flag to indicate downlink band id associated with the received rx_tof (received photon event). A value of 0 indicates the photon corresponds to band1; A value of 1 indicates the photon corresponds to band2. Corresponding parameters are band_width, band_offset and band_eventcount." ;
          		rx_band_id:coordinates = "delta_time" ;
          		rx_band_id:flag_meanings = "band1 band2" ;
          		rx_band_id:flag_values = 0b, 1b ;
          	ubyte ph_id_channel(delta_time) ;
          		ph_id_channel:long_name = "Receive channel id" ;
          		ph_id_channel:units = "1" ;
          		ph_id_channel:source = "Derived as part of Photon ID" ;
          		ph_id_channel:valid_min = 1UB ;
          		ph_id_channel:valid_max = 120UB ;
          		ph_id_channel:contentType = "referenceInformation" ;
          		ph_id_channel:description = "Channel number assigned for each received photon event. This is part of the photon ID. Values range from 1 to 120 to span all channels and rise/fall edges. Values 1 to 60 are for falling edge; PCE1 (1 to 20), PCE 2 (21 to 40) and PCE3 (41 to 60). Values 61 to 120 are for rising edge; PCE1 (61 to 80), PCE 2 (81 to 100) and PC3 (101 to 120)." ;
          		ph_id_channel:coordinates = "delta_time" ;
          	float tx_ll_tof(delta_time) ;
          		tx_ll_tof:long_name = "Transmit LL time from T0" ;
          		tx_ll_tof:units = "seconds" ;
          		tx_ll_tof:source = "ATL01/atlas/pcex/a_alt_science_ph TX data L1B ATBD section tof" ;
          		tx_ll_tof:contentType = "referenceInformation" ;
          		tx_ll_tof:description = "Transmit (Tx) Leading Lower (LL) time of flight (TOF); the round trip time in seconds from the detected lower leading edge of the transmit pulse relative to the ATLAS T0. Includes all calibrations of coarse and fine counts." ;
          		tx_ll_tof:coordinates = "delta_time" ;
          	byte tof_flag(delta_time) ;
          		tof_flag:long_name = "TOF Flag" ;
          		tof_flag:units = "counts" ;
          		tof_flag:source = "L1B ATBD Sect 2.5.4" ;
          		tof_flag:valid_min = 1b ;
          		tof_flag:valid_max = 18b ;
          		tof_flag:contentType = "referenceInformation" ;
          		tof_flag:description = "Time Of Flight center correction flag. Values indicate what components were used to adjust the TOF to the centroid of the Tx pulse, based on the alignment of Tx components across all 3 PCEs. 1=LL_LU_TU_TL; 2=LL_TU_TL; 3=LL_LU_TL; 4=LL_LU_TU; 5=LL_TL; 6=LL_TU; 7=LL_LU; 8=LL. Values greater than 10 indicate the same sequence of conditions indicated for a potential TEP photon." ;
          		tof_flag:coordinates = "delta_time" ;
          		tof_flag:flag_meanings = "LL_LU_TU_TL LL_TU_TL LL_LU_TL LL_LU_TU LL_TL LL_TU LL_LU LL TEP_LL_LU_TU_TL TEP_LL_TU_TL TEP_LL_LU_TL TEP_LL_LU_TU TEP_LL_TL TEP_LL_TU TEP_LL_LU TEP_LL" ;
          		tof_flag:flag_values = 1b, 2b, 3b, 4b, 5b, 6b, 7b, 8b, 11b, 12b, 13b, 14b, 15b, 16b, 17b, 18b ;
          	uint pce_mframe_cnt(delta_time) ;
          		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
          		pce_mframe_cnt:units = "counts" ;
          		pce_mframe_cnt:source = "Retained from latest a_alt_science packet" ;
          		pce_mframe_cnt:contentType = "referenceInformation" ;
          		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over. It is in the first time tag science packet. Used as part of the photon ID" ;
          		pce_mframe_cnt:coordinates = "delta_time" ;

          // group attributes:
          		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
          		:Description = "Group contains the PCE Altimetric received photon event (ph) decommutated data and its matching Transmit time tag data. Note the Transmit time tag data are repeated for each received photon event. Data is from Altimetry Science Packet (alt_sci_tlm) APID 1254, 1264, 1274 with Sequence Flag = 0 or 2. See ICESat-2-MEB-SPEC-0875, section 5.12, SPACEWIRE: TIME TAG SCIENCE DATA FORMAT" ;
          		:data_rate = "Data within this group are stored at the data rate of the source photon events. (varies by detection; nominal value is sixty thousand per second, derived from laser_rate * photons_per_shot * beams_per_pce; where laser_rate=10000, photons_per_shot=3, beams_per_pce=2.)" ;
          } // group photons
        } // group weak

      group: strong {
        variables:
        	float band2_width(delta_time) ;
        		band2_width:long_name = "Band2 Width" ;
        		band2_width:units = "seconds" ;
        		band2_width:source = "L1A ATBD" ;
        		band2_width:contentType = "physicalMeasurement" ;
        		band2_width:description = "Width of downlink band2." ;
        		band2_width:coordinates = "../delta_time" ;
        	float band1_offset(delta_time) ;
        		band1_offset:long_name = "Band1 Offset" ;
        		band1_offset:source = "L1A ATBD" ;
        		band1_offset:contentType = "physicalMeasurement" ;
        		band1_offset:description = "Downlink band offset (DLBO) for band1." ;
        		band1_offset:coordinates = "../delta_time" ;
        		band1_offset:units = "seconds" ;
        	float band1_width(delta_time) ;
        		band1_width:long_name = "Band1 Width" ;
        		band1_width:source = "L1A ATBD" ;
        		band1_width:contentType = "physicalMeasurement" ;
        		band1_width:description = "Width of downlink band1." ;
        		band1_width:coordinates = "../delta_time" ;
        		band1_width:units = "seconds" ;
        	float alt_rw_width(delta_time) ;
        		alt_rw_width:long_name = "Altimetric Range Window Width" ;
        		alt_rw_width:units = "seconds" ;
        		alt_rw_width:source = "ATL01/atlas/pcex/a_pmf_algorithm_science and L1B ATBD conversion" ;
        		alt_rw_width:contentType = "referenceInformation" ;
        		alt_rw_width:description = "The number of seconds from the range window start and range window stop" ;
        		alt_rw_width:coordinates = "../delta_time" ;
        	int hist(delta_time, ds_hist) ;
        		hist:long_name = "Center-aligned TOF Histogram" ;
        		hist:units = "counts" ;
        		hist:source = "ATL02" ;
        		hist:contentType = "qualityInformation" ;
        		hist:description = "Per-major frame, peak-aligned, windowed time-of-flight histograms.  " ;
        		hist:coordinates = "../ds_hist ../delta_time" ;
        	float alt_rw_start(delta_time) ;
        		alt_rw_start:long_name = "Altimetric Range Window Start" ;
        		alt_rw_start:units = "seconds" ;
        		alt_rw_start:source = "ATL01/atlas/pcex/a_pmf_algorithm_science and L1B ATBD conversion" ;
        		alt_rw_start:contentType = "referenceInformation" ;
        		alt_rw_start:description = "The number of seconds between the transmit pulse and the start of the altimetric range window for the beam" ;
        		alt_rw_start:coordinates = "../delta_time" ;
        	float band2_offset(delta_time) ;
        		band2_offset:long_name = "Band2 Offset" ;
        		band2_offset:units = "seconds" ;
        		band2_offset:source = "L1A ATBD" ;
        		band2_offset:contentType = "physicalMeasurement" ;
        		band2_offset:description = "Downlink band offset (DLBO) for band2." ;
        		band2_offset:coordinates = "../delta_time" ;
        	int n_mf_ph(delta_time) ;
        		n_mf_ph:long_name = "Number of photons" ;
        		n_mf_ph:units = "counts" ;
        		n_mf_ph:source = "Derived" ;
        		n_mf_ph:contentType = "auxiliaryInformation" ;
        		n_mf_ph:description = "Number of photons within each major frame." ;
        		n_mf_ph:coordinates = "../delta_time" ;
        	int64 ph_ndx_beg(delta_time) ;
        		ph_ndx_beg:long_name = "Photon Index Begin" ;
        		ph_ndx_beg:units = "counts" ;
        		ph_ndx_beg:source = "Derived" ;
        		ph_ndx_beg:contentType = "auxiliaryInformation" ;
        		ph_ndx_beg:description = "Index (1-based) within the photon-rate data of the first photon within each major frame." ;
        		ph_ndx_beg:coordinates = "../delta_time" ;

        // group attributes:
        		:Description = "The PCE Altimetry Science Packet specific to  a beam (PCEx_ALT_SCI_TLM_MID in APID 1254, 1264, 1274 sequence flag 01 (once per major frame). (see ICESat-2-MEB-SPEC-0875, section 5.12, Spacewire: Major Frame Packet Data Format" ;
        		:data_rate = "Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)" ;

        group: photons {
          dimensions:
          	delta_time = UNLIMITED ; // (11252817 currently)
          variables:
          	double delta_time(delta_time) ;
          		delta_time:long_name = "Elapsed GPS seconds" ;
          		delta_time:standard_name = "time" ;
          		delta_time:units = "seconds since 2018-01-01" ;
          		delta_time:source = "Derived via L1B ATBD" ;
          		delta_time:contentType = "referenceInformation" ;
          		delta_time:description = "The Time of Day for the specific Transmit (TX) pulse associated with the Received (RX) event. (see L1B ATBD section 5 time of flight), relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
          	ubyte ph_id_count(delta_time) ;
          		ph_id_count:long_name = "photon event counter" ;
          		ph_id_count:units = "counts" ;
          		ph_id_count:source = "Derived as part of Photon ID" ;
          		ph_id_count:contentType = "referenceInformation" ;
          		ph_id_count:description = "photon event counter is part of photon ID and will count from 1 for each channel until reset by laser pulse counter. If ph_id_count is 0, then there was a transmit pulse without any received photons. In this case, the transmit portion of the alt_science packet is valid, but the receive portion is all 0s and should not be used." ;
          		ph_id_count:coordinates = "delta_time" ;
          	double ph_tof(delta_time) ;
          		ph_tof:long_name = "Time of Flight" ;
          		ph_tof:source = "ATL02 ATBD" ;
          		ph_tof:contentType = "physicalMeasurement" ;
          		ph_tof:description = "Time of flight (TOF);  the round trip time in seconds of the received photon relative to the beam\'s zero range point (ZRP). Computed from the Transmit (Tx) and Receive (Rx) Time-of-flight components and then calibrated to the centroid of the transmit pulse." ;
          		ph_tof:coordinates = "delta_time" ;
          		ph_tof:units = "seconds" ;
          	float tx_other_tof(delta_time) ;
          		tx_other_tof:long_name = "Other Transmit Time from LL" ;
          		tx_other_tof:units = "seconds" ;
          		tx_other_tof:source = "ATL01/atlas/pcex/a_alt_science_ph TX data L1B ATBD section tof" ;
          		tx_other_tof:contentType = "referenceInformation" ;
          		tx_other_tof:description = "Time of flight from the PCE-specific leading-lower (LL) threshold (tx_ll_tof) to the detected other transmit pulse edge. For PCE1, this is the time from the PCE1 LL to the Transmit Leading Upper edge (LU) threshold; for PCE2, this is the time from the PCE2 LL to the Transmit Trailing Upper edge (TU) threshold; and for PCE3, this is the time from the PCE3 LL to the Transmit Trailing Lower edge (TL) threshold." ;
          		tx_other_tof:coordinates = "delta_time" ;
          	ubyte ph_id_pulse(delta_time) ;
          		ph_id_pulse:long_name = "laser pulse counter" ;
          		ph_id_pulse:units = "counts" ;
          		ph_id_pulse:source = "Derived as part of Photon ID" ;
          		ph_id_pulse:contentType = "referenceInformation" ;
          		ph_id_pulse:description = "laser pulse counter is part of photon ID and will count from 1 to 200 and reset for each new major frame (major_fram_id). If the corresponding ph_id_count is 0, then there was a transmit pulse without any received photons." ;
          		ph_id_pulse:coordinates = "delta_time" ;
          	byte rx_band_id(delta_time) ;
          		rx_band_id:long_name = "rx downlink band id" ;
          		rx_band_id:units = "counts" ;
          		rx_band_id:source = "ATL01/atlas/pcex/a_alt_science_ph RX data" ;
          		rx_band_id:valid_min = 0b ;
          		rx_band_id:valid_max = 1b ;
          		rx_band_id:contentType = "referenceInformation" ;
          		rx_band_id:description = "Flag to indicate downlink band id associated with the received rx_tof (received photon event). A value of 0 indicates the photon corresponds to band1; A value of 1 indicates the photon corresponds to band2. Corresponding parameters are band_width, band_offset and band_eventcount." ;
          		rx_band_id:coordinates = "delta_time" ;
          		rx_band_id:flag_meanings = "band1 band2" ;
          		rx_band_id:flag_values = 0b, 1b ;
          	ubyte ph_id_channel(delta_time) ;
          		ph_id_channel:long_name = "Receive channel id" ;
          		ph_id_channel:units = "1" ;
          		ph_id_channel:source = "Derived as part of Photon ID" ;
          		ph_id_channel:valid_min = 1UB ;
          		ph_id_channel:valid_max = 120UB ;
          		ph_id_channel:contentType = "referenceInformation" ;
          		ph_id_channel:description = "Channel number assigned for each received photon event. This is part of the photon ID. Values range from 1 to 120 to span all channels and rise/fall edges. Values 1 to 60 are for falling edge; PCE1 (1 to 20), PCE 2 (21 to 40) and PCE3 (41 to 60). Values 61 to 120 are for rising edge; PCE1 (61 to 80), PCE 2 (81 to 100) and PC3 (101 to 120)." ;
          		ph_id_channel:coordinates = "delta_time" ;
          	float tx_ll_tof(delta_time) ;
          		tx_ll_tof:long_name = "Transmit LL time from T0" ;
          		tx_ll_tof:units = "seconds" ;
          		tx_ll_tof:source = "ATL01/atlas/pcex/a_alt_science_ph TX data L1B ATBD section tof" ;
          		tx_ll_tof:contentType = "referenceInformation" ;
          		tx_ll_tof:description = "Transmit (Tx) Leading Lower (LL) time of flight (TOF); the round trip time in seconds from the detected lower leading edge of the transmit pulse relative to the ATLAS T0. Includes all calibrations of coarse and fine counts." ;
          		tx_ll_tof:coordinates = "delta_time" ;
          	byte tof_flag(delta_time) ;
          		tof_flag:long_name = "TOF Flag" ;
          		tof_flag:units = "counts" ;
          		tof_flag:source = "L1B ATBD Sect 2.5.4" ;
          		tof_flag:valid_min = 1b ;
          		tof_flag:valid_max = 18b ;
          		tof_flag:contentType = "referenceInformation" ;
          		tof_flag:description = "Time Of Flight center correction flag. Values indicate what components were used to adjust the TOF to the centroid of the Tx pulse, based on the alignment of Tx components across all 3 PCEs. 1=LL_LU_TU_TL; 2=LL_TU_TL; 3=LL_LU_TL; 4=LL_LU_TU; 5=LL_TL; 6=LL_TU; 7=LL_LU; 8=LL. Values greater than 10 indicate the same sequence of conditions indicated for a potential TEP photon." ;
          		tof_flag:coordinates = "delta_time" ;
          		tof_flag:flag_meanings = "LL_LU_TU_TL LL_TU_TL LL_LU_TL LL_LU_TU LL_TL LL_TU LL_LU LL TEP_LL_LU_TU_TL TEP_LL_TU_TL TEP_LL_LU_TL TEP_LL_LU_TU TEP_LL_TL TEP_LL_TU TEP_LL_LU TEP_LL" ;
          		tof_flag:flag_values = 1b, 2b, 3b, 4b, 5b, 6b, 7b, 8b, 11b, 12b, 13b, 14b, 15b, 16b, 17b, 18b ;
          	uint pce_mframe_cnt(delta_time) ;
          		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
          		pce_mframe_cnt:units = "counts" ;
          		pce_mframe_cnt:source = "Retained from latest a_alt_science packet" ;
          		pce_mframe_cnt:contentType = "referenceInformation" ;
          		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over. It is in the first time tag science packet. Used as part of the photon ID" ;
          		pce_mframe_cnt:coordinates = "delta_time" ;

          // group attributes:
          		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
          		:Description = "Group contains the PCE Altimetric received photon event (ph) decommutated data and its matching Transmit time tag data. Note the Transmit time tag data are repeated for each received photon event. Data is from Altimetry Science Packet (alt_sci_tlm) APID 1254, 1264, 1274 with Sequence Flag = 0 or 2. See ICESat-2-MEB-SPEC-0875, section 5.12, SPACEWIRE: TIME TAG SCIENCE DATA FORMAT" ;
          		:data_rate = "Data within this group are stored at the data rate of the source photon events. (varies by detection; nominal value is sixty thousand per second, derived from laser_rate * photons_per_shot * beams_per_pce; where laser_rate=10000, photons_per_shot=3, beams_per_pce=2.)" ;
          } // group photons
        } // group strong
      } // group altimetry

    group: atmosphere_s {
      dimensions:
      	delta_time = UNLIMITED ; // (10575 currently)
      	ds_hist_bin_index = UNLIMITED ; // (467 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via L1B ATBD" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "The time of the first TX pulse in major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	short ds_hist_bin_index(ds_hist_bin_index) ;
      		ds_hist_bin_index:long_name = "DS for ATM histogram bins" ;
      		ds_hist_bin_index:units = "1" ;
      		ds_hist_bin_index:source = "Dimension Scale" ;
      		ds_hist_bin_index:valid_min = 1s ;
      		ds_hist_bin_index:valid_max = 467s ;
      		ds_hist_bin_index:contentType = "referenceInformation" ;
      		ds_hist_bin_index:description = "Dimension scale for atmosphere histogram bins." ;
      	short atm_shift_amount(delta_time) ;
      		atm_shift_amount:units = "counts" ;
      		atm_shift_amount:long_name = "Atmospheric Range Window Shift" ;
      		atm_shift_amount:source = "ATL01/atlas/pcex/a_atm_hist_x and L1B ATBD section ATM" ;
      		atm_shift_amount:contentType = "referenceInformation" ;
      		atm_shift_amount:description = "The number of bins the range window start of one of the histograms was shifted to align them before they are added together." ;
      		atm_shift_amount:coordinates = "delta_time" ;
      	float atm_rw_start(delta_time) ;
      		atm_rw_start:long_name = "Atmospheric Range Window Start" ;
      		atm_rw_start:units = "seconds" ;
      		atm_rw_start:source = "ATL01/atlas/pcex/a_atm_hist_x and L1B ATBD section ATM" ;
      		atm_rw_start:contentType = "referenceInformation" ;
      		atm_rw_start:description = "The number of seconds between the transmit pulse and the start of the Atmospheric range window" ;
      		atm_rw_start:coordinates = "delta_time" ;
      	float atm_rw_width(delta_time) ;
      		atm_rw_width:long_name = "Atmospheric Range Window Width" ;
      		atm_rw_width:units = "seconds" ;
      		atm_rw_width:source = "ATL01/atlas/pcex/a_atm_hist_x and L1B ATBD section ATM" ;
      		atm_rw_width:contentType = "referenceInformation" ;
      		atm_rw_width:description = "The number of seconds from the Atmospheric range window start and range window stop." ;
      		atm_rw_width:coordinates = "delta_time" ;
      	uint pce_mframe_cnt(delta_time) ;
      		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
      		pce_mframe_cnt:units = "counts" ;
      		pce_mframe_cnt:source = "ATL01/atlas/pcex/a_atm_hist_x" ;
      		pce_mframe_cnt:contentType = "referenceInformation" ;
      		pce_mframe_cnt:description = "Major Frame Counter - The  major frame counter is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over. It is in the first time tag science packet. Used as part of the photon ID" ;
      		pce_mframe_cnt:coordinates = "delta_time" ;
      	ushort atm_bins(delta_time, ds_hist_bin_index) ;
      		atm_bins:long_name = "Atmospheric Science Histogram" ;
      		atm_bins:units = "counts" ;
      		atm_bins:source = "ATL01/atlas/pcex/a_atm_hist_x" ;
      		atm_bins:contentType = "referenceInformation" ;
      		atm_bins:description = "The histogram bins for the Atmospheric beam.Once every 400 shots ( laser pulses). Bin 1 (clouds) is nearest to spacecraft .Bin 467 is under ground." ;
      		atm_bins:coordinates = "delta_time" ;
      	ubyte useflag(delta_time) ;
      		useflag:long_name = "Science Mode Flag" ;
      		useflag:units = "counts" ;
      		useflag:source = "ATL01/atlas/pcex/a_alt_sci/" ;
      		useflag:valid_min = 0UB ;
      		useflag:valid_max = 15UB ;
      		useflag:contentType = "referenceInformation" ;
      		useflag:description = "Science Mode Flag.  Used by ATL03 to discard non-science mode data. 0=stby, 1=science_mode, 2=test, 3=manual, 4=radio, 5=unknown, > 10=amcs_not_normal" ;
      		useflag:coordinates = "delta_time" ;
      		useflag:flag_meanings = "stby science test manual radio unknown unused unused unused unused stby_alt_amcs science_alt_amcs test_alt_amcs manual_alt_amcs radio_alt_amcs unknown_alt_amcs" ;
      		useflag:flag_values = 0UB, 1UB, 2UB, 3UB, 4UB, 5UB, 6UB, 7UB, 8UB, 9UB, 10UB, 11UB, 12UB, 13UB, 14UB, 15UB ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time\nds_hist_bin_index" ;
      		:Description = "Contains parameters relating to the PCE Atmospheric Data Histograms. Normally 25 hz. (APID 1255, 1259, 1265, 1269, 1275, 1279). P1 S,P1 W, P2 S, P2 W, P3 S, P3 W." ;
      		:data_rate = "Data in this group is stored at a 25hz (25 per second) rate." ;
      } // group atmosphere_s

    group: pmf_hk {
      dimensions:
      	delta_time = UNLIMITED ; // (423 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	ushort autorestartdfccount(delta_time) ;
      		autorestartdfccount:long_name = "AutoRestartDFCCount" ;
      		autorestartdfccount:units = "counts" ;
      		autorestartdfccount:source = "APID 1073, 1089, 1105 Byte 0090-0091" ;
      		autorestartdfccount:contentType = "referenceInformation" ;
      		autorestartdfccount:description = "Number of DFC Auto Restarts" ;
      		autorestartdfccount:coordinates = "delta_time" ;
      	ubyte cmd_err_cntr(delta_time) ;
      		cmd_err_cntr:long_name = "cmd_err_cntr" ;
      		cmd_err_cntr:units = "counts" ;
      		cmd_err_cntr:source = "APID 1073, 1089, 1105 Byte 0012-0012" ;
      		cmd_err_cntr:contentType = "referenceInformation" ;
      		cmd_err_cntr:description = "Command error counter" ;
      		cmd_err_cntr:coordinates = "delta_time" ;
      	ubyte cmd_suc_cntr(delta_time) ;
      		cmd_suc_cntr:long_name = "cmd_suc_cntr" ;
      		cmd_suc_cntr:units = "counts" ;
      		cmd_suc_cntr:source = "APID 1073, 1089, 1105 Byte 0013-0013" ;
      		cmd_suc_cntr:contentType = "referenceInformation" ;
      		cmd_suc_cntr:description = "Command success counter." ;
      		cmd_suc_cntr:coordinates = "delta_time" ;
      	ubyte activeknobstable(delta_time) ;
      		activeknobstable:long_name = "ActiveKnobsTable" ;
      		activeknobstable:units = "counts" ;
      		activeknobstable:source = "APID 1073, 1089, 1105 Byte 0037-0037" ;
      		activeknobstable:contentType = "referenceInformation" ;
      		activeknobstable:description = "The active knobs table." ;
      		activeknobstable:coordinates = "delta_time" ;
      	ubyte mode(delta_time) ;
      		mode:long_name = "Mode" ;
      		mode:units = "counts" ;
      		mode:source = "APID 1073, 1089, 1105 Byte 0036-0036" ;
      		mode:valid_min = 0UB ;
      		mode:valid_max = 5UB ;
      		mode:contentType = "referenceInformation" ;
      		mode:description = "PCE Mode. 0=STBY; 1=Science; 2=Test; 3=Manual; 4=Radio; 5=Unknown" ;
      		mode:coordinates = "delta_time" ;
      		mode:flag_meanings = "STBY Science Test Manual Radio Test" ;
      		mode:flag_values = 0UB, 1UB, 2UB, 3UB, 4UB, 5UB ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
      		:Description = "PCE Diagnostic Telemetry Packet from one of the following APIDs : 1073, 1089, 1105 (each APID is associated with a specific PCE). Packet Frequency is 1 Hertz." ;
      } // group pmf_hk

    group: sxp_ssr_w {
      dimensions:
      	delta_time = UNLIMITED ; // (423 currently)
      	ds_50samples = UNLIMITED ; // (50 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via L1B ATBD" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "The time of the first TX pulse in the major frame, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	byte ds_50samples(ds_50samples) ;
      		ds_50samples:long_name = "DS for 50 bytes" ;
      		ds_50samples:units = "1" ;
      		ds_50samples:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		ds_50samples:valid_min = 1b ;
      		ds_50samples:valid_max = 50b ;
      		ds_50samples:contentType = "referenceInformation" ;
      		ds_50samples:description = "Dimension scale for an array of 50 samples." ;
      		ds_50samples:coordinates = "delta_time latitude longitude" ;
      	double latitude(delta_time, ds_50samples) ;
      		latitude:long_name = "latitude" ;
      		latitude:units = "degrees" ;
      		latitude:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		latitude:contentType = "referenceInformation" ;
      		latitude:description = "Latitude" ;
      		latitude:coordinates = "delta_time" ;
      	double longitude(delta_time, ds_50samples) ;
      		longitude:long_name = "longitude" ;
      		longitude:units = "degrees" ;
      		longitude:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		longitude:contentType = "referenceInformation" ;
      		longitude:description = "Longitude" ;
      		longitude:coordinates = "delta_time" ;
      	double mf_cosz(delta_time) ;
      		mf_cosz:long_name = "First Major Frame cosZ" ;
      		mf_cosz:units = "counts" ;
      		mf_cosz:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		mf_cosz:contentType = "referenceInformation" ;
      		mf_cosz:description = "Cosine of the solar zenith angle" ;
      		mf_cosz:coordinates = "delta_time latitude longitude" ;
      	uint pce_mframe_cnt(delta_time) ;
      		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
      		pce_mframe_cnt:units = "counts" ;
      		pce_mframe_cnt:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		pce_mframe_cnt:contentType = "referenceInformation" ;
      		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over." ;
      		pce_mframe_cnt:coordinates = "delta_time latitude longitude" ;
      	double cosb(delta_time, ds_50samples) ;
      		cosb:long_name = "cosB" ;
      		cosb:units = "counts" ;
      		cosb:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		cosb:contentType = "referenceInformation" ;
      		cosb:description = "Cosine of the off-nadir angle as calculated onboard from the spacecraft information" ;
      		cosb:coordinates = "delta_time latitude longitude" ;
      	ubyte srm(delta_time, ds_50samples) ;
      		srm:long_name = "srm" ;
      		srm:units = "1" ;
      		srm:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		srm:contentType = "referenceInformation" ;
      		srm:description = "Surface type, vegetation and coastline information from the SRM. (bit 0-1 = surface type (0=ocean, 1=land, 2=sea ice, 3=land ice). Bit 2 = vegetation present, Bit 3 = coastline present)" ;
      		srm:coordinates = "delta_time latitude longitude" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time\nds_50samples" ;
      		:Description = "SBC Extrapolation Task telemetry containing Flight Science Receiver Algorithm team requested telemetry for the first set of PCE extrapolation data for a major frame.: lat, long, range, nadir angle, etc. (from APIDs 1152 thru 1157)" ;
      } // group sxp_ssr_w

    group: background {
      dimensions:
      	delta_time = UNLIMITED ; // (84600 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via L1B ATBD" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "The time of the first TX pulse in the 50 laser pulses used for background, in seconds relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      		delta_time:coordinates = "delta_time" ;
      	ushort bg_cnt_50shot_w(delta_time) ;
      		bg_cnt_50shot_w:long_name = "Weak background counts" ;
      		bg_cnt_50shot_w:units = "counts" ;
      		bg_cnt_50shot_w:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
      		bg_cnt_50shot_w:contentType = "referenceInformation" ;
      		bg_cnt_50shot_w:description = "ATLAS flight s/w indicates for the beam the # of counted time tags (BackgroundCounts_50Shot) during the range windows associated with a set of 50 laser pulses of the major frame." ;
      		bg_cnt_50shot_w:coordinates = "delta_time" ;
      	ushort bg_cnt_50shot_s(delta_time) ;
      		bg_cnt_50shot_s:units = "counts" ;
      		bg_cnt_50shot_s:long_name = "Strong background counts" ;
      		bg_cnt_50shot_s:source = "ATL01/atlas/pcex/a_pmf_algorithm_science" ;
      		bg_cnt_50shot_s:contentType = "referenceInformation" ;
      		bg_cnt_50shot_s:description = "ATLAS flight s/w indicates for the beam the # of counted time tags (BackgroundCounts_50Shot) during the range windows associated with a set of 50 laser pulses of the major frame." ;
      		bg_cnt_50shot_s:coordinates = "delta_time" ;
      	uint pce_mframe_cnt(delta_time) ;
      		pce_mframe_cnt:long_name = "PCE Major frame counter" ;
      		pce_mframe_cnt:units = "counts" ;
      		pce_mframe_cnt:source = "Derived" ;
      		pce_mframe_cnt:contentType = "referenceInformation" ;
      		pce_mframe_cnt:description = "Major Frame ID - The  major frame ID is read from the DFC and starts counting at DFC POR.  The counter is used to identify individual major frames across diag and science packets. This counter can go for about 2.7 years before rolling over. It is in the first time tag science packet. Used as part of the photon ID" ;
      		pce_mframe_cnt:coordinates = "delta_time" ;
      	ubyte useflag(delta_time) ;
      		useflag:long_name = "Science Mode Flag" ;
      		useflag:units = "counts" ;
      		useflag:source = "ATL01/atlas/pcex/a_alt_sci/" ;
      		useflag:valid_min = 0UB ;
      		useflag:valid_max = 15UB ;
      		useflag:contentType = "referenceInformation" ;
      		useflag:description = "Science Mode Flag.  Used by ATL03 to discard non-science mode data. 0=stby, 1=science_mode, 2=test, 3=manual, 4=radio, 5=unknown, > 10=amcs_not_normal" ;
      		useflag:coordinates = "delta_time" ;
      		useflag:flag_meanings = "stby science test manual radio unknown unused unused unused unused stby_alt_amcs science_alt_amcs test_alt_amcs manual_alt_amcs radio_alt_amcs unknown_alt_amcs" ;
      		useflag:flag_values = 0UB, 1UB, 2UB, 3UB, 4UB, 5UB, 6UB, 7UB, 8UB, 9UB, 10UB, 11UB, 12UB, 13UB, 14UB, 15UB ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
      		:Description = "The background data is specific to each beam and reported at a 50-shot rate." ;
      		:data_rate = "Data within this group are stored at the data rate of the source PCE Altimetric Data Packets. (nominally fifty per second.)" ;
      } // group background
    } // group pce3
  } // group atlas

group: gpsr {

  // group attributes:
  		:Description = "Contains parameters related to the GPS Receiver." ;
  		:data_rate = "Data within this group are stored at the data rate of the source GPS Receiver Data Packets. (nominally one per second.)" ;

  group: carrier_amplitude {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    	ds_16_slots = UNLIMITED ; // (16 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time, in seconds since the ATLAS SDP GPS Epoch, computed from raw_gps_time_sec and subseconds in the time correlation group. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	byte ds_16_slots(ds_16_slots) ;
    		ds_16_slots:long_name = "DS for 16 slots" ;
    		ds_16_slots:units = "1" ;
    		ds_16_slots:source = "Dimension Scale" ;
    		ds_16_slots:valid_min = 1b ;
    		ds_16_slots:valid_max = 16b ;
    		ds_16_slots:contentType = "referenceInformation" ;
    		ds_16_slots:description = "Dimension scale representing each of the 16 slots." ;
    	float noise_ratio(delta_time, ds_16_slots) ;
    		noise_ratio:units = "dBHz" ;
    		noise_ratio:long_name = "CADR Carrier to Noise Power Density Ratio" ;
    		noise_ratio:source = "ATL01/sc3/gpsr/carrier_amplitude converted" ;
    		noise_ratio:contentType = "referenceInformation" ;
    		noise_ratio:description = "Carrier Amplitude Data Record (CADR) - Carrier to Noise Power Density Ratio. Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		noise_ratio:coordinates = "delta_time" ;
    	byte num_valid_slots(delta_time) ;
    		num_valid_slots:long_name = "Number of slots filled" ;
    		num_valid_slots:units = "counts" ;
    		num_valid_slots:source = "ATL01/sc3/gpsr/carrier_amplitude/dfh/raw_num_recs" ;
    		num_valid_slots:valid_min = 0b ;
    		num_valid_slots:valid_max = 24b ;
    		num_valid_slots:contentType = "referenceInformation" ;
    		num_valid_slots:description = "Number of the 16 available slots filled by telemetry.  Data values after the number of valid slots are filled with 0. Note: Valid data records will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 16, then the remaining unused data fields within the arrays will be zero-filled." ;
    		num_valid_slots:coordinates = "delta_time" ;
    	byte antenna_id(delta_time, ds_16_slots) ;
    		antenna_id:long_name = "CADR Antenna Identifier" ;
    		antenna_id:units = "1" ;
    		antenna_id:source = "ATL01/sc3/gpsr/carrier_amplitude" ;
    		antenna_id:valid_min = 0b ;
    		antenna_id:valid_max = 1b ;
    		antenna_id:contentType = "referenceInformation" ;
    		antenna_id:description = "Carrier Amplitude Data Record (CADR) - Antenna Identifier.  0 = First Antenna  1 = Second Antenna (invalid for present receiver)  All other values invalid. Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		antenna_id:coordinates = "delta_time" ;
    		antenna_id:flag_meanings = "first_antenna second_antenna" ;
    		antenna_id:flag_values = 0b, 1b ;
    	byte signal_type(delta_time, ds_16_slots) ;
    		signal_type:source = "ATL01/sc3/gpsr/carrier_amplitude" ;
    		signal_type:valid_min = 0b ;
    		signal_type:valid_max = 6b ;
    		signal_type:contentType = "referenceInformation" ;
    		signal_type:description = "Carrier Amplitude Data Record (CADR) - GPS Signal Type. 0 = GPS L1 C/A  1 = GPS L1 P   2 = GPS L2 C/A (N/A for present receiver)   3 = GPS L2 P   4 = GPS L2 CM   5 = GPS L2 CL (N/A for present receiver)   6 = No signal processing on this channel   All other values invalid. Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		signal_type:coordinates = "delta_time" ;
    		signal_type:flag_meanings = "gps_l1a_ca gps_l1_p gps_l2_ca gps_l2_p gps_l2_cm gps_l2_cl no_signal_processing" ;
    		signal_type:flag_values = 0b, 1b, 2b, 3b, 4b, 5b, 6b ;
    		signal_type:long_name = "CADR GPS Signal Type" ;
    		signal_type:units = "1" ;
    	byte constell_id(delta_time, ds_16_slots) ;
    		constell_id:long_name = "CADR Constellation ID" ;
    		constell_id:units = "counts" ;
    		constell_id:source = "ATL01/sc3/gpsr/carrier_amplitude" ;
    		constell_id:contentType = "referenceInformation" ;
    		constell_id:description = "Carrier Amplitude Data Record (CADR) - Constellation ID - Single Frequency Channel 1-24 (0 = GPS Constellation; All other values invalid). Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		constell_id:coordinates = "delta_time" ;
    	byte channel_num(delta_time, ds_16_slots) ;
    		channel_num:long_name = "CADR Channel Number" ;
    		channel_num:units = "counts" ;
    		channel_num:source = "ATL01/sc3/gpsr/carrier_amplitude" ;
    		channel_num:valid_min = 0b ;
    		channel_num:valid_max = 23b ;
    		channel_num:contentType = "referenceInformation" ;
    		channel_num:description = "Carrier Amplitude Data Record (CADR) - Channel Number. 0 to 23;  All other values invalid. Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		channel_num:coordinates = "delta_time" ;
    	float carrier_amp(delta_time, ds_16_slots) ;
    		carrier_amp:long_name = "CADR Carrier Amplitude" ;
    		carrier_amp:units = "dB" ;
    		carrier_amp:source = "ATL01/sc3/gpsr/carrier_amplitude converted" ;
    		carrier_amp:contentType = "referenceInformation" ;
    		carrier_amp:description = "Carrier Amplitude Data Record (CADR) - Carrier Amplitude - Multiple Frequency Processing. Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		carrier_amp:coordinates = "delta_time" ;
    	byte sv_id(delta_time, ds_16_slots) ;
    		sv_id:long_name = "CADR Space Vehicle ID" ;
    		sv_id:units = "counts" ;
    		sv_id:source = "ATL01/sc3/gpsr/carrier_amplitude" ;
    		sv_id:valid_min = 0b ;
    		sv_id:valid_max = 32b ;
    		sv_id:contentType = "referenceInformation" ;
    		sv_id:description = "Carrier Amplitude Data Record (CADR) - Space Vehicle ID. (0 = No signal acquisition or tracking;  1-32 = GPS SVs. All other values invalid). Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		sv_id:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time\nds_16_slots" ;
    		:Description = "Contains parameters related to Carrier Amplitude Data Record (CADR)." ;
    		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;
    } // group carrier_amplitude

  group: carrier_phase {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    	ds_24_slots = UNLIMITED ; // (24 currently)
    variables:
    	byte ds_24_slots(ds_24_slots) ;
    		ds_24_slots:units = "1" ;
    		ds_24_slots:long_name = "DS for 24 slots" ;
    		ds_24_slots:source = "Dimension Scale" ;
    		ds_24_slots:valid_min = 1b ;
    		ds_24_slots:valid_max = 24b ;
    		ds_24_slots:contentType = "referenceInformation" ;
    		ds_24_slots:description = "Dimension scale representing each of the 24 slots." ;
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time, in seconds since the ATLAS SDP GPS Epoch, computed from raw_gps_time_sec and subseconds in the time correlation group. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	double delta_range(delta_time, ds_24_slots) ;
    		delta_range:long_name = "CRPDR Delta Range" ;
    		delta_range:units = "meters/second" ;
    		delta_range:source = "ATL01/sc3/gpsr/carrier_phase converted" ;
    		delta_range:contentType = "referenceInformation" ;
    		delta_range:description = "Carrier Phase Data Record (CrPDR) - Delta Range.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		delta_range:coordinates = "delta_time" ;
    	byte num_valid_slots(delta_time) ;
    		num_valid_slots:long_name = "Number of slots filled" ;
    		num_valid_slots:units = "counts" ;
    		num_valid_slots:source = "ATL01/sc3/gpsr/carrier_phase/dfh_x/raw_num_recs" ;
    		num_valid_slots:valid_min = 0b ;
    		num_valid_slots:valid_max = 24b ;
    		num_valid_slots:contentType = "referenceInformation" ;
    		num_valid_slots:description = "Number of the 24 available slots filled by telemetry.  Data values after the number of valid slots are filled with 0. Note: Valid data records will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused data fields within the arrays will be zero-filled." ;
    		num_valid_slots:coordinates = "delta_time" ;
    	byte antenna_id(delta_time, ds_24_slots) ;
    		antenna_id:long_name = "CRPDR Antenna Identifier" ;
    		antenna_id:units = "1" ;
    		antenna_id:source = "ATL01/sc3/gpsr/carrier_phase" ;
    		antenna_id:contentType = "referenceInformation" ;
    		antenna_id:description = "Carrier Phase Data Record (CrPDR) - Antenna Identifier.  0 = First Antenna  1 = Second Antenna (invalid for present receiver)  All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		antenna_id:coordinates = "delta_time" ;
    		antenna_id:flag_meanings = "first_antenna second_antenna" ;
    		antenna_id:flag_values = 0b, 1b ;
    	byte constell_id(delta_time, ds_24_slots) ;
    		constell_id:long_name = "CRPDR Constellation ID" ;
    		constell_id:units = "counts" ;
    		constell_id:source = "ATL01/sc3/gpsr/carrier_phase" ;
    		constell_id:contentType = "referenceInformation" ;
    		constell_id:description = "Carrier Phase Data Record (CrPDR) - Constellation ID - Single Frequency Channel 1-24 (0 = GPS Constellation; All other values invalid).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		constell_id:coordinates = "delta_time" ;
    	byte signal_type(delta_time, ds_24_slots) ;
    		signal_type:long_name = "CRPDR GPS Signal Type" ;
    		signal_type:units = "1" ;
    		signal_type:source = "ATL01/sc3/gpsr/carrier_phase" ;
    		signal_type:valid_min = 0b ;
    		signal_type:valid_max = 6b ;
    		signal_type:contentType = "referenceInformation" ;
    		signal_type:description = "Carrier Phase Data Record (CrPDR) - GPS Signal Type. 0 = GPS L1 C/A  1 = GPS L1 P   2 = GPS L2 C/A (N/A for present receiver)   3 = GPS L2 P   4 = GPS L2 CM   5 = GPS L2 CL (N/A for present receiver)   6 = No signal processing on this channel   All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		signal_type:coordinates = "delta_time" ;
    		signal_type:flag_meanings = "gps_l1a_ca gps_l1_p gps_l2_ca gps_l2_p gps_l2_cm gps_l2_cl no_signal_processing" ;
    		signal_type:flag_values = 0b, 1b, 2b, 3b, 4b, 5b, 6b ;
    	byte deter_f(delta_time, ds_24_slots) ;
    		deter_f:long_name = "CRPDR Deterioration Flag" ;
    		deter_f:units = "1" ;
    		deter_f:source = "ATL01/sc3/gpsr/carrier_phase" ;
    		deter_f:valid_min = 0b ;
    		deter_f:valid_max = 1b ;
    		deter_f:contentType = "referenceInformation" ;
    		deter_f:description = "Carrier Phase Data Record (CrPDR) - Deterioration Flag.  0= Carrier Loop Lock Steady   1 = Carrier Loop Lock Unsteady (Measurement data may be deteriorated).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		deter_f:coordinates = "delta_time" ;
    		deter_f:flag_meanings = "steady unsteady" ;
    		deter_f:flag_values = 0b, 1b ;
    	int64 carrier_c_int(delta_time, ds_24_slots) ;
    		carrier_c_int:long_name = "CRPDR Integer Carrier Cycle Counter" ;
    		carrier_c_int:units = "counts" ;
    		carrier_c_int:source = "ATL01/sc3/gpsr/carrier_phase" ;
    		carrier_c_int:contentType = "referenceInformation" ;
    		carrier_c_int:description = "Carrier Phase Data Record (CrPDR) - Integer Carrier Cycle Counter - Note: At the beginning of each track the integer carrier cycle count starts with 0.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		carrier_c_int:coordinates = "delta_time" ;
    	float carrier_c_fract(delta_time, ds_24_slots) ;
    		carrier_c_fract:units = "degrees" ;
    		carrier_c_fract:long_name = "CRPDR Carrier Cycle Fraction" ;
    		carrier_c_fract:source = "ATL01/sc3/gpsr/carrier_phase converted" ;
    		carrier_c_fract:contentType = "referenceInformation" ;
    		carrier_c_fract:description = "Carrier Phase Data Record (CrPDR) - Carrier Cycle Fraction -  Fraction corresponding to 360 degrees divided by 4096.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		carrier_c_fract:coordinates = "delta_time" ;
    	byte channel_num(delta_time, ds_24_slots) ;
    		channel_num:long_name = "CRPDR Channel Number" ;
    		channel_num:units = "counts" ;
    		channel_num:source = "ATL01/sc3/gpsr/carrier_phase" ;
    		channel_num:valid_min = 0b ;
    		channel_num:valid_max = 23b ;
    		channel_num:contentType = "referenceInformation" ;
    		channel_num:description = "Carrier Phase Data Record (CrPDR) - Channel Number. 0 to 23;  All other values invalid.  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		channel_num:coordinates = "delta_time" ;
    	byte sv_id(delta_time, ds_24_slots) ;
    		sv_id:long_name = "CRPDR Space Vehicle ID" ;
    		sv_id:units = "counts" ;
    		sv_id:source = "ATL01/sc3/gpsr/carrier_phase" ;
    		sv_id:valid_min = 0b ;
    		sv_id:valid_max = 32b ;
    		sv_id:contentType = "referenceInformation" ;
    		sv_id:description = "Carrier Phase Data Record (CrPDR) - Space Vehicle ID. (0 = No signal acquisition or tracking;  1-32 = GPS SVs. All other values invalid).  Note: Valid data records (num_valid_slots) will only be included for the amount of SFCs being tracked by the GPSR. If the tracked SFCs < 24, then the remaining unused CSR data fields within the ancillary packet will be zero-filled." ;
    		sv_id:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time\nds_24_slots" ;
    		:Description = "Contains parameters related to the GPSR Carrier Phase Data Record (CrPDR)." ;
    		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;
    } // group carrier_phase

  group: channel_status {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    	ds_24_slots = UNLIMITED ; // (24 currently)
    variables:
    	byte ds_24_slots(ds_24_slots) ;
    		ds_24_slots:long_name = "DS for 24 slots" ;
    		ds_24_slots:units = "1" ;
    		ds_24_slots:source = "Dimension Scale" ;
    		ds_24_slots:valid_min = 1b ;
    		ds_24_slots:valid_max = 24b ;
    		ds_24_slots:contentType = "referenceInformation" ;
    		ds_24_slots:description = "Dimension scale representing each of the 24 slots." ;
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time, in seconds since the ATLAS SDP GPS Epoch, computed from raw_gps_time_sec and subseconds in the time correlation group. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	byte code_loop_bw(delta_time, ds_24_slots) ;
