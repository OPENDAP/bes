      		srm:long_name = "srm" ;
      		srm:units = "1" ;
      		srm:source = "ATL01/atlas/pcex/a_sxp_ssr" ;
      		srm:contentType = "referenceInformation" ;
      		srm:description = "Surface type, vegetation and coastline information from the SRM. (bit 0-1 = surface type (0=ocean, 1=land, 2=sea ice, 3=land ice). Bit 2 = vegetation present, Bit 3 = coastline present)" ;
      		srm:coordinates = "delta_time latitude longitude" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time\nds_50samples" ;
      		:Description = "SBC Extrapolation Task telemetry containing Flight Science Receiver Algorithm team requested telemetry for the first set of PCE extrapolation data for a major frame.: lat, long, range, nadir angle, etc. (from APIDs 1152 thru 1157)" ;
