  group: hk {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time, in seconds since the ATLAS SDP GPS Epoch, computed from raw_gps_time_sec and subseconds in the time correlation group. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	ubyte ic_tag_error(delta_time) ;
    		ic_tag_error:long_name = "HK Instr Cache Tag Error Counter" ;
    		ic_tag_error:units = "counts" ;
    		ic_tag_error:source = "ATL01/sc4/gpsr/hk" ;
    		ic_tag_error:contentType = "referenceInformation" ;
    		ic_tag_error:description = "Housekeeping Parameter Report (HK) - Instr Cache Tag Error Counter" ;
    		ic_tag_error:coordinates = "delta_time" ;
    	ubyte edac_single_bit_error(delta_time) ;
    		edac_single_bit_error:units = "counts" ;
    		edac_single_bit_error:source = "ATL01/sc4/gpsr/hk" ;
    		edac_single_bit_error:contentType = "referenceInformation" ;
    		edac_single_bit_error:description = "Housekeeping Parameter Report (HK) - MilBus I/F EDAC Single Bit Error" ;
    		edac_single_bit_error:coordinates = "delta_time" ;
    		edac_single_bit_error:long_name = "HK MilBus I/F EDAC Single Bit Error" ;
    	ubyte dc_data_error(delta_time) ;
    		dc_data_error:long_name = "HK Data Cache Data Error Counter" ;
    		dc_data_error:units = "counts" ;
    		dc_data_error:source = "ATL01/sc4/gpsr/hk" ;
    		dc_data_error:contentType = "referenceInformation" ;
    		dc_data_error:description = "Housekeeping Parameter Report (HK) - Data Cache Data Error Counter" ;
    		dc_data_error:coordinates = "delta_time" ;
    	byte register_file_errors(delta_time) ;
    		register_file_errors:long_name = "HK Corrected Register File Errors" ;
    		register_file_errors:units = "1" ;
    		register_file_errors:source = "ATL01/sc4/gpsr/hk" ;
    		register_file_errors:valid_min = 0b ;
    		register_file_errors:valid_max = 1b ;
    		register_file_errors:contentType = "referenceInformation" ;
    		register_file_errors:description = "Housekeeping Parameter Report (HK) - Corrected Register File Errors" ;
    		register_file_errors:coordinates = "delta_time" ;
    		register_file_errors:flag_meanings = "no_error_detected error_detected" ;
    		register_file_errors:flag_values = 0b, 1b ;
    	ushort cpu_processor_load(delta_time) ;
    		cpu_processor_load:long_name = "HK CPU Processor Load" ;
    		cpu_processor_load:units = "counts" ;
    		cpu_processor_load:source = "ATL01/sc4/gpsr/hk" ;
    		cpu_processor_load:contentType = "referenceInformation" ;
    		cpu_processor_load:description = "Housekeeping Parameter Report (HK) - CPU Load of most recent PPS interval" ;
    		cpu_processor_load:coordinates = "delta_time" ;
    	byte nsm(delta_time) ;
    		nsm:long_name = "GPSR Navigation Solution Method (NSM)" ;
    		nsm:units = "1" ;
    		nsm:source = "ATL01/sc4/gpsr/hk" ;
    		nsm:valid_min = 0b ;
    		nsm:valid_max = 7b ;
    		nsm:contentType = "referenceInformation" ;
    		nsm:description = "GPSR - Navigation Solution Method. 1 = Propagated;  2 = Cold Start - First Nav Fix; 3 = Cold Start - Least Squares Method w/ no GDOP Optimization; 4 = Least Squares Method w/ all Visible SVs; 5 = Kalman Filter Method (Normal Operation); 7 = Invalid Navigation Solution. All other values are invalid." ;
    		nsm:coordinates = "delta_time" ;
    		nsm:flag_meanings = "unknown propagated cold_first_nav cold_lsq_no_gdop lsqm_w_svs normal_kalman invalid_solution" ;
    		nsm:flag_values = 0b, 1b, 2b, 3b, 4b, 5b, 7b ;
    	byte edac_double_bit_error(delta_time) ;
    		edac_double_bit_error:units = "counts" ;
    		edac_double_bit_error:long_name = "HK MilBus I/F EDAC Double Bit Error" ;
    		edac_double_bit_error:source = "ATL01/sc4/gpsr/hk" ;
    		edac_double_bit_error:contentType = "referenceInformation" ;
    		edac_double_bit_error:description = "Housekeeping Parameter Report (HK) - MilBus I/F EDAC Double Bit Error" ;
    		edac_double_bit_error:coordinates = "delta_time" ;
    	byte sram_edac_status(delta_time) ;
    		sram_edac_status:long_name = "HK SRAM EDAC Status" ;
    		sram_edac_status:units = "1" ;
    		sram_edac_status:source = "ATL01/sc4/gpsr/hk" ;
    		sram_edac_status:valid_min = 0b ;
    		sram_edac_status:valid_max = 1b ;
    		sram_edac_status:contentType = "referenceInformation" ;
    		sram_edac_status:description = "Housekeeping Parameter Report (HK) - SRAM EDAC Single bit error" ;
    		sram_edac_status:coordinates = "delta_time" ;
    		sram_edac_status:flag_meanings = "no_error_detected error_detected" ;
    		sram_edac_status:flag_values = 0b, 1b ;
    	ubyte discarded_tm_packets(delta_time) ;
    		discarded_tm_packets:units = "counts" ;
    		discarded_tm_packets:long_name = "HK Discarded TM Packet Counter" ;
    		discarded_tm_packets:source = "ATL01/sc4/gpsr/hk" ;
    		discarded_tm_packets:contentType = "referenceInformation" ;
    		discarded_tm_packets:description = "Housekeeping Parameter Report (HK) - Number of TM packets discarded since start of GPSR (wrapping counter)." ;
    		discarded_tm_packets:coordinates = "delta_time" ;
    	byte n_svs_acquired(delta_time) ;
    		n_svs_acquired:long_name = "HK Number of SVs Being Acquired" ;
    		n_svs_acquired:units = "counts" ;
