      		internal:source = "CAL54" ;
      		internal:contentType = "auxiliaryInformation" ;
      		internal:description = "Internal laser monitor coefficients (a_(J),b0_(J/count),b1_(J/degC_count),c0_(J/count^2),c1_(J/degC_count^2),d_(J/count^3),e_(J/count^4),std_of_residuals)" ;
