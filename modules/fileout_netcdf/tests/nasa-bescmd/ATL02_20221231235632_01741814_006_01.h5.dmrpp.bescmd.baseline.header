    		corr_tx_coarse_pce2:units = "counts" ;
    		corr_tx_coarse_pce2:source = "ATLAS L1B ATBD" ;
    		corr_tx_coarse_pce2:contentType = "auxiliaryInformation" ;
    		corr_tx_coarse_pce2:description = "Correction for the PCE2 Transmit coarse clock offset. This corrects for the offset between the actual number of coarse clock cycles and the reported number of coarse clock cycles. Default value is -1." ;
    	int corr_rx_coarse_pce2(dim262) ;
    		corr_rx_coarse_pce2:long_name = "Correction value for PCE2 Rx coarse clock offset" ;
    		corr_rx_coarse_pce2:units = "counts" ;
    		corr_rx_coarse_pce2:source = "ATLAS L1B ATBD" ;
    		corr_rx_coarse_pce2:contentType = "auxiliaryInformation" ;
    		corr_rx_coarse_pce2:description = "Correction for the PCE2 Receive coarse clock offset. This corrects for the offset between the actual number of coarse clock cycles and the reported number of coarse clock cycles (for each channel). Default value is -1." ;
    	double dt_uso(dim263) ;
    		dt_uso:long_name = "USO (AMET) Clock Tick" ;
    		dt_uso:units = "seconds/count" ;
    		dt_uso:source = "ATLAS L1B ATBD, Section 4.2.1" ;
    		dt_uso:contentType = "auxiliaryInformation" ;
    		dt_uso:description = "The AMET clock tick" ;
    	int min_conf(dim264) ;
    		min_conf:long_name = "Minimum Confidence" ;
    		min_conf:units = "1" ;
    		min_conf:source = "ATLAS L1B ATBD," ;
    		min_conf:contentType = "auxiliaryInformation" ;
    		min_conf:description = "Minimum TxRx histogram confidence level to fail a granule." ;
    	double dt_imet(dim265) ;
    		dt_imet:long_name = "IMET Clock Tick" ;
    		dt_imet:units = "seconds/count" ;
    		dt_imet:source = "ATLAS L1B ATBD, Section 4.2.1" ;
