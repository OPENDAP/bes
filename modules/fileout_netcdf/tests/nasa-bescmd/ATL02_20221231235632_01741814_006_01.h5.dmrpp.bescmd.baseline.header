    group: pdu {
      dimensions:
      	delta_time = UNLIMITED ; // (423 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Number of GPS seconds since the ATLAS SDP GPS Epoch. This is computed based on the housekeeping design to sample a measurement every 0.003125 seconds from the internal ASC 1PPS . The time for this packet is set as the time of the lowest software channel number in this telemetry packet. If the specific time is needed add to it the difference of its actual ATLAS hardware channel number from the lowest software channel number times the 0.003125 seconds. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	float pdu_p3p3v_dem5_i(delta_time) ;
      		pdu_p3p3v_dem5_i:long_name = "PDU P3P3V DEM5 I" ;
      		pdu_p3p3v_dem5_i:units = "amps" ;
      		pdu_p3p3v_dem5_i:source = "ATL01/atlas/a_hkt_a_1059 converted" ;
      		pdu_p3p3v_dem5_i:contentType = "referenceInformation" ;
      		pdu_p3p3v_dem5_i:description = "PDU P3P3V DEM5 I - A_HKT.chan[57]" ;
      		pdu_p3p3v_dem5_i:coordinates = "delta_time" ;
      	float pdu_n3v_dem1_i(delta_time) ;
      		pdu_n3v_dem1_i:long_name = "PDU N3V DEM1 I" ;
      		pdu_n3v_dem1_i:units = "amps" ;
      		pdu_n3v_dem1_i:source = "ATL01/atlas/a_hkt_a_1059 converted" ;
      		pdu_n3v_dem1_i:contentType = "referenceInformation" ;
      		pdu_n3v_dem1_i:description = "PDU N3V DEM1 I - A_HKT.chan[52]" ;
      		pdu_n3v_dem1_i:coordinates = "delta_time" ;
      	float pdu_tcs_ofa_htr1_i(delta_time) ;
      		pdu_tcs_ofa_htr1_i:long_name = "PDU TCS OFA HTR1 I" ;
      		pdu_tcs_ofa_htr1_i:units = "amps" ;
      		pdu_tcs_ofa_htr1_i:source = "ATL01/atlas/a_hkt_a_1059 converted" ;
      		pdu_tcs_ofa_htr1_i:contentType = "referenceInformation" ;
      		pdu_tcs_ofa_htr1_i:description = "PDU TCS OFA HTR1 I - A_HKT.chan[32]" ;
      		pdu_tcs_ofa_htr1_i:coordinates = "delta_time" ;
      	float pdu_lhp2_i(delta_time) ;
