  group: attitude_control_system {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "The time tag of the data computed from raw_acs_time_sec and subseconds in the L1A Attitude_control_ group, relative to the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	double sc_to_lrs_quat_3(delta_time) ;
    		sc_to_lrs_quat_3:long_name = "SC Inertial to LRS Frame Quaternions 3" ;
    		sc_to_lrs_quat_3:units = "counts" ;
    		sc_to_lrs_quat_3:source = "ATL01/sc1/attitude_control_system and L1B ATBD conversion" ;
    		sc_to_lrs_quat_3:contentType = "referenceInformation" ;
    		sc_to_lrs_quat_3:description = "ACS Spacecraft Inertial frame to Laser Reference System (LRS) reference frame quaternion 3. (Same data provided to ATLAS in RT at 1Hz)." ;
    		sc_to_lrs_quat_3:coordinates = "delta_time" ;
    	double sc_to_lrs_quat_4(delta_time) ;
    		sc_to_lrs_quat_4:long_name = "SC Inertial to LRS Frame Quaternions 4" ;
    		sc_to_lrs_quat_4:units = "counts" ;
    		sc_to_lrs_quat_4:source = "ATL01/sc1/attitude_control_system and L1B ATBD conversion" ;
    		sc_to_lrs_quat_4:contentType = "referenceInformation" ;
    		sc_to_lrs_quat_4:description = "ACS Spacecraft Inertial frame to Laser Reference System (LRS) reference frame quaternion4. (Same data provided to ATLAS in RT at 1Hz)." ;
    		sc_to_lrs_quat_4:coordinates = "delta_time" ;
    	double sc_to_lrs_quat_2(delta_time) ;
    		sc_to_lrs_quat_2:long_name = "SC Inertial to LRS Frame Quaternions 2" ;
    		sc_to_lrs_quat_2:units = "counts" ;
    		sc_to_lrs_quat_2:source = "ATL01/sc1/attitude_control_system and L1B ATBD conversion" ;
    		sc_to_lrs_quat_2:contentType = "referenceInformation" ;
    		sc_to_lrs_quat_2:description = "ACS Spacecraft Inertial frame to Laser Reference System (LRS) reference frame quaternion 2. (Same data provided to ATLAS in RT at 1Hz)." ;
    		sc_to_lrs_quat_2:coordinates = "delta_time" ;
    	double sc_body_rate_z(delta_time) ;
    		sc_body_rate_z:long_name = "SC Body Rate (Z)" ;
    		sc_body_rate_z:units = "radians/second" ;
    		sc_body_rate_z:source = "ATL01/sc1/attitude_control_system and L1B ATBD conversion" ;
    		sc_body_rate_z:contentType = "referenceInformation" ;
    		sc_body_rate_z:description = "ACS Fine Rate Estimate - SC Body Z axis.  (Same data provided to ATLAS in RT at 1Hz)" ;
    		sc_body_rate_z:coordinates = "delta_time" ;
    	ubyte acs_mode(delta_time) ;
    		acs_mode:long_name = "ACS Software Mode" ;
    		acs_mode:units = "counts" ;
    		acs_mode:source = "ATL01/sc1/attitude_control_system" ;
    		acs_mode:valid_min = 0UB ;
    		acs_mode:valid_max = 14UB ;
    		acs_mode:contentType = "referenceInformation" ;
    		acs_mode:description = "ACS Active ACS Software Mode 0 = Idle 1 = Rate Capture 2 = Sun Acquisition  3 = (Reserved - N/A for ICESat-2) 4 = Slew 5 = Inertial Sun Point  6 = Earth Pointing  7 = ACS Calibration 8 = Inertial Pointing 9 = Reference Ground Track (RGT) 10 = Roll Off-Point (ROP) 11 = Instrument Calibration (ICAL) 12 = DV Wheel Standby 13 = DV Thruster Standby 14 = DV Burn" ;
    		acs_mode:coordinates = "delta_time" ;
    		acs_mode:flag_meanings = "idle rate_capture sun_acquisition reserved slew inertial_sun_point earth_pointing acs_calibration inertial_pointing reference_ground_track roll_off_point instrument_calibration dv_wheel_standby dv_thruster_standby dv_burn" ;
    		acs_mode:flag_values = 0UB, 1UB, 2UB, 3UB, 4UB, 5UB, 6UB, 7UB, 8UB, 9UB, 10UB, 11UB, 12UB, 13UB, 14UB ;
    	double sc_to_lrs_quat_1(delta_time) ;
    		sc_to_lrs_quat_1:long_name = "SC Inertial to LRS Frame Quaternions 1" ;
    		sc_to_lrs_quat_1:units = "counts" ;
    		sc_to_lrs_quat_1:source = "ATL01/sc1/attitude_control_system and L1B ATBD conversion" ;
    		sc_to_lrs_quat_1:contentType = "referenceInformation" ;
    		sc_to_lrs_quat_1:description = "ACS Spacecraft Inertial frame to Laser Reference System (LRS) reference frame quaternion1. (Same data provided to ATLAS in RT at 1Hz)." ;
    		sc_to_lrs_quat_1:coordinates = "delta_time" ;
    	double sc_body_rate_y(delta_time) ;
    		sc_body_rate_y:long_name = "SC Body Rate (Y)" ;
    		sc_body_rate_y:units = "radians/second" ;
    		sc_body_rate_y:source = "ATL01/sc1/attitude_control_system and L1B ATBD conversion" ;
    		sc_body_rate_y:contentType = "referenceInformation" ;
    		sc_body_rate_y:description = "ACS Fine Rate Estimate - SC Body Y axis.  (Same data provided to ATLAS in RT at 1Hz)" ;
    		sc_body_rate_y:coordinates = "delta_time" ;
    	double sc_body_rate_x(delta_time) ;
    		sc_body_rate_x:long_name = "SC Body Rate (X)" ;
    		sc_body_rate_x:units = "radians/second" ;
    		sc_body_rate_x:source = "ATL01/sc1/attitude_control_system and L1B ATBD conversion" ;
    		sc_body_rate_x:contentType = "referenceInformation" ;
    		sc_body_rate_x:description = "ACS Fine Rate Estimate - SC Body X axis.  (Same data provided to ATLAS in RT at 1Hz)" ;
    		sc_body_rate_x:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters related to spacecraft ACS (attitude control system) software." ;
    		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;
    } // group attitude_control_system

  group: solar_array {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "SC time at the initiation of the ACS task, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	float azimuth_meas_1(delta_time) ;
    		azimuth_meas_1:long_name = "SADA Azimuth Measured Position (Pot 1)" ;
    		azimuth_meas_1:units = "degrees" ;
    		azimuth_meas_1:source = "ATL01/sc1/solar_array" ;
    		azimuth_meas_1:valid_min = -100.f ;
    		azimuth_meas_1:valid_max = 100.f ;
    		azimuth_meas_1:contentType = "referenceInformation" ;
    		azimuth_meas_1:description = "Solar Array Drive Assembly (SADA) - Estimated Azimuth angle based on Potentiometer 1 (as reported by ACS software)." ;
    		azimuth_meas_1:coordinates = "delta_time" ;
    	float azimuth_meas_2(delta_time) ;
    		azimuth_meas_2:long_name = "SADA Azimuth Measured Position (Pot 2)" ;
    		azimuth_meas_2:units = "degrees" ;
    		azimuth_meas_2:source = "ATL01/sc1/solar_array" ;
    		azimuth_meas_2:valid_min = -100.f ;
    		azimuth_meas_2:valid_max = 100.f ;
    		azimuth_meas_2:contentType = "referenceInformation" ;
    		azimuth_meas_2:description = "Solar Array Drive Assembly (SADA) - Estimated Azimuth angle based on Potentiometer 2 (as reported by ACS software)." ;
    		azimuth_meas_2:coordinates = "delta_time" ;
    	float azimuth_est(delta_time) ;
    		azimuth_est:long_name = "SADA Azimuth Estimated Position" ;
    		azimuth_est:units = "degrees" ;
    		azimuth_est:source = "ATL01/sc1/solar_array" ;
    		azimuth_est:valid_min = -100.f ;
    		azimuth_est:valid_max = 100.f ;
    		azimuth_est:contentType = "referenceInformation" ;
    		azimuth_est:description = "Solar Array Drive Assembly (SADA) - Estimated Azimuth position used for ACS control" ;
    		azimuth_est:coordinates = "delta_time" ;
    	float elev_meas_1(delta_time) ;
    		elev_meas_1:units = "degrees" ;
    		elev_meas_1:long_name = "SADA Elevation Measured Position (Pot 1)" ;
    		elev_meas_1:source = "ATL01/sc1/solar_array" ;
    		elev_meas_1:valid_min = -10.f ;
    		elev_meas_1:valid_max = 90.f ;
    		elev_meas_1:contentType = "referenceInformation" ;
    		elev_meas_1:description = "Solar Array Drive Assembly (SADA) - Estimated Elevation angle based on Potentiometer 1 (as reported by ACS software)." ;
    		elev_meas_1:coordinates = "delta_time" ;
    	float elev_est(delta_time) ;
    		elev_est:long_name = "SADA Elevation Estimated Position" ;
    		elev_est:units = "degrees" ;
    		elev_est:source = "ATL01/sc1/solar_array" ;
    		elev_est:valid_min = -10.f ;
    		elev_est:valid_max = 90.f ;
    		elev_est:contentType = "referenceInformation" ;
    		elev_est:description = "Solar Array Drive Assembly (SADA) - Estimated Elevation position used for ACS control" ;
    		elev_est:coordinates = "delta_time" ;
    	float elev_meas_2(delta_time) ;
    		elev_meas_2:units = "degrees" ;
    		elev_meas_2:long_name = "SADA Elevation Measured Position (Pot 2)" ;
    		elev_meas_2:source = "ATL01/sc1/solar_array" ;
    		elev_meas_2:valid_min = -10.f ;
    		elev_meas_2:valid_max = 90.f ;
    		elev_meas_2:contentType = "referenceInformation" ;
    		elev_meas_2:description = "Solar Array Drive Assembly (SADA) - Estimated Elevation angle based on Potentiometer 2 (as reported by ACS software)." ;
    		elev_meas_2:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters related to solar array driver assembly." ;
    		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;
    } // group solar_array

  group: star_tracker {
    dimensions:
    	delta_time = UNLIMITED ; // (4230 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time of the Star track subaddress 1 data, relative to the ATLAS SDP GPS Epoch and computed from raw_ace_time_sec/subseconds and etr_delay_tm1. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	ushort atm_frame_counter(delta_time) ;
    		atm_frame_counter:long_name = "ATM Frame Counter" ;
    		atm_frame_counter:units = "counts" ;
    		atm_frame_counter:source = "ATL01/sc2/star_tracker" ;
    		atm_frame_counter:contentType = "referenceInformation" ;
    		atm_frame_counter:description = "Star Tracker Electronics (STE) [ATM TM#1: Subaddress 13] - External Time Reference (ETR) counter - Used to determine measurement time of reported ATM TLM with respect to SC-provided sync pulse; This item increments upon the reception of the SC-provided sync pulse." ;
    		atm_frame_counter:coordinates = "delta_time" ;
    	ushort atm_etr_counter(delta_time) ;
    		atm_etr_counter:long_name = "ATM ETR Counter" ;
    		atm_etr_counter:units = "counts" ;
    		atm_etr_counter:source = "ATL01/sc2/star_tracker" ;
    		atm_etr_counter:contentType = "referenceInformation" ;
    		atm_etr_counter:description = "Star Tracker Electronics (STE) [ATM TM#1: Subaddress 13] - External Time Reference (ETR) delay ticks - Used to determine measurement time of reported ATM TLM with respect to SC-provided sync pulse; Additional delay of quaternion measurement time in ticks of 20 usec from ETR." ;
    		atm_etr_counter:coordinates = "delta_time" ;
    	ushort etr_counter(delta_time) ;
    		etr_counter:units = "counts" ;
    		etr_counter:long_name = "STE Star Tracker ETR Counter" ;
    		etr_counter:source = "ATL01/sc2/star_tracker" ;
    		etr_counter:contentType = "referenceInformation" ;
    		etr_counter:description = "Star Tracker Electronics (STE) [Star Tracker Status TM#1: Subaddress 1] - External Time Reference (ETR) counter - Used to determine measurement time of reported STE/OH mode status with respect to SC-provided sync pulse; This item increments upon the reception of the SC-provided sync pulse - Sample 1-10" ;
    		etr_counter:coordinates = "delta_time" ;
    	ushort mode_status(delta_time) ;
    		mode_status:units = "1" ;
    		mode_status:long_name = "STE Star Tracker Mode Status" ;
    		mode_status:source = "ATL01/sc2/star_tracker" ;
    		mode_status:valid_min = 0US ;
    		mode_status:valid_max = 15US ;
    		mode_status:contentType = "referenceInformation" ;
    		mode_status:description = "Star Tracker Electronics (STE) [Star Tracker Status TM#1: Subaddress 1] - Mode Status - Represents the current mode of the STE software . 0 = Initialization 1 = Standby 2 = Memory Read 3 = Memory Write 4 = Self Test 5 = Photo 9 = Angular Rate 10 = Attitude Acquisition 11 = Attitude Tracking 14 = AOM/Attitude Acquisition Phase 15 = AOM/Attitude Tracking Phase All other values invalid" ;
    		mode_status:coordinates = "delta_time" ;
    		mode_status:flag_meanings = "init stby mem_read mem_write self_test photon angular_rate att_acq att_track aom_acq aom_track" ;
    		mode_status:flag_values = 0US, 1US, 2US, 3US, 4US, 5US, 9US, 10US, 11US, 14US, 15US ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:data_rate = "Data within this group are stored at the data rate of the source Star Tracker data within the Spacecraft Ancillary Science Data Packets. (nominally ten per second.)" ;

    group: optical_head_1 {
      dimensions:
      	delta_time = UNLIMITED ; // (4230 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Elapsed GPS seconds since the ATLAS SDP GPS Epoch, computed from raw_ace_time_sec and subseconds and atm_etr_delay_tm7. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	float att_qa_x(delta_time) ;
      		att_qa_x:long_name = "STOH Attitude Quality (X)" ;
      		att_qa_x:units = "arcsec" ;
      		att_qa_x:source = "ATL01/sc2/star_tracker/optical_head_1 converted" ;
      		att_qa_x:contentType = "referenceInformation" ;
      		att_qa_x:description = "Star Tracker Optical Head (STOH) Quality measurement of STOH computed quaternion (X)" ;
      		att_qa_x:coordinates = "delta_time" ;
      	ushort atm_etr_counter(delta_time) ;
      		atm_etr_counter:long_name = "ATM ETR Counter" ;
      		atm_etr_counter:units = "counts" ;
      		atm_etr_counter:source = "ATL01/sc2/star_tracker/optical_head_1" ;
      		atm_etr_counter:contentType = "referenceInformation" ;
      		atm_etr_counter:description = "Star Tracker Optical Head (STOH) 1 [ATM TM#7: Subaddress 19] - External Time Reference (ETR) counter - Used to determine measurement time of reported quaternions with respect to SC- provided sync pulse; This item increments upon the reception of the SC-provided sync pulse." ;
      		atm_etr_counter:coordinates = "delta_time" ;
      	float att_qa_z(delta_time) ;
      		att_qa_z:long_name = "STOH Attitude Quality (Z)" ;
      		att_qa_z:units = "arcsec" ;
      		att_qa_z:source = "ATL01/sc2/star_tracker/optical_head_1 converted" ;
      		att_qa_z:contentType = "referenceInformation" ;
      		att_qa_z:description = "Star Tracker Optical Head (STOH) Quality measurement of STOH computed quaternion (Z)" ;
      		att_qa_z:coordinates = "delta_time" ;
      	byte seq_mode_st(delta_time) ;
      		seq_mode_st:_FillValue = 127b ;
      		seq_mode_st:long_name = "Sequencing Mode Status" ;
      		seq_mode_st:units = "counts" ;
      		seq_mode_st:source = "ATL01/sc2/star_tracker/optical_head_1" ;
      		seq_mode_st:valid_min = 0b ;
      		seq_mode_st:valid_max = 7b ;
      		seq_mode_st:contentType = "referenceInformation" ;
      		seq_mode_st:description = "Star Tracker Optical Head (STOH)  [Star Tracker Status TM#1: Subaddress 1] - Sequencing (Mode) Status" ;
      		seq_mode_st:coordinates = "delta_time" ;
      		seq_mode_st:flag_meanings = "off standby photo acquire track autotest win_acq powered" ;
      		seq_mode_st:flag_values = 0b, 1b, 2b, 3b, 4b, 5b, 6b, 7b ;
      	ushort atm_frame_counter(delta_time) ;
      		atm_frame_counter:long_name = "STOH1 ATM Frame Counter" ;
      		atm_frame_counter:units = "counts" ;
      		atm_frame_counter:source = "ATL01/sc2/star_tracker/optical_head_1" ;
      		atm_frame_counter:contentType = "referenceInformation" ;
      		atm_frame_counter:description = "Star Tracker Optical Head (STOH) 1 [ATM TM#7: Subaddress 19] - Frame Counter" ;
      		atm_frame_counter:coordinates = "delta_time" ;
      	double quaternion3(delta_time) ;
      		quaternion3:long_name = "STOH1 Quaternion3" ;
      		quaternion3:units = "counts" ;
      		quaternion3:source = "ATL01/sc2/star_tracker/optical_head_1" ;
      		quaternion3:contentType = "referenceInformation" ;
      		quaternion3:description = "Star Tracker Optical Head (STOH)  [ATM TM#7: Subaddress 19] - Attitude quaternion 3 - STOH reference frame to Earth-Centered Inertial (ECI) reference frame" ;
      		quaternion3:coordinates = "delta_time" ;
      	float att_qa_y(delta_time) ;
      		att_qa_y:long_name = "STOH Attitude Quality (Y)" ;
      		att_qa_y:units = "arcsec" ;
      		att_qa_y:source = "ATL01/sc2/star_tracker/optical_head_1 converted" ;
      		att_qa_y:contentType = "referenceInformation" ;
      		att_qa_y:description = "Star Tracker Optical Head (STOH) Quality measurement of STOH computed quaternion (Y)" ;
      		att_qa_y:coordinates = "delta_time" ;
      	double quaternion1(delta_time) ;
      		quaternion1:long_name = "STOH1 Quaternion1" ;
      		quaternion1:units = "counts" ;
      		quaternion1:source = "ATL01/sc2/star_tracker/optical_head_1" ;
      		quaternion1:contentType = "referenceInformation" ;
      		quaternion1:description = "Star Tracker Optical Head (STOH)  [ATM TM#7: Subaddress 19] - Attitude quaternion 1 - STOH reference frame to Earth-Centered Inertial (ECI) reference frame" ;
      		quaternion1:coordinates = "delta_time" ;
      	double quaternion4(delta_time) ;
      		quaternion4:long_name = "STOH1 Quaternion4" ;
      		quaternion4:units = "counts" ;
      		quaternion4:source = "ATL01/sc2/star_tracker/optical_head_1" ;
      		quaternion4:contentType = "referenceInformation" ;
      		quaternion4:description = "Star Tracker Optical Head (STOH)  [ATM TM#7: Subaddress 19] - Attitude quaternion 4 - STOH reference frame to Earth-Centered Inertial (ECI) reference frame" ;
      		quaternion4:coordinates = "delta_time" ;
      	double quaternion2(delta_time) ;
      		quaternion2:long_name = "STOH1 Quaternion2" ;
      		quaternion2:units = "counts" ;
      		quaternion2:source = "ATL01/sc2/star_tracker/optical_head_1" ;
      		quaternion2:contentType = "referenceInformation" ;
      		quaternion2:description = "Star Tracker Optical Head (STOH)  [ATM TM#7: Subaddress 19] - Attitude quaternion 2 - STOH reference frame to Earth-Centered Inertial (ECI) reference frame" ;
      		quaternion2:coordinates = "delta_time" ;
      	byte n_stars(delta_time) ;
      		n_stars:_FillValue = 127b ;
      		n_stars:long_name = "STOHx Number of Coherent Stars" ;
      		n_stars:units = "counts" ;
      		n_stars:source = "ATL01/sc2/star_tracker/optical_head_1" ;
      		n_stars:contentType = "referenceInformation" ;
      		n_stars:description = "Star Tracker Electronics (STE) [ATM TM#1: Subaddress 13] - Number of coherent stars used in STOH attitude calculation." ;
      		n_stars:coordinates = "delta_time" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
      		:Description = "Contains parameters related to spacecraft Star Tracker Optical Head 1 (STOH1)." ;
      		:data_rate = "Data within this group are stored at the data rate of the source Star Tracker data within the Spacecraft Ancillary Science Data Packets. (nominally ten per second.)" ;
      } // group optical_head_1

    group: optical_head_2 {
      dimensions:
      	delta_time = UNLIMITED ; // (4230 currently)
      variables:
      	double delta_time(delta_time) ;
      		delta_time:long_name = "Elapsed GPS seconds" ;
      		delta_time:standard_name = "time" ;
      		delta_time:units = "seconds since 2018-01-01" ;
      		delta_time:source = "Derived via Time Tagging" ;
      		delta_time:contentType = "referenceInformation" ;
      		delta_time:description = "Elapsed GPS seconds from the ATLAS SDP GPS Epoch, computed from raw_ace_time_sec and subseconds and atm_etr_delay_tm8. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
      	float att_qa_x(delta_time) ;
      		att_qa_x:long_name = "STOH Attitude Quality (X)" ;
      		att_qa_x:units = "arcsec" ;
      		att_qa_x:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		att_qa_x:contentType = "referenceInformation" ;
      		att_qa_x:description = "Star Tracker Optical Head (STOH) Quality measurement of STOH computed quaternion (X)" ;
      		att_qa_x:coordinates = "delta_time" ;
      	ushort atm_etr_counter(delta_time) ;
      		atm_etr_counter:long_name = "ATM ETR Counter" ;
      		atm_etr_counter:units = "counts" ;
      		atm_etr_counter:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		atm_etr_counter:contentType = "referenceInformation" ;
      		atm_etr_counter:description = "Star Tracker Optical Head (STOH) 2 [ATM TM#8: Subaddress 20] - External Time Reference (ETR) counter - Used to determine measurement time of reported quaternions with respect to SC- provided sync pulse; This item increments upon the reception of the SC-provided sync pulse" ;
      		atm_etr_counter:coordinates = "delta_time" ;
      	float att_qa_z(delta_time) ;
      		att_qa_z:long_name = "STOH Attitude Quality (Z)" ;
      		att_qa_z:units = "arcsec" ;
      		att_qa_z:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		att_qa_z:contentType = "referenceInformation" ;
      		att_qa_z:description = "Star Tracker Optical Head (STOH) Quality measurement of STOH computed quaternion (Z)" ;
      		att_qa_z:coordinates = "delta_time" ;
      	byte seq_mode_st(delta_time) ;
      		seq_mode_st:_FillValue = 127b ;
      		seq_mode_st:long_name = "Sequencing Mode Status" ;
      		seq_mode_st:units = "counts" ;
      		seq_mode_st:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		seq_mode_st:valid_min = 0b ;
      		seq_mode_st:valid_max = 7b ;
      		seq_mode_st:contentType = "referenceInformation" ;
      		seq_mode_st:description = "Star Tracker Optical Head (STOH)  [Star Tracker Status TM#1: Subaddress 1] - Sequencing (Mode) Status. A value of 127 indicates that the data could not be filled from the vc5 packets." ;
      		seq_mode_st:coordinates = "delta_time" ;
      		seq_mode_st:flag_meanings = "off standby photo acquire track autotest win_acq powered" ;
      		seq_mode_st:flag_values = 0b, 1b, 2b, 3b, 4b, 5b, 6b, 7b ;
      	ushort atm_frame_counter(delta_time) ;
      		atm_frame_counter:long_name = "STOH2 ATM Frame Counter" ;
      		atm_frame_counter:units = "counts" ;
      		atm_frame_counter:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		atm_frame_counter:contentType = "referenceInformation" ;
      		atm_frame_counter:description = "Star Tracker Optical Head (STOH) 2 [ATM TM#8: Subaddress 20] - Frame Counter" ;
      		atm_frame_counter:coordinates = "delta_time" ;
      	double quaternion3(delta_time) ;
      		quaternion3:long_name = "STOH1 Quaternion3" ;
      		quaternion3:units = "counts" ;
      		quaternion3:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		quaternion3:contentType = "referenceInformation" ;
      		quaternion3:description = "Star Tracker Optical Head (STOH)  [ATM TM#7: Subaddress 19] - Attitude quaternion 3 - STOH reference frame to Earth-Centered Inertial (ECI) reference frame" ;
      		quaternion3:coordinates = "delta_time" ;
      	float att_qa_y(delta_time) ;
      		att_qa_y:long_name = "STOH Attitude Quality (Y)" ;
      		att_qa_y:units = "arcsec" ;
      		att_qa_y:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		att_qa_y:contentType = "referenceInformation" ;
      		att_qa_y:description = "Star Tracker Optical Head (STOH) Quality measurement of STOH computed quaternion (Y)" ;
      		att_qa_y:coordinates = "delta_time" ;
      	double quaternion1(delta_time) ;
      		quaternion1:long_name = "STOH1 Quaternion1" ;
      		quaternion1:units = "counts" ;
      		quaternion1:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		quaternion1:contentType = "referenceInformation" ;
      		quaternion1:description = "Star Tracker Optical Head (STOH)  [ATM TM#7: Subaddress 19] - Attitude quaternion 1 - STOH reference frame to Earth-Centered Inertial (ECI) reference frame" ;
      		quaternion1:coordinates = "delta_time" ;
      	double quaternion4(delta_time) ;
      		quaternion4:long_name = "STOH1 Quaternion4" ;
      		quaternion4:units = "counts" ;
      		quaternion4:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		quaternion4:contentType = "referenceInformation" ;
      		quaternion4:description = "Star Tracker Optical Head (STOH)  [ATM TM#7: Subaddress 19] - Attitude quaternion 4 - STOH reference frame to Earth-Centered Inertial (ECI) reference frame" ;
      		quaternion4:coordinates = "delta_time" ;
      	double quaternion2(delta_time) ;
      		quaternion2:long_name = "STOH1 Quaternion2" ;
      		quaternion2:units = "counts" ;
      		quaternion2:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		quaternion2:contentType = "referenceInformation" ;
      		quaternion2:description = "Star Tracker Optical Head (STOH)  [ATM TM#7: Subaddress 19] - Attitude quaternion 2 - STOH reference frame to Earth-Centered Inertial (ECI) reference frame" ;
      		quaternion2:coordinates = "delta_time" ;
      	byte n_stars(delta_time) ;
      		n_stars:_FillValue = 127b ;
      		n_stars:long_name = "STOHx Number of Coherent Stars" ;
      		n_stars:units = "counts" ;
      		n_stars:source = "ATL01/sc2/star_tracker/optical_head_2" ;
      		n_stars:contentType = "referenceInformation" ;
      		n_stars:description = "Star Tracker Electronics (STE) [ATM TM#1: Subaddress 13] - Number of coherent stars used in STOH attitude calculation" ;
      		n_stars:coordinates = "delta_time" ;

      // group attributes:
      		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
      		:Description = "Contains parameters related to spacecraft Star Tracker Optical Head 2 (STOH2)." ;
      		:data_rate = "Data within this group are stored at the data rate of the source Star Tracker data within the Spacecraft Ancillary Science Data Packets. (nominally ten per second.)" ;
      } // group optical_head_2
    } // group star_tracker

  group: inertial_measurement_unit {
    dimensions:
    	delta_time = UNLIMITED ; // (21150 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "IMU delta time tag at the end of the IDL frame over which the integrated gyro angle data was collected, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	double sync_event_ttag(delta_time) ;
    		sync_event_ttag:long_name = "IMU Sync Event Time Tag" ;
    		sync_event_ttag:units = "seconds" ;
    		sync_event_ttag:source = "ATL01/sc1/inertial_measurement_unit/hi_rate converted" ;
    		sync_event_ttag:contentType = "referenceInformation" ;
    		sync_event_ttag:description = "IMU Time remaining on the countdown timer which triggers the IDL interrupt (between the event strobe and the timetag of the next IDL data packet). IMU time at the reception of the last IMU time sync pulse. This word contains the time stamp that is recorded when the Event Strobe input to the SSIRU transitions to the active (low) state." ;
    		sync_event_ttag:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters related to spacecraft IMU (Inertial Measurement Unit)." ;
    		:data_rate = "Data within this main group are stored at the data rate of the source IMU within the Spacecraft Ancillary Science Data Packet. (nominally fifty per second.)" ;

    group: gyro_a {
      variables:
      	float gyro_angle(delta_time) ;
      		gyro_angle:long_name = "IMU Gyro Integrated Angle Counter (Gyros A, B, C, D)" ;
      		gyro_angle:units = "arcseconds" ;
      		gyro_angle:source = "ATL01/sc1/inertial_measurement_unit/hi_rate converted" ;
      		gyro_angle:contentType = "referenceInformation" ;
      		gyro_angle:description = "IMU integrated angle sensed by the SSIRU Gyro. The data word shall increment from 0 to full scale (0xFFFF) and roll over to zero for positive input rates about the Gyro input axis. The data word shall decrement from full scale to 0 and roll over to 0xFFFF for negative input rates about the Gyro input axis." ;
      		gyro_angle:coordinates = "../delta_time" ;
      	byte gyro_rate_f(delta_time) ;
      		gyro_rate_f:long_name = "IMU Gyro Rate Valid (Gyros A, B, C, D)" ;
      		gyro_rate_f:units = "1" ;
      		gyro_rate_f:source = "ATL01/sc1/inertial_measurement_unit/hi_rate" ;
      		gyro_rate_f:valid_min = 0b ;
      		gyro_rate_f:valid_max = 1b ;
      		gyro_rate_f:contentType = "referenceInformation" ;
      		gyro_rate_f:description = "IMU Gyro Integrated Angular Rate data validity status. 0=invalid, 1=valid." ;
      		gyro_rate_f:coordinates = "../delta_time" ;
      		gyro_rate_f:flag_meanings = "invalid valid" ;
      		gyro_rate_f:flag_values = 0b, 1b ;
      	byte gyro_sat_f(delta_time) ;
      		gyro_sat_f:long_name = "IMU Gyro Saturation Bit (Gyros A, B, C, D)" ;
      		gyro_sat_f:units = "1" ;
      		gyro_sat_f:source = "ATL01/sc1/inertial_measurement_unit/hi_rate" ;
      		gyro_sat_f:valid_min = 0b ;
      		gyro_sat_f:valid_max = 1b ;
      		gyro_sat_f:contentType = "referenceInformation" ;
      		gyro_sat_f:description = "IMU Gyro saturation mode: Force to Rebalance (FTR) Mode (The gyro operates in this mode during low inertial rates) or Whole Angle Saturation (WAS) Mode (The gyro operates in this mode during high inertial rates)." ;
      		gyro_sat_f:coordinates = "../delta_time" ;
      		gyro_sat_f:flag_meanings = "ftr_mode was_mode" ;
      		gyro_sat_f:flag_values = 0b, 1b ;
      	byte gyro_scal_f(delta_time) ;
      		gyro_scal_f:long_name = "IMU Gyro Scaling Factor (Gyros A, B, C, D)" ;
      		gyro_scal_f:units = "1" ;
      		gyro_scal_f:source = "ATL01/sc1/inertial_measurement_unit/hi_rate" ;
      		gyro_scal_f:valid_min = 0b ;
      		gyro_scal_f:valid_max = 1b ;
      		gyro_scal_f:contentType = "referenceInformation" ;
      		gyro_scal_f:description = "IMU Gyro scale factor mode: low scaling factor mode with the corresponding Integrated Angle word being 0.05 arc-sec/LSB or high scaling factor with the corresponding Integrated Angle word being 1.6 arc-sec/LSB." ;
      		gyro_scal_f:coordinates = "../delta_time" ;
      		gyro_scal_f:flag_meanings = "low_scale_factor high_scale_factor" ;
      		gyro_scal_f:flag_values = 0b, 1b ;

      // group attributes:
      		:Description = "Contains parameters related to spacecraft IMU (Inertial Measurement Unit) gyros." ;
      		:data_rate = "Data within this main group are stored at the data rate of the source IMU high_rate data within the Spacecraft Ancillary Science Data Packet. (nominally fifty per second.)" ;
      } // group gyro_a

    group: gyro_b {
