      		e_tx_pce1_w:contentType = "referenceInformation" ;
      		e_tx_pce1_w:description = "Laser energy for the PCE1 weak spot derived from the analog HK telemetry and split by calibration." ;
      		e_tx_pce1_w:coordinates = "delta_time" ;
      	float e_tx_pce3_w(delta_time, ds_10) ;
