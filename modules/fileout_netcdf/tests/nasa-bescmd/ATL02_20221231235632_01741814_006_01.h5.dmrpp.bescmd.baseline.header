      		qa_at_n_rx_s:contentType = "qualityInformation" ;
      		qa_at_n_rx_s:description = "The number of Strong Rx events in the along-track interval." ;
      		qa_at_n_rx_s:coordinates = "../delta_time_start" ;
      	int qa_at_n_tep(delta_time_start) ;
