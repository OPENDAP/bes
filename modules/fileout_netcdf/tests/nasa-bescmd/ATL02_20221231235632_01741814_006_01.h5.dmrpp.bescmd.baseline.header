    		qa_s_tod_a_sla_hk:source = "Derived via L1B ATBD" ;
    		qa_s_tod_a_sla_hk:contentType = "qualityInformation" ;
    		qa_s_tod_a_sla_hk:description = "Summary statistics on the differences between successive A_SLA_HK time of day values. Values are in the order number_of_points, minimum, maximum, average, standard_deviation." ;
    		qa_s_tod_a_sla_hk:coordinates = "delta_time_start" ;
    	double qa_s_tod_sc_imu(delta_time_start, ds_statistics) ;
