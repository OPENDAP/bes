    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters related to GPSR housekeeping." ;
    		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;
    } // group hk

  group: time_correlation {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time, in seconds since the ATLAS SDP GPS Epoch, computed from raw_gps_time_sec and subseconds in the time correlation group. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	ushort utc_usec(delta_time) ;
    		utc_usec:long_name = "TCDR TCDR UTC Time - Microseconds" ;
    		utc_usec:units = "usec" ;
    		utc_usec:source = "ATL01/sc4/gpsr/time_correlation" ;
    		utc_usec:contentType = "referenceInformation" ;
    		utc_usec:description = "Time Correlation Data Record (TCDR) - UTC time representation of the synchronization time stamp. Number of microseconds of current day." ;
    		utc_usec:coordinates = "delta_time" ;
    	float tdop(delta_time) ;
    		tdop:long_name = "GPSR Time Dilution of Precision" ;
    		tdop:units = "meters" ;
    		tdop:source = "ATL01/sc4/gpsr/time_correlation converted" ;
    		tdop:contentType = "referenceInformation" ;
    		tdop:description = "GPSR - Time Dilution of Precision. Values greater than 655.34 are saturated to 655.34; Value set to 655.35 when NSM = 1 or in the case NSM = 5 with fewer than 4 SVs available." ;
    		tdop:coordinates = "delta_time" ;
    	byte nsm(delta_time) ;
    		nsm:long_name = "GPSR Navigation Solution Method (NSM)" ;
    		nsm:units = "1" ;
    		nsm:source = "ATL01/sc4/gpsr/time_correlation" ;
    		nsm:valid_min = 1b ;
    		nsm:valid_max = 7b ;
    		nsm:contentType = "referenceInformation" ;
    		nsm:description = "GPSR - Navigation Solution Method. 1 = Propagated  2 = Cold Start - First Nav Fix 3 = Cold Start - Least Squares Method w/ no GDOP Optimization 4 = Least Squares Method w/ all Visible SVs 5 = Kalman Filter Method (Normal Operation) 7 = Invalid Navigation Solution All other values invalid" ;
    		nsm:coordinates = "delta_time" ;
    		nsm:flag_meanings = "propagated cold_lsq_no_gdop lsqm_w_svs normal_lsqm normal_kalman unused invalid_solution" ;
    		nsm:flag_values = 1b, 2b, 3b, 4b, 5b, 6b, 7b ;
    	uint64 imt(delta_time) ;
    		imt:long_name = "TCDR Instrument Measurement Time" ;
    		imt:units = "counts" ;
    		imt:source = "ATL01/sc4/gpsr/time_correlation" ;
    		imt:contentType = "referenceInformation" ;
    		imt:description = "Time Correlation Data Record (TCDR) - Time Correlation Data Record (TCDR) - Instrument Measurement Time (IMT) representation of the synchronization time stamp. IMT precisely describes how the GPSR clock oscillator behaves, and is for internal and maintenance use only. This field contains the raw 64-bit IMT value. (Be aware of possible precision loss possible when converting to seconds.)" ;
    		imt:coordinates = "delta_time" ;
    	uint gps_time_sec(delta_time) ;
    		gps_time_sec:long_name = "TCDR GPS Time (Seconds)" ;
    		gps_time_sec:units = "seconds" ;
    		gps_time_sec:source = "ATL01/sc4/gpsr/time_correlation" ;
    		gps_time_sec:contentType = "referenceInformation" ;
    		gps_time_sec:description = "Time Correlation Data Record (TCDR) - GPS Time (GPST) representation of the synchronization time stamp. Total seconds elapsed since GPS epoch (6-Jan-1980 00:00:00) starting with 0. (Same data that is provided to ATLAS in RT)" ;
    		gps_time_sec:coordinates = "delta_time" ;
    	short time_qa(delta_time) ;
    		time_qa:long_name = "TCDR Time Quality Index" ;
    		time_qa:units = "nanoseconds" ;
    		time_qa:source = "ATL01/sc4/gpsr/time_correlation" ;
    		time_qa:valid_min = 0s ;
    		time_qa:valid_max = 4095s ;
    		time_qa:contentType = "referenceInformation" ;
    		time_qa:description = "Time Correlation Data Record (TCDR) - Time Quality Index. Nanoseconds; Values greater than 4095 ns are saturated to 4095 ns." ;
    		time_qa:coordinates = "delta_time" ;
    	uint gps_time_subsec(delta_time) ;
    		gps_time_subsec:long_name = "TCDR GPS Time (Subseconds)" ;
    		gps_time_subsec:units = "1/4294967296 seconds" ;
    		gps_time_subsec:source = "ATL01/sc4/gpsr/time_correlation" ;
    		gps_time_subsec:contentType = "referenceInformation" ;
    		gps_time_subsec:description = "Time Correlation Data Record (TCDR) - Subseconds portion of the GPS Time (GPST) representation of the synchronization time stamp. Total seconds elapsed since GPS epoch (6-Jan-1980 00:00:00) starting with 0. (Same data that is provided to ATLAS in RT)" ;
    		gps_time_subsec:coordinates = "delta_time" ;
    	ushort utc_days(delta_time) ;
    		utc_days:units = "days" ;
    		utc_days:long_name = "TCDR TCDR UTC Time - Days" ;
    		utc_days:source = "ATL01/sc4/gpsr/time_correlation" ;
    		utc_days:contentType = "referenceInformation" ;
    		utc_days:description = "Time Correlation Data Record (TCDR) - UTC time representation of the synchronization time stamp. Number of days since 1st January 2000, 00:00:00 starting with 0." ;
    		utc_days:coordinates = "delta_time" ;
    	uint utc_msec(delta_time) ;
    		utc_msec:units = "msec" ;
    		utc_msec:source = "ATL01/sc4/gpsr/time_correlation" ;
    		utc_msec:contentType = "referenceInformation" ;
    		utc_msec:description = "Time Correlation Data Record (TCDR) - UTC time representation of the synchronization time stamp. Number of milliseconds of current day." ;
    		utc_msec:coordinates = "delta_time" ;
    		utc_msec:long_name = "TCDR TCDR UTC Time - Milliseconds" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters related to GPSR time correlation data record (TCDR)." ;
    		:data_rate = "Data within this group are stored at the data rate of the source Spacecraft Ancillary Science Data Packets. (nominally one per second.)" ;
    } // group time_correlation
  } // group gpsr

group: lrs {

  // group attributes:
  		:Description = "Group contains the Laser Reference System (LRS) packet decommutated data" ;
  		:data_rate = "Data within this group are stored at the nominal rate of the corresponding LRS APIDs (varies per APID)." ;

  group: laser_centroid {
    dimensions:
    	delta_time = UNLIMITED ; // (211500 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Time values retrieved from the CCSDS header timestamps, relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	short cent_mag(delta_time) ;
    		cent_mag:units = "counts" ;
    		cent_mag:long_name = "LRS_LCENT centroid magitude" ;
    		cent_mag:source = "LRS_LCENT" ;
    		cent_mag:contentType = "referenceInformation" ;
    		cent_mag:description = "The 12-bit centroid magnitude. The centroids are the Transmit Laser Centroids and TAMS Centroids." ;
    		cent_mag:coordinates = "delta_time" ;
    	byte quality_f(delta_time) ;
    		quality_f:units = "1" ;
    		quality_f:long_name = "LRS_LCENT Centroid quality" ;
    		quality_f:source = "LRS_LCENT" ;
    		quality_f:valid_min = 0b ;
    		quality_f:valid_max = 1b ;
    		quality_f:contentType = "referenceInformation" ;
    		quality_f:description = "Flag indicates centroids pass basic validity checks in the LRS software.  0 = valid centroids; 1 = the corresponding centroid is considered questionable (that is, the corresponding centroid should not be expected to report a valid target with full accuracy). The win parameter within this group correlates the flags to tams/laser windows. However, the correlation of the windows to the actual tams/laser spots is not guaranteed." ;
    		quality_f:coordinates = "delta_time" ;
    		quality_f:flag_meanings = "valid questionable" ;
    		quality_f:flag_values = 0b, 1b ;
    	float cent_h(delta_time) ;
    		cent_h:long_name = "LRS_LCENT centroid H" ;
    		cent_h:units = "pixels" ;
    		cent_h:source = "LRS_LCENT" ;
    		cent_h:contentType = "referenceInformation" ;
    		cent_h:description = "The centroid H value. The centroids are the Transmit Laser Centroids and TAMS Centroids." ;
    		cent_h:coordinates = "delta_time" ;
    	uint centofintbase(delta_time) ;
    		centofintbase:units = "counts" ;
    		centofintbase:long_name = "Center of integration base" ;
    		centofintbase:source = "LRS" ;
    		centofintbase:contentType = "referenceInformation" ;
    		centofintbase:description = "Base age of centroids relative to secondary header timestamp. This 32-bit value indicates how many 843.75 kHz time ticks of offset should be applied between the secondary header timestamp and the center_of_integration for the laser centroids reported.  This time offset assumes that the secondary header timestamp represents an exact milli-second (that is, is accurate beyond the precision expressed in the timestamp).  The offset is based on the LRS internal 27 MHz oscillator (divided by 32), and it can express offset from zero to more than 84 minutes with about 1.185 micro second resolution.  Under normal operating conditions, the offset should never exceed 20 milli seconds (about 16875 counts).  Centroid timetags offset with this value alone should be adequate for coarse geo-location, but not precision geo-location knowledge as expected for science (individual centroid offsets are required for that purpose)." ;
    		centofintbase:coordinates = "delta_time" ;
    	byte trackstat_f(delta_time) ;
    		trackstat_f:units = "1" ;
    		trackstat_f:long_name = "LRS_LCENT Tracking status" ;
    		trackstat_f:source = "LRS_LCENT" ;
    		trackstat_f:valid_min = 0b ;
    		trackstat_f:valid_max = 1b ;
    		trackstat_f:contentType = "referenceInformation" ;
    		trackstat_f:description = "Flag indicates tracking status for centroid;  1 = valid tracking of that centroid window; 0 = the corresponding window is in a searching or acquiring state (that is, the corresponding centroid should not be considered to report a valid target).  The win parameter within this group correlates the flags to tams/laser windows. However, the correlation of the windows to the actual tams/laser spots is not guaranteed." ;
    		trackstat_f:coordinates = "delta_time" ;
    		trackstat_f:flag_meanings = "acq_state track_state" ;
    		trackstat_f:flag_values = 0b, 1b ;
    	byte win(delta_time) ;
    		win:long_name = "Window" ;
    		win:units = "1" ;
    		win:source = "LRS_LCENT" ;
    		win:valid_min = 0b ;
    		win:valid_max = 10b ;
    		win:contentType = "referenceInformation" ;
    		win:description = "Indicates the window corresponding to each component of the centmagtime and corresponding flags. Values of 1-4 correspond to TAMS windows; values of 5-10 correspond to laser windows. Assignment of a window to a particular spot is not guaranteed." ;
    		win:coordinates = "delta_time" ;
    		win:flag_meanings = "none tams0 tams1 tams2 tams3 laser1 laser2 laser3 laser4 laser5 laser6" ;
    		win:flag_values = 0b, 1b, 2b, 3b, 4b, 5b, 6b, 7b, 8b, 9b, 10b ;
    	float cent_v(delta_time) ;
    		cent_v:long_name = "LRS_LCENT centroid V" ;
    		cent_v:units = "pixels" ;
    		cent_v:source = "LRS_LCENT" ;
    		cent_v:contentType = "referenceInformation" ;
    		cent_v:description = "The centroid V value. The centroids are the Transmit Laser Centroids and TAMS Centroids." ;
    		cent_v:coordinates = "delta_time" ;
    	short coi_offset(delta_time) ;
    		coi_offset:units = "counts" ;
    		coi_offset:long_name = "Center of integration offset" ;
    		coi_offset:source = "LRS" ;
    		coi_offset:contentType = "referenceInformation" ;
    		coi_offset:description = "The signed 16-bit center of integration offset for this specific centroid." ;
    		coi_offset:coordinates = "delta_time" ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "Contains parameters relating to the Application Laser Centroid (LCENT) Data. The (Application Mode) Laser Centroid Data Packet contains reported Laser-Side Centroids, which are part of the core LRS data output.  This packet normally will contain 10 valid centroids, reported and stored at a nominally 50 Hz rate and is available through all data channels (SSR, real time telemetry, and onboard to the spacecraft ACS)." ;
    		:data_rate = "Data within this group are stored at the data rate of the source LRS Application Laser Centroid Data (nominally fifty per second)." ;
    } // group laser_centroid

  group: stellar_centroid {
    dimensions:
    	delta_time = UNLIMITED ; // (315 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Retrieved times from the CCSDS header timestamps, in seconds relative to the ATLAS SDP GPS Epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    	short coi_offset(delta_time) ;
    		coi_offset:long_name = "Center of integration offset" ;
    		coi_offset:units = "counts" ;
    		coi_offset:source = "LRS" ;
    		coi_offset:contentType = "referenceInformation" ;
    		coi_offset:description = "The signed 16-bit center of integration offset for this specific centroid." ;
    		coi_offset:coordinates = "delta_time" ;
    	short cent_mag(delta_time) ;
    		cent_mag:long_name = "LRS_LCENT centroid magitude" ;
    		cent_mag:units = "counts" ;
    		cent_mag:source = "LRS_LCENT" ;
    		cent_mag:contentType = "referenceInformation" ;
    		cent_mag:description = "The 12-bit centroid magnitude. From Word 2, bits 15 (MSB) to 4" ;
    		cent_mag:coordinates = "delta_time" ;
    	uint centofintbase(delta_time) ;
    		centofintbase:long_name = "Center of integration base" ;
    		centofintbase:units = "counts" ;
    		centofintbase:source = "LRS" ;
    		centofintbase:contentType = "referenceInformation" ;
    		centofintbase:description = "Base age of centroids relative to secondary header timestamp. This 32-bit value indicates how many 843.75 kHz time ticks of offset should be applied between the secondary header timestamp and the center_of_integration for the laser centroids reported.  This time offset assumes that the secondary header timestamp represents an exact milli-second (that is, is accurate beyond the precision expressed in the timestamp).  The offset is based on the LRS internal 27 MHz oscillator (divided by 32), and it can express offset from zero to more than 84 minutes with about 1.185 micro second resolution.  Under normal operating conditions, the offset should never exceed 20 milli seconds (about 16875 counts).  Centroid timetags offset with this value alone should be adequate for coarse geo-location, but not precision geo-location knowledge as expected for science (individual centroid offsets are required for that purpose)." ;
    		centofintbase:coordinates = "delta_time" ;
    	float cent_h(delta_time) ;
    		cent_h:long_name = "LRS_LCENT centroid H" ;
    		cent_h:units = "pixels" ;
    		cent_h:source = "LRS_LCENT" ;
    		cent_h:contentType = "referenceInformation" ;
    		cent_h:description = "The centroid H value." ;
    		cent_h:coordinates = "delta_time" ;
    	byte quality_f(delta_time) ;
    		quality_f:long_name = "LRS_LCENT Centroid quality" ;
    		quality_f:units = "1" ;
    		quality_f:source = "LRS_LCENT" ;
    		quality_f:valid_min = 0b ;
    		quality_f:valid_max = 1b ;
    		quality_f:contentType = "referenceInformation" ;
    		quality_f:description = "Flag indicates centroids pass basic validity checks in the LRS software.  0 indicate valid centroids; 1 indicate the corresponding centroid is considered questionable (that is, the corresponding centroid should not be expected to report a valid target with full accuracy)." ;
    		quality_f:coordinates = "delta_time" ;
    		quality_f:flag_meanings = "valid questionable" ;
    		quality_f:flag_values = 0b, 1b ;
    	float cent_v(delta_time) ;
    		cent_v:long_name = "LRS_LCENT centroid V" ;
    		cent_v:units = "pixels" ;
    		cent_v:source = "LRS_LCENT" ;
    		cent_v:contentType = "referenceInformation" ;
    		cent_v:description = "The centroid V value." ;
    		cent_v:coordinates = "delta_time" ;
    	byte trackstat_f(delta_time) ;
    		trackstat_f:units = "1" ;
    		trackstat_f:long_name = "LRS_LCENT Tracking status" ;
    		trackstat_f:source = "LRS_LCENT" ;
    		trackstat_f:valid_min = 0b ;
    		trackstat_f:valid_max = 1b ;
    		trackstat_f:contentType = "referenceInformation" ;
    		trackstat_f:description = "Flag indicates tracking status for centroid.  1 indicate valid tracking of that centroid window; 0 indicate the corresponding window is in a searching or acquiring state (that is, the corresponding centroid should not be considered to report a valid target)." ;
    		trackstat_f:coordinates = "delta_time" ;
    		trackstat_f:flag_meanings = "acq_state track_state" ;
    		trackstat_f:flag_values = 0b, 1b ;

    // group attributes:
    		:DODS_EXTRA.Unlimited_Dimension = "delta_time" ;
    		:Description = "The (Application Mode) Stellar Centroid Data Packet contains reported Stellar-Side Centroids, which are part of the core LRS data output.  This packet is normally reported and stored at a nominally 10 Hz rate with a variable number of stars reported and is available through all data channels (SSR, real time telemetry, and onboard to the spacecraft ACS)." ;
    		:data_rate = "Data within this group are stored at the data rate of the source LRS Stellar Centroid Data Packet. (nominally 10 per second.)" ;
    } // group stellar_centroid

  group: hk_1120 {
    dimensions:
    	delta_time = UNLIMITED ; // (423 currently)
    variables:
    	double delta_time(delta_time) ;
    		delta_time:long_name = "Elapsed GPS seconds" ;
    		delta_time:standard_name = "time" ;
    		delta_time:units = "seconds since 2018-01-01" ;
    		delta_time:source = "Derived via Time Tagging" ;
    		delta_time:contentType = "referenceInformation" ;
    		delta_time:description = "Number of GPS seconds since the ATLAS SDP epoch. The ATLAS Standard Data Products (SDP) epoch offset is defined within /ancillary_data/atlas_sdp_gps_epoch as the number of GPS seconds between the GPS epoch (removed date-time) and the ATLAS SDP epoch. By adding the offset contained within atlas_sdp_gps_epoch to delta time parameters, the time in gps_seconds relative to the GPS epoch can be computed." ;
    		delta_time:coordinates = "latitude longitude" ;
    	float srate_y(delta_time) ;
    		srate_y:long_name = "LRS_HK Stellar Pattern Rate  Y" ;
    		srate_y:units = "pixels/second" ;
    		srate_y:source = "LRS_HK" ;
    		srate_y:contentType = "referenceInformation" ;
    		srate_y:description = "Y component (tip/tilt) of the stellar rate pattern estimate" ;
    		srate_y:coordinates = "delta_time" ;
    	float pc_t(delta_time) ;
    		pc_t:long_name = "LRS_HK Processor Card Thermistor" ;
    		pc_t:units = "degreesC" ;
    		pc_t:source = "LRS_HK" ;
    		pc_t:contentType = "referenceInformation" ;
    		pc_t:description = "Temperature of Processor Card - 0x0000 = 0.000 V (nominal short;) 0xFFFF = +4.000 V (nominal open) [see thermistor scaling section later for temperature scaling]" ;
    		pc_t:coordinates = "delta_time" ;
    	uint spwdiscardlink(delta_time) ;
    		spwdiscardlink:long_name = "LRS_HK Spacewire tlm packets dropped due to link not available" ;
    		spwdiscardlink:units = "counts" ;
    		spwdiscardlink:source = "LRS_HK" ;
    		spwdiscardlink:contentType = "referenceInformation" ;
    		spwdiscardlink:description = "This 32-bit counter is incremented every time a spacewire telemetry packet is dropped by Failsafe Mode while waiting for a valid spacewire link between the LRS and MEB (an abnormal condition).  It starts at 0x00000000, and rolls over to 0x00000000 when it increments from 0xFFFFFFFF.  This counter will be reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT)." ;
    		spwdiscardlink:coordinates = "delta_time" ;
    	byte sysstat_ac_en(delta_time) ;
    		sysstat_ac_en:long_name = "LRS_HK System Status Register - Analog Converter Status" ;
    		sysstat_ac_en:units = "1" ;
    		sysstat_ac_en:source = "LRS_HK" ;
    		sysstat_ac_en:valid_min = 0b ;
    		sysstat_ac_en:valid_max = 1b ;
    		sysstat_ac_en:contentType = "referenceInformation" ;
    		sysstat_ac_en:description = "The current status of the LRS FPGA Analog Converter. (0 =DISABLED (abnormal condition); 1 = ENABLED (normal operating condition))" ;
    		sysstat_ac_en:coordinates = "delta_time" ;
    		sysstat_ac_en:flag_meanings = "disabled enabled" ;
    		sysstat_ac_en:flag_values = 0b, 1b ;
    	ushort timecnt(delta_time) ;
    		timecnt:long_name = "LRS_HK Valid Time Sync Command Counter" ;
    		timecnt:units = "counts" ;
    		timecnt:source = "LRS_HK" ;
    		timecnt:contentType = "referenceInformation" ;
    		timecnt:description = "The Valid Time Sync Command Counter is a 16-bit counter that increments each time that the Failsafe Mode processes a valid command of the corresponding command type.  A valid command is defined as a command that passes all verification tests.  The counter starts at 0x0000, and rolls over to 0x0000 when it increments from 0xFFFF.  The counter is reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT)." ;
    		timecnt:coordinates = "delta_time" ;
    	float m12v_ldc_mon_v(delta_time) ;
    		m12v_ldc_mon_v:long_name = "LRS_HK -12VDC LDC Monitor" ;
    		m12v_ldc_mon_v:units = "volts" ;
    		m12v_ldc_mon_v:source = "LRS_HK" ;
    		m12v_ldc_mon_v:contentType = "referenceInformation" ;
    		m12v_ldc_mon_v:description = "Voltage of -12VDC LDC Monitor - 0x0000 = 0.000 V; 0xBF9D = -12.000 V (nominal value); 0xFFFF = -16.000 V : A_LRS_HK.ANALOGHK[11]" ;
    		m12v_ldc_mon_v:coordinates = "delta_time" ;
    	ushort timeerrcnt(delta_time) ;
    		timeerrcnt:long_name = "LRS_HK Time Sync Command Error Counter" ;
    		timeerrcnt:units = "counts" ;
    		timeerrcnt:source = "LRS_HK" ;
    		timeerrcnt:contentType = "referenceInformation" ;
    		timeerrcnt:description = "The 16-bit Time Sync Command error Counter is incremented every time the Failsafe Mode has one or more command verification or processing errors with the corresponding command type (abnormal conditions).  The counter starts at 0x0000, and rolls over to 0x0000 when it increments from 0xFFFF.  The counter increments only once per command when there is at least one verification/processing error for that command.  TIMEERRCODE will indicate the type of error.  The counter is reset at power on and by a Failsafe Reset Counters Command (LRSfscmRSTCNT)." ;
    		timeerrcnt:coordinates = "delta_time" ;
    	float p5v_sdc_mon_v(delta_time) ;
