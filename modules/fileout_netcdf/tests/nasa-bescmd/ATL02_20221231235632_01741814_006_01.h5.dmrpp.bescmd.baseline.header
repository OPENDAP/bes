      		txrx_slip_flag:units = "1" ;
      		txrx_slip_flag:source = "TxRx detection" ;
      		txrx_slip_flag:valid_min = 0 ;
      		txrx_slip_flag:valid_max = 2 ;
      		txrx_slip_flag:contentType = "qualityInformation" ;
