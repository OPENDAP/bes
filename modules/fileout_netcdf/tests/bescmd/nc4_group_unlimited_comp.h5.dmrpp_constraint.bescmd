<?xml version="1.0" encoding="UTF-8"?>
<request reqID="some_unique_value" >
    <setContext name="dap_format">dap2</setContext>
    <setContainer name="data" space="catalog">/data/nc4_group_unlimited_comp.h5.dmrpp</setContainer>
    <define name="d">
	<container name="data" >
           <dap4constraint>/g1/dim2[0:1:1];/g1/d2[0:1:0][0:1:1]</dap4constraint>
        </container>
    </define>
    <get type="dap" definition="d" returnAs="netcdf-4"/>
</request>
