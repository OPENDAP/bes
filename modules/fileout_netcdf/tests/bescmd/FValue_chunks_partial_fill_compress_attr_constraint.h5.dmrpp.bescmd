<?xml version="1.0" encoding="UTF-8"?>
<request reqID="some_unique_value" >
    <setContext name="dap_format">dap4</setContext>
    <setContainer name="c" space="catalog">/data/FValue_chunks_partial_fill_compress_attr.h5.dmrpp</setContainer>
    <define name="d">
	   <container name="c" >
           <dap4constraint>/chunks_some_fill[0:1:2][0:1:1]</dap4constraint>
           </container>
    </define>
    <get type="dap" definition="d" returnAs="netcdf-4"/>
</request>
